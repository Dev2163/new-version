{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footwear-picks-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-footwear-picks-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-footwear-picks-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-footwear-picks-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.title_font.family }}, {{ block.settings.title_font.fallback_families }};
    font-weight: {{ block.settings.title_font.weight }};
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    text-transform: uppercase;
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
    margin: 0;
  }

  .ai-footwear-picks-view-all-{{ ai_gen_id }} {
    font-family: {{ block.settings.link_font.family }}, {{ block.settings.link_font.fallback_families }};
    font-weight: {{ block.settings.link_font.weight }};
    font-size: {{ block.settings.link_size }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.link_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    background-color: {{ block.settings.button_background }};
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-block;
  }

  .ai-footwear-picks-view-all-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: radial-gradient(circle, {{ block.settings.link_color }} 0%, transparent 70%);
    transform: translate(-50%, -50%);
    transition: width 0.5s ease, height 0.5s ease;
    z-index: 0;
    opacity: 0.2;
  }

  .ai-footwear-picks-view-all-{{ ai_gen_id }}:hover::before {
    width: 300px;
    height: 300px;
  }

  .ai-footwear-picks-view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    border-color: {{ block.settings.button_hover_border }};
    color: {{ block.settings.button_hover_text }};
    transform: translateY(-2px);
    box-shadow: 0 4px 20px {{ block.settings.button_glow_color }};
  }

  .ai-footwear-picks-view-all-text-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
  }

  .ai-footwear-picks-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.products_per_row }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-footwear-picks-grid-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-footwear-picks-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .ai-footwear-picks-card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    border-color: {{ block.settings.hover_border_color }};
    box-shadow: 0 {{ block.settings.hover_lift }}px {{ block.settings.glow_spread }}px {{ block.settings.glow_blur }}px {{ block.settings.glow_color }};
  }

  .ai-footwear-picks-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: {{ block.settings.image_spacing }}px;
  }

  .ai-footwear-picks-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-footwear-picks-card-{{ ai_gen_id }}:hover .ai-footwear-picks-image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_zoom_scale }});
  }

  .ai-footwear-picks-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-footwear-picks-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-footwear-picks-info-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-footwear-picks-product-title-{{ ai_gen_id }} {
    font-family: {{ block.settings.product_title_font.family }}, {{ block.settings.product_title_font.fallback_families }};
    font-weight: {{ block.settings.product_title_font.weight }};
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
    transition: all 0.3s ease;
    text-transform: {{ block.settings.product_title_transform }};
  }

  .ai-footwear-picks-card-{{ ai_gen_id }}:hover .ai-footwear-picks-product-title-{{ ai_gen_id }} {
    color: {{ block.settings.hover_title_color }};
    text-shadow: 0 0 {{ block.settings.title_glow_blur }}px {{ block.settings.hover_title_color }};
  }

  .ai-footwear-picks-product-price-{{ ai_gen_id }} {
    font-family: {{ block.settings.price_font.family }}, {{ block.settings.price_font.fallback_families }};
    font-weight: {{ block.settings.price_font.weight }};
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-footwear-picks-empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.title_color }};
    opacity: 0.6;
  }

  @media screen and (max-width: 989px) {
    .ai-footwear-picks-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_tablet }}, 1fr);
    }

    .ai-footwear-picks-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-footwear-picks-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.products_per_row_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap | times: 0.7 }}px;
    }

    .ai-footwear-picks-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.6);
    }

    .ai-footwear-picks-view-all-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.link_size }}px * 0.8);
      padding: {{ block.settings.button_padding_vertical | times: 0.8 }}px {{ block.settings.button_padding_horizontal | times: 0.8 }}px;
    }

    .ai-footwear-picks-card-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding | times: 0.7 }}px;
    }
  }
{% endstyle %}

<footwear-picks-{{ ai_gen_id }} class="ai-footwear-picks-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footwear-picks-container-{{ ai_gen_id }}">
    <div class="ai-footwear-picks-header-{{ ai_gen_id }}">
      <h2 class="ai-footwear-picks-title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
      {% if block.settings.view_all_link != blank %}
        <a href="{{ block.settings.view_all_link }}" class="ai-footwear-picks-view-all-{{ ai_gen_id }}">
          <span class="ai-footwear-picks-view-all-text-{{ ai_gen_id }}">{{ block.settings.view_all_text }}</span>
        </a>
      {% endif %}
    </div>

    {% if block.settings.product_list != blank and block.settings.product_list.size > 0 %}
      <div class="ai-footwear-picks-grid-{{ ai_gen_id }}">
        {% for product in block.settings.product_list limit: block.settings.products_to_show %}
          <div class="ai-footwear-picks-card-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-footwear-picks-link-{{ ai_gen_id }}">
              <div class="ai-footwear-picks-image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-footwear-picks-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: block.settings.image_aspect_ratio }}"
                  >
                {% else %}
                  <div class="ai-footwear-picks-image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              <div class="ai-footwear-picks-info-{{ ai_gen_id }}">
                <h3 class="ai-footwear-picks-product-title-{{ ai_gen_id }}">{{ product.title }}</h3>
                <p class="ai-footwear-picks-product-price-{{ ai_gen_id }}">{{ product.price | money }}</p>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-footwear-picks-empty-state-{{ ai_gen_id }}">
        <p>Next, add products to showcase your footwear collection</p>
      </div>
    {% endif %}
  </div>
</footwear-picks-{{ ai_gen_id }}>

<script>
  (function() {
    class FootwearPicks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const cards = this.querySelectorAll('.ai-footwear-picks-card-{{ ai_gen_id }}');
        cards.forEach(card => {
          card.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('footwear-picks-{{ ai_gen_id }}', FootwearPicks{{ ai_gen_id }});
  })();
</script>

