{% comment %}
  ONE9 AI Shopping Assistant — Nova AI Chat Widget Snippet
{% comment %}

<!-- Nova AI Floating Trigger -->
<div id="nova-chat-trigger" class="nova-trigger" onclick="toggleNovaChat()" style="position: fixed !important; bottom: 28px !important; right: 24px !important; z-index: 2147483647 !important; display: flex !important; visibility: visible !important; opacity: 1 !important;">
  <div class="nova-trigger__icon">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f4c430" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
      <rect x="4" y="8" width="16" height="12" rx="2"/>
      <circle cx="9" cy="13" r="1.5" fill="#f4c430"/>
      <circle cx="15" cy="13" r="1.5" fill="#f4c430"/>
      <path d="M10 17h4"/>
    </svg>
  </div>
  <span class="nova-trigger__label">NOVA AI</span>
  <span class="nova-trigger__pulse"></span>
</div>

<!-- Nova AI Chat Window -->
<div id="nova-chat-window" class="nova-window" style="display: none; position: fixed !important; bottom: 88px !important; right: 24px !important; z-index: 2147483647 !important;">
  <!-- Header -->
  <div class="nova-header">
    <div class="nova-header__title-group">
      <div class="nova-avatar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#000" stroke-width="2">
          <path d="M12 2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2 2 2 0 0 1-2-2V4a2 2 0 0 1 2-2z"/>
          <rect x="4" y="8" width="16" height="12" rx="2"/>
          <circle cx="9" cy="13" r="1.5" fill="#000"/>
          <circle cx="15" cy="13" r="1.5" fill="#000"/>
        </svg>
      </div>
      <div>
        <div class="nova-header__name">Nova AI</div>
        <div class="nova-header__status"><span class="status-dot"></span> Online • Streetwear Assistant</div>
      </div>
    </div>

    <div class="nova-header__actions">
      <!-- Language Pills -->
      <div class="nova-lang-selector">
        <button type="button" class="lang-btn active" data-lang="en" onclick="switchNovaLang('en')">EN</button>
        <button type="button" class="lang-btn" data-lang="hi" onclick="switchNovaLang('hi')">HI</button>
        <button type="button" class="lang-btn" data-lang="gu" onclick="switchNovaLang('gu')">GU</button>
      </div>
      <button type="button" class="nova-close-btn" onclick="toggleNovaChat()">&times;</button>
    </div>
  </div>

  <!-- Messages Body -->
  <div id="nova-chat-messages" class="nova-messages">
    <!-- Messages appended dynamically -->
  </div>

  <!-- Quick Reply Chips -->
  <div id="nova-chat-chips" class="nova-chips">
    <button type="button" onclick="sendNovaQuickReply('Recommend Outfits')">🔥 Outfits</button>
    <button type="button" onclick="sendNovaQuickReply('Size Guide')">📏 Size Guide</button>
    <button type="button" onclick="sendNovaQuickReply('Track Order')">📦 Track Order</button>
    <button type="button" onclick="sendNovaQuickReply('Coupons')">🏷️ Discounts</button>
    <button type="button" onclick="sendNovaQuickReply('Upcoming Drop')">🚀 Drop 002</button>
    <button type="button" onclick="window.requestNovaPushNotification ? window.requestNovaPushNotification() : sendNovaQuickReply('Push Alerts')">🔔 Push Alerts</button>
  </div>

  <!-- Input Bar -->
  <form id="nova-chat-form" onsubmit="handleNovaSubmit(event)" class="nova-input-bar">
    <input type="text" id="nova-chat-input" placeholder="Ask Nova AI anything..." autocomplete="off">
    <button type="submit" id="nova-chat-send">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </form>
</div>

<style>
  .nova-trigger {
    position: fixed !important;
    bottom: 28px !important;
    right: 24px !important;
    z-index: 99999999 !important;
    background: #080808 !important;
    border: 2px solid #f4c430 !important;
    border-radius: 50px !important;
    padding: 8px 16px 8px 10px !important;
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    cursor: pointer !important;
    box-shadow: 0 8px 25px rgba(244, 196, 48, 0.4) !important;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1) !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
  .nova-trigger:hover {
    transform: translateY(-3px) scale(1.03) !important;
    box-shadow: 0 12px 30px rgba(244, 196, 48, 0.6) !important;
  }
  .nova-trigger__icon {
    width: 34px !important;
    height: 34px !important;
    background: rgba(244, 196, 48, 0.15) !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .nova-trigger__label {
    font-family: 'Orbitron', sans-serif !important;
    font-size: 11px !important;
    font-weight: 900 !important;
    color: #ffffff !important;
    letter-spacing: 1px !important;
  }
  .nova-trigger__pulse {
    width: 8px !important;
    height: 8px !important;
    border-radius: 50% !important;
    background: #22c55e !important;
    box-shadow: 0 0 8px #22c55e !important;
    animation: novaPulse 1.8s infinite !important;
  }
  @keyframes novaPulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 197, 94, 0); }
  }

  .nova-window {
    position: fixed !important;
    bottom: 88px !important;
    right: 24px !important;
    width: min(380px, calc(100vw - 32px)) !important;
    height: 540px !important;
    max-height: calc(100vh - 110px) !important;
    z-index: 99999999 !important;
    background: #0a0a0a !important;
    border: 1px solid rgba(244, 196, 48, 0.4) !important;
    border-radius: 16px !important;
    display: flex !important;
    flex-direction: column !important;
    box-shadow: 0 20px 50px rgba(0,0,0,0.8), 0 0 30px rgba(244, 196, 48, 0.15) !important;
    overflow: hidden !important;
    animation: novaSlideUp 0.3s ease-out !important;
  }

  @media screen and (max-width: 749px) {
    .nova-trigger {
      bottom: 80px !important;
      right: 16px !important;
    }
    .nova-window {
      bottom: 135px !important;
      right: 12px !important;
      height: 480px !important;
    }
  }

  .nova-header {
    background: #111111 !important;
    padding: 12px 16px !important;
    border-bottom: 1px solid rgba(255,255,255,0.1) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
  }
  .nova-header__title-group {
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
  }
  .nova-avatar {
    width: 32px !important;
    height: 32px !important;
    background: #f4c430 !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
  .nova-header__name {
    font-family: 'Orbitron', sans-serif !important;
    font-size: 13px !important;
    font-weight: 800 !important;
    color: #ffffff !important;
    letter-spacing: 0.5px !important;
  }
  .nova-header__status {
    font-family: 'Rajdhani', sans-serif !important;
    font-size: 11px !important;
    color: #a0a0a0 !important;
    display: flex !important;
    align-items: center !important;
    gap: 5px !important;
  }
  .status-dot {
    width: 6px !important;
    height: 6px !important;
    border-radius: 50% !important;
    background: #22c55e !important;
  }

  .nova-header__actions {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
  }
  .nova-lang-selector {
    display: flex !important;
    background: rgba(255,255,255,0.06) !important;
    padding: 2px !important;
    border-radius: 20px !important;
    border: 1px solid rgba(255,255,255,0.1) !important;
  }
  .lang-btn {
    background: transparent !important;
    border: none !important;
    color: #888 !important;
    font-family: 'Orbitron', sans-serif !important;
    font-size: 9px !important;
    font-weight: 700 !important;
    padding: 3px 6px !important;
    border-radius: 12px !important;
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .lang-btn.active {
    background: #f4c430 !important;
    color: #000 !important;
  }
  .nova-close-btn {
    background: transparent !important;
    border: none !important;
    color: #aaa !important;
    font-size: 22px !important;
    line-height: 1 !important;
    cursor: pointer !important;
    padding: 0 4px !important;
  }
  .nova-close-btn:hover { color: #fff !important; }

  .nova-messages {
    flex: 1 !important;
    padding: 16px !important;
    overflow-y: auto !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 12px !important;
    scrollbar-width: thin !important;
  }

  .msg-bubble {
    max-width: 85% !important;
    padding: 10px 14px !important;
    border-radius: 12px !important;
    font-family: 'Rajdhani', sans-serif !important;
    font-size: 14px !important;
    line-height: 1.45 !important;
    word-break: break-word !important;
  }
  .msg-bubble--bot {
    align-self: flex-start !important;
    background: #181818 !important;
    color: #eeeeee !important;
    border: 1px solid rgba(255,255,255,0.08) !important;
    border-top-left-radius: 2px !important;
  }
  .msg-bubble--user {
    align-self: flex-end !important;
    background: #f4c430 !important;
    color: #000000 !important;
    font-weight: 700 !important;
    border-top-right-radius: 2px !important;
  }

  .nova-product-card {
    background: #141414 !important;
    border: 1px solid rgba(244, 196, 48, 0.3) !important;
    border-radius: 8px !important;
    padding: 8px !important;
    margin-top: 8px !important;
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
  }
  .nova-product-card img {
    width: 48px !important;
    height: 48px !important;
    object-fit: contain !important;
    background: #fff !important;
    border-radius: 4px !important;
  }
  .nova-product-card__info {
    flex: 1 !important;
  }
  .nova-product-card__title {
    font-family: 'Orbitron', sans-serif !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    color: #fff !important;
  }
  .nova-product-card__price {
    font-family: 'Rajdhani', sans-serif !important;
    font-size: 12px !important;
    font-weight: 700 !important;
    color: #f4c430 !important;
  }
  .nova-product-card__btn {
    background: #f4c430 !important;
    color: #000 !important;
    font-family: 'Orbitron', sans-serif !important;
    font-size: 9px !important;
    font-weight: 800 !important;
    padding: 6px 10px !important;
    border-radius: 4px !important;
    text-decoration: none !important;
    text-transform: uppercase !important;
  }

  .nova-chips {
    padding: 8px 12px !important;
    display: flex !important;
    gap: 6px !important;
    overflow-x: auto !important;
    background: #0d0d0d !important;
    border-top: 1px solid rgba(255,255,255,0.05) !important;
    scrollbar-width: none !important;
  }
  .nova-chips::-webkit-scrollbar { display: none !important; }
  .nova-chips button {
    background: rgba(255,255,255,0.05) !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    color: #ccc !important;
    font-family: 'Rajdhani', sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    padding: 5px 10px !important;
    border-radius: 14px !important;
    white-space: nowrap !important;
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .nova-chips button:hover {
    background: #f4c430 !important;
    color: #000 !important;
    border-color: #f4c430 !important;
  }

  .nova-input-bar {
    display: flex !important;
    padding: 10px !important;
    background: #111 !important;
    border-top: 1px solid rgba(255,255,255,0.1) !important;
    gap: 8px !important;
  }
  .nova-input-bar input {
    flex: 1 !important;
    background: #1c1c1c !important;
    border: 1px solid rgba(255,255,255,0.15) !important;
    border-radius: 8px !important;
    padding: 10px 14px !important;
    color: #fff !important;
    font-family: 'Rajdhani', sans-serif !important;
    font-size: 14px !important;
    outline: none !important;
  }
  .nova-input-bar input:focus {
    border-color: #f4c430 !important;
  }
  .nova-input-bar button {
    background: #f4c430 !important;
    color: #000 !important;
    border: none !important;
    border-radius: 8px !important;
    width: 40px !important;
    height: 40px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: transform 0.2s ease !important;
  }
  .nova-input-bar button:hover {
    transform: scale(1.05) !important;
  }
</style>

<script>
  (function() {
    let currentLang = 'en';

    const sampleCatalog = [
      { id: 1, name: "Oversized Acid Wash Tee", price: "£44.00", image: "https://cdn.shopify.com/s/files/1/0000/0000/files/placeholder.png", url: "/products/one9-the-mars-royal-quarter-zip" },
      { id: 2, name: "Boxy Fit Graphic Hoodie", price: "£46.00", image: "https://cdn.shopify.com/s/files/1/0000/0000/files/placeholder.png", url: "/products/one9-the-aries-cosmic-hoodie" },
      { id: 3, name: "Cargo Jogger Pants", price: "£42.00", image: "https://cdn.shopify.com/s/files/1/0000/0000/files/placeholder.png", url: "/collections/all" },
      { id: 4, name: "Chunky Retro Sneakers", price: "£65.00", image: "https://cdn.shopify.com/s/files/1/0000/0000/files/placeholder.png", url: "/collections/shoes" }
    ];

    const sampleOrders = {
      "ONE9-1001": { status: "Shipped", courier: "Delhivery", eta: "2 days" },
      "ONE9-1002": { status: "Out for Delivery", courier: "Bluedart", eta: "Today" },
      "ONE9-1003": { status: "Processing", courier: "Standard Express", eta: "3-4 days" },
      "ONE9-1004": { status: "Delivered", courier: "Ecom Express", eta: "Delivered" }
    };

    const welcomes = {
      en: "Yo! 👋 I'm Nova AI, your ONE9 streetwear assistant. Need outfit recommendations, size help, discount codes, or order tracking?",
      hi: "नमस्ते! 👋 मैं Nova AI हूँ, आपका ONE9 स्ट्रीटवेयर असिस्टेंट। साइज़, डिस्काउंट या आर्डर ट्रैकिंग में मदद चाहिए?",
      gu: "નમસ્તે! 👋 હું Nova AI છું, તમારો ONE9 સ્ટ્રીટવેર આસિસ્ટન્ટ. સાઈઝ, ડિસ્કાઉન્ટ કોડ કે ઓર્ડર ટ્રેકિંગમાં મદદ જોઈએ છે?"
    };

    window.toggleNovaChat = function() {
      const win = document.getElementById('nova-chat-window');
      if (!win) return;
      if (win.style.display === 'none' || win.style.display === '') {
        win.style.display = 'flex';
        const msgBox = document.getElementById('nova-chat-messages');
        if (msgBox && msgBox.children.length === 0) {
          addBotMessage(welcomes[currentLang]);
        }
      } else {
        win.style.display = 'none';
      }
    };

    window.switchNovaLang = function(lang) {
      currentLang = lang;
      document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.getAttribute('data-lang') === lang);
      });
      addBotMessage(welcomes[lang]);
    };

    window.sendNovaQuickReply = function(text) {
      addUserMessage(text);
      processNovaAI(text);
    };

    window.handleNovaSubmit = function(e) {
      e.preventDefault();
      const input = document.getElementById('nova-chat-input');
      const query = input.value.trim();
      if (!query) return;
      input.value = '';
      addUserMessage(query);
      processNovaAI(query);
    };

    function addUserMessage(text) {
      const box = document.getElementById('nova-chat-messages');
      const bubble = document.createElement('div');
      bubble.className = 'msg-bubble msg-bubble--user';
      bubble.textContent = text;
      box.appendChild(bubble);
      box.scrollTop = box.scrollHeight;
    }

    function addBotMessage(text, cards = []) {
      const box = document.getElementById('nova-chat-messages');
      const bubble = document.createElement('div');
      bubble.className = 'msg-bubble msg-bubble--bot';
      bubble.innerHTML = text.replace(/\n/g, '<br>');

      if (cards && cards.length > 0) {
        cards.forEach(prod => {
          const cardEl = document.createElement('div');
          cardEl.className = 'nova-product-card';
          cardEl.innerHTML = `
            <img src="${prod.image}" alt="${prod.name}">
            <div class="nova-product-card__info">
              <div class="nova-product-card__title">${prod.name}</div>
              <div class="nova-product-card__price">${prod.price}</div>
            </div>
            <a href="${prod.url}" class="nova-product-card__btn">VIEW</a>
          `;
          bubble.appendChild(cardEl);
        });
      }

      box.appendChild(bubble);
      box.scrollTop = box.scrollHeight;
    }

    function processNovaAI(query) {
      const q = query.toLowerCase();

      // 1. Order Tracking
      const orderMatch = query.match(/ONE9-\d{4}/i);
      if (orderMatch) {
        const orderId = orderMatch[0].toUpperCase();
        const order = sampleOrders[orderId];
        if (order) {
          if (currentLang === 'hi') {
            addBotMessage(`📦 ऑर्ड र **${orderId}** સ્ટેટસ: **${order.status}**\n🚚 कूरियर: ${order.courier}\n⏱️ Delivery: ${order.eta}`);
          } else if (currentLang === 'gu') {
            addBotMessage(`📦 ઓર્ડર **${orderId}** સ્ટેટસ: **${order.status}**\n🚚 કુરિયર: ${order.courier}\n⏱️ ડિલિવરી સમય: ${order.eta}`);
          } else {
            addBotMessage(`📦 Order **${orderId}** Status: **${order.status}**\n🚚 Courier: ${order.courier}\n⏱️ Expected Delivery: ${order.eta}`);
          }
        } else {
          addBotMessage(`Sorry, I couldn't find order ${orderId}. Let me connect you with human support on WhatsApp.`, [
            { name: "Chat on WhatsApp Support", price: "Direct Help", image: "https://cdn-icons-png.flaticon.com/512/3670/3670051.png", url: "https://wa.me/447000000000" }
          ]);
        }
        return;
      }

      // 2. Track Order intent without ID
      if (q.includes('track') || q.includes('order') || q.includes('ઓર્ડર') || q.includes('ऑर्डर')) {
        addBotMessage("Please provide your Order ID (e.g., ONE9-1001) to check live status!");
        return;
      }

      // 3. Coupons & Offers
      if (q.includes('coupon') || q.includes('code') || q.includes('discount') || q.includes('offer') || q.includes('ડિસ્કાઉન્ટ')) {
        addBotMessage("🏷️ **Active ONE9 Coupons:**\n\n• **WELCOME10** — 10% off your first order\n• **FLAT200** — Flat discount on orders above ₹1999");
        return;
      }

      // 4. Upcoming Drop
      if (q.includes('drop') || q.includes('launch') || q.includes('windbreaker') || q.includes('new') || q.includes('લૉન્ચ')) {
        addBotMessage("🚀 **ONE9 Reflective Windbreaker — Drop 002**\n📅 Launching: August 1, 2026\n\nWater-resistant, reflective piping, oversized cut — limited run of 300 pieces!\n\nWant early VIP notification? Type your Name & Email/Phone!");
        return;
      }

      // 5. Size Recommendation
      if (q.includes('size') || q.includes('fit') || q.includes('સાંકડું') || q.includes('સાઈઝ')) {
        if (q.includes('kg') || q.includes('ft') || q.includes('cm') || q.includes('height')) {
          addBotMessage("Based on your measurements, I recommend **Large (L)** for that signature ONE9 oversized streetwear fit! 🔥");
        } else {
          addBotMessage("What is your height and weight? (e.g. 5ft 10in, 70kg). I'll calculate the perfect ONE9 fit for you!");
        }
        return;
      }

      // 6. Outfits / Recommendations
      if (q.includes('outfit') || q.includes('recommend') || q.includes('shirt') || q.includes('hoodie') || q.includes('shoe') || q.includes('કપડાં')) {
        addBotMessage("Here are top-selling ONE9 streetwear pieces recommended for you:", sampleCatalog.slice(0, 2));
        return;
      }

      // Default Response
      addBotMessage("Got it! I can help you with size guides, special discount codes (WELCOME10), tracking your order, or recommending top drops!", sampleCatalog.slice(0, 1));
    }

    // FCM Notification Request Helper
    window.requestNovaPushNotification = function() {
      if (!('Notification' in window)) {
        addBotMessage("Push notifications are not supported in this browser.");
        return;
      }
      Notification.requestPermission().then((permission) => {
        if (permission === 'granted') {
          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register("{{ 'firebase-messaging-sw.js' | asset_url }}")
              .then(() => {
                addBotMessage("🔔 **VIP Push Notifications Enabled!**\n\nYou will receive instant alerts for new streetwear drops, restocks & order updates!");
              })
              .catch(() => {
                addBotMessage("🔔 VIP Notifications Allowed!");
              });
          } else {
            addBotMessage("🔔 VIP Notifications Allowed!");
          }
        } else {
          addBotMessage("Notification permission was not granted.");
        }
      });
    // Auto-mount widget directly to document.body to escape any parent section clipping or container stacking contexts
    function initNovaWidget() {
      const trigger = document.getElementById('nova-chat-trigger');
      const win = document.getElementById('nova-chat-window');
      if (trigger && document.body && trigger.parentElement !== document.body) {
        document.body.appendChild(trigger);
      }
      if (win && document.body && win.parentElement !== document.body) {
        document.body.appendChild(win);
      }
    }

    if (document.readyState === 'interactive' || document.readyState === 'complete') {
      initNovaWidget();
    } else {
      document.addEventListener('DOMContentLoaded', initNovaWidget);
    }
    setTimeout(initNovaWidget, 500);
    setTimeout(initNovaWidget, 1500);
  })();
</script>
