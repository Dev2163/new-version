{%- doc -%}
  Custom Product Card specifically designed for Shoes (Dark Theme).
  Usage: {% render 'shoe-product-card', product: product %}
{%- enddoc -%}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_image | default: product.featured_media.preview_image
-%}

<div class="dark-shoe-card">
  <!-- Top Badge -->
  {%- if product.available == false -%}
    <div class="dark-shoe-card__badge dark-shoe-card__badge--soldout">Sold Out</div>
  {%- elsif product.tags contains 'New' or product.tags contains 'new' -%}
    <div class="dark-shoe-card__badge dark-shoe-card__badge--new">NEW</div>
  {%- endif -%}

  <!-- Image -->
  <a href="{{ product.url }}" class="dark-shoe-card__image-link">
    {%- if featured_image -%}
      <img 
        src="{{ featured_image | image_url: width: 600 }}" 
        alt="{{ featured_image.alt | escape }}" 
        class="dark-shoe-card__image"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'dark-shoe-card__image placeholder' }}
    {%- endif -%}
  </a>

  <div class="dark-shoe-card__details">
    <!-- Swatches -->
    <div class="dark-shoe-card__swatches">
      {%- assign related_colors = product.metafields.custom.related_colors.value -%}
      {%- if related_colors != blank -%}
        
        <!-- Current product swatch ALWAYS shown exactly once -->
        {%- assign unique_color_ids = product.id | append: "" -%}
        <a href="{{ product.url }}" class="dark-shoe-card__swatch is-active" style="background: #fff; overflow: hidden; display: flex; justify-content: center; align-items: center;" title="{{ product.title }}">
          <img src="{{ product.featured_media | image_url: width: 40 }}" style="width: 100%; height: 100%; object-fit: contain; border-radius: 50%;">
        </a>

        <!-- Related colors swatches (Filtered for duplicates) -->
        {%- for related_item in related_colors limit: 5 -%}
          {%- assign item_id_str = related_item.id | append: "" -%}
          {%- unless unique_color_ids contains item_id_str -%}
            <a href="{{ related_item.url }}" class="dark-shoe-card__swatch" style="background: #fff; overflow: hidden; display: flex; justify-content: center; align-items: center;" title="{{ related_item.title }}">
              {%- assign swatch_img = related_item.featured_media | default: related_item.image -%}
              {%- if swatch_img -%}
                <img src="{{ swatch_img | image_url: width: 40 }}" style="width: 100%; height: 100%; object-fit: contain; border-radius: 50%;">
              {%- endif -%}
            </a>
            {%- assign unique_color_ids = unique_color_ids | append: "," | append: item_id_str -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback if no related colors -->
        {%- assign color_options = product.options_with_values | where: 'name', 'Color' -%}
        {%- if color_options.size > 0 -%}
          {%- for value in color_options[0].values limit: 4 -%}
            <span class="dark-shoe-card__swatch" style="background-color: {{ value | handleize }};" title="{{ value }}"></span>
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    </div>

    <!-- Title and Type -->
    <h3 class="dark-shoe-card__title">
      <a href="{{ product.url }}">{{ product.title | default: 'Example Shoe' }}</a>
    </h3>
    <p class="dark-shoe-card__type">{{ product.type | default: 'Running Shoes' }}</p>

    <!-- Footer: Price and Add to Cart -->
    <div class="dark-shoe-card__footer">
      <div class="dark-shoe-card__price">
        {%- if product.price_varies -%}
          From {{ product.price_min | money }}
        {%- else -%}
          {{ product.price | money | default: '£129.00' }}
        {%- endif -%}
      </div>
      
      <form method="post" action="/cart/add" class="dark-shoe-card__form">
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <button type="submit" class="dark-shoe-card__cart-btn" aria-label="Add to cart" {% unless product.available %}disabled{% endunless %}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  .dark-shoe-card {
    background-color: #151515;
    border-radius: 12px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.3s ease, background-color 0.3s ease;
    height: 100%;
    min-height: 380px;
  }
  
  .dark-shoe-card:hover {
    background-color: #1a1a1a;
    transform: translateY(-5px);
  }

  .dark-shoe-card__badge {
    position: absolute;
    top: 20px;
    left: 20px;
    padding: 4px 10px;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 2;
  }
  
  .dark-shoe-card__badge--new {
    background-color: #FF8C00;
    color: #fff;
  }
  
  .dark-shoe-card__badge--soldout {
    background-color: #333;
    color: #fff;
  }

  .dark-shoe-card__image-link {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 30px 20px;
    margin-bottom: 15px;
    text-decoration: none;
    background-color: #ffffff;
    border-radius: 8px;
    position: relative;
    overflow: hidden;
  }

  .dark-shoe-card__image {
    width: 100%;
    max-width: 240px;
    height: auto;
    object-fit: contain;
    transition: transform 0.4s ease;
    /* Optional: filter: drop-shadow(0 15px 15px rgba(0,0,0,0.2)); if they want shadow on white */
  }
  
  .dark-shoe-card:hover .dark-shoe-card__image {
    transform: scale(1.05) rotate(-2deg);
  }

  .dark-shoe-card__details {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 15px;
  }

  .dark-shoe-card__swatches {
    display: flex;
    gap: 8px;
    margin-bottom: 8px;
    align-items: center;
  }

  .dark-shoe-card__swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: inline-block;
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  
  .dark-shoe-card__swatch:hover,
  .dark-shoe-card__swatch.is-active {
    border-color: #FF8C00;
    transform: scale(1.1);
  }

  .dark-shoe-card__title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    font-family: 'Inter', sans-serif;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .dark-shoe-card__title a {
    color: #ffffff;
    text-decoration: none;
  }

  .dark-shoe-card__type {
    margin: 0;
    font-size: 13px;
    color: #888888;
    font-family: 'Inter', sans-serif;
  }

  .dark-shoe-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 12px;
  }

  .dark-shoe-card__price {
    color: #FF8C00;
    font-weight: 700;
    font-size: 15px;
    font-family: 'Inter', sans-serif;
  }

  .dark-shoe-card__form {
    margin: 0;
  }

  .dark-shoe-card__cart-btn {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #ffffff;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dark-shoe-card__cart-btn:hover {
    background: #ffffff;
    border-color: #ffffff;
    color: #111111;
  }

  .dark-shoe-card__cart-btn svg {
    width: 18px;
    height: 18px;
  }
  
  .dark-shoe-card__cart-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>
