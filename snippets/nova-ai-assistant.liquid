</style>

<script>
(function() {
  let retryCount = 0;

  function initNovaAI() {
    const fab = document.getElementById('nova-ai-fab');
    if (!fab) {
      if (retryCount < 30) {
        retryCount++;
        setTimeout(initNovaAI, 100);
      }
      return;
    }

    if (fab.dataset.initialized === 'true') return;
    fab.dataset.initialized = 'true';

    // Store Catalog Data from System Prompt
    const CATALOG = [
      {id:1, name:"Oversized Acid Wash Tee", cat:"tshirt", colors:["Black","White","Grey"], price:899, material:"240GSM Cotton", fit:"Oversized", rating:4.6, stock:"in", icon:"👕"},
      {id:2, name:"Boxy Fit Graphic Hoodie", cat:"hoodie", colors:["Black","Olive"], price:1799, material:"320GSM Fleece", fit:"Boxy", rating:4.8, stock:"in", icon:"🧥"},
      {id:3, name:"Cargo Jogger Pants", cat:"cargo", colors:["Black","Beige"], price:1499, material:"Ripstop Cotton", fit:"Relaxed", rating:4.5, stock:"low", icon:"👖"},
      {id:4, name:"Oversized Drop-Shoulder Tee", cat:"tshirt", colors:["White","Sand"], price:999, material:"220GSM Cotton", fit:"Oversized", rating:4.4, stock:"in", icon:"👕"},
      {id:5, name:"Varsity Bomber Jacket", cat:"jacket", colors:["Black","Cream"], price:2499, material:"Poly-Twill", fit:"Regular", rating:4.7, stock:"in", icon:"🧥"},
      {id:6, name:"Relaxed Fit Cargo Shorts", cat:"cargo", colors:["Black","Beige"], price:1099, material:"Cotton Twill", fit:"Relaxed", rating:4.3, stock:"in", icon:"🩳"},
      {id:7, name:"ONE9 Snapback Cap", cat:"accessory", colors:["Black","White"], price:599, material:"Cotton Twill", fit:"One Size", rating:4.5, stock:"in", icon:"🧢"},
      {id:8, name:"Chunky Retro Sneakers", cat:"shoes", colors:["Black","White"], price:2999, material:"Mesh + Rubber", fit:"True to size", rating:4.6, stock:"low", icon:"👟"}
    ];

    // Active Coupons
    const COUPONS = [
      {code:"WELCOME10", desc:"10% off first order", min:999},
      {code:"FLAT200", desc:"Flat ₹200 off", min:1999}
    ];

    // Sample Orders
    const ORDERS = {
      "ONE9-1001": {status:"Shipped", courier:"Delhivery", eta:"2 days"},
      "ONE9-1002": {status:"Out for delivery", courier:"Bluedart", eta:"Today"},
      "ONE9-1003": {status:"Processing", courier:"—", eta:"3-4 days"},
      "ONE9-1004": {status:"Delivered", courier:"Ecom Express", eta:"Delivered"}
    };

    // Launch Info
    const LAUNCH = {
      name: "ONE9 Reflective Windbreaker — Drop 002",
      launch_date: "August 1, 2026",
      price: 1999,
      teaser: "Water-resistant, reflective piping, boxy oversized cut — limited run of 300 pieces, restock not guaranteed."
    };

    // State Management
    let currentLang = 'en';
    let isWaitingForLead = false;
    let leadData = { name: '', contact: '' };

    // DOM Elements
    const panel = document.getElementById('nova-ai-panel');
    const closeBtn = document.getElementById('nova-ai-close');
    const messagesContainer = document.getElementById('nova-ai-messages');
    const quickRepliesContainer = document.getElementById('nova-ai-quick-replies');
    const form = document.getElementById('nova-ai-form');
    const input = document.getElementById('nova-ai-input');
    const langBtns = document.querySelectorAll('.lang-btn');

    // Language Switcher
    langBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        langBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentLang = btn.dataset.lang;
        addBotMessage(getLangWelcomeMsg(currentLang), [], getLangQuickReplies(currentLang));
      });
    });

    function getLangWelcomeMsg(lang) {
      if (lang === 'hi') {
        return "नमस्ते! मैं NovaAI हूँ, आपका Streetwear AI Assistant। आज मैं आपकी क्या मदद कर सकता हूँ? Fits, Orders या Discounts?";
      } else if (lang === 'gu') {
        return "નમસ્તે! હું NovaAI છું, તમારો Streetwear AI Assistant. આજે હું તમને કેવી રીતે મદદ કરી શકું? Order Tracking, Sizes કે Offers?";
      }
      return "Yo! I'm NovaAI, your ONE9 streetwear sales assistant. Looking for fresh oversized fits, order updates, or discount codes?";
    }

    function getLangQuickReplies(lang) {
      if (lang === 'hi') {
        return ["👕 Trending Fits", "📦 Order Track", "🔥 Drop 002", "🏷️ Discount Code"];
      } else if (lang === 'gu') {
        return ["👕 Top Items", "📦 Tracking", "🔥 Drop 002", "🏷️ Offers"];
      }
      return ["👕 Trending Fits", "📦 Track Order", "🔥 Drop 002", "🏷️ Discount Codes"];
    }

    function initWelcome() {
      if (messagesContainer && messagesContainer.children.length === 0) {
        addBotMessage(getLangWelcomeMsg(currentLang), [], getLangQuickReplies(currentLang));
      }
    }

    // Auto load welcome message
    initWelcome();

    // Handle Form Submit
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const query = input.value.trim();
      if (!query) return;

      addUserMessage(query);
      input.value = '';

      setTimeout(() => {
        processUserQuery(query);
      }, 450);
    });

    function addUserMessage(text) {
      const timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      const msgHTML = `
        <div class="nova-msg nova-msg--user">
          <div class="nova-msg__bubble">${escapeHTML(text)}</div>
          <div class="nova-msg__time">${timeStr}</div>
        </div>
      `;
      messagesContainer.insertAdjacentHTML('beforeend', msgHTML);
      scrollToBottom();
    }

    function addBotMessage(text, productIds = [], quickReplies = [], handoff = false) {
      const timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
      let productHTML = '';
      
      if (productIds && productIds.length > 0) {
        productHTML = '<div class="nova-products-grid">';
        productIds.forEach(id => {
          const prod = CATALOG.find(p => p.id === id);
          if (prod) {
            productHTML += `
              <div class="nova-product-card">
                <div class="nova-product-card__icon">${prod.icon}</div>
                <div class="nova-product-card__details">
                  <div class="nova-product-card__title">${escapeHTML(prod.name)}</div>
                  <div class="nova-product-card__meta">${prod.fit} • ${prod.material}</div>
                  <div class="nova-product-card__price">₹${prod.price}</div>
                </div>
                <button class="nova-product-card__btn" onclick="NovaAI_AddToCart(${prod.id}, '${escapeHTML(prod.name)}')">
                  Add +
                </button>
              </div>
            `;
          }
        });
        productHTML += '</div>';
      }

      let handoffHTML = '';
      if (handoff) {
        handoffHTML = `
          <div class="nova-whatsapp-box">
            <span style="font-size: 11px; color: #DDD;">Need human assistance?</span>
            <a href="https://wa.me/919999999999?text=Hi%20ONE9%20Team%2C%20I%20need%20help" target="_blank" class="nova-whatsapp-btn">
              💬 WhatsApp Support
            </a>
          </div>
        `;
      }

      const msgHTML = `
        <div class="nova-msg nova-msg--bot">
          <div class="nova-msg__bubble">
            ${escapeHTML(text)}
            ${productHTML}
            ${handoffHTML}
          </div>
          <div class="nova-msg__time">${timeStr}</div>
        </div>
      `;
      messagesContainer.insertAdjacentHTML('beforeend', msgHTML);

      updateQuickReplies(quickReplies);
      scrollToBottom();
    }

    function updateQuickReplies(replies) {
      quickRepliesContainer.innerHTML = '';
      const list = (replies && replies.length > 0) ? replies : getLangQuickReplies(currentLang);
      list.forEach(r => {
        const chip = document.createElement('button');
        chip.className = 'quick-chip';
        chip.textContent = r;
        chip.addEventListener('click', () => {
          addUserMessage(r);
          setTimeout(() => processUserQuery(r), 400);
        });
        quickRepliesContainer.appendChild(chip);
      });
    }

    function scrollToBottom() {
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function escapeHTML(str) {
      return str.replace(/[&<>'"]/g, 
        tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
      );
    }

    // Client AI Intelligence Engine
    function processUserQuery(query) {
      const q = query.toLowerCase();

      // 1. Order Tracking
      const orderMatch = q.match(/one9-\d{4}/i);
      if (orderMatch) {
        const orderNo = orderMatch[0].toUpperCase();
        if (ORDERS[orderNo]) {
          const ord = ORDERS[orderNo];
          const reply = `Order ${orderNo} status: ${ord.status}. Courier: ${ord.courier}. Estimated delivery: ${ord.eta}. Let me know if you need anything else!`;
          return addBotMessage(reply, [], ["👕 Browse Fits", "🏷️ View Coupons"]);
        } else {
          const reply = `I couldn't find order ${orderNo} in our system. Let me connect you directly to our human support team on WhatsApp!`;
          return addBotMessage(reply, [], ["💬 Contact Support"], true);
        }
      }
      if (q.includes("order") || q.includes("track") || q.includes("status") || q.includes("where is my")) {
        return addBotMessage("Sure thing! Please share your 4-digit order number (e.g. ONE9-1001) and I'll track it right away.", [], ["ONE9-1001", "ONE9-1002"]);
      }

      // 2. Product Launch Drop 002
      if (q.includes("drop") || q.includes("launch") || q.includes("new") || q.includes("coming soon") || q.includes("windbreaker")) {
        isWaitingForLead = true;
        const reply = `🔥 Upcoming Drop: ${LAUNCH.name} launching on ${LAUNCH.launch_date} for ₹${LAUNCH.price}! ${LAUNCH.teaser} Would you like me to add you to the VIP notify list?`;
        return addBotMessage(reply, [], ["Yes, notify me!", "No thanks"]);
      }

      if (isWaitingForLead) {
        if (q.includes("yes") || q.includes("notify") || q.includes("sure") || q.includes("add me")) {
          const reply = "Awesome! Please type your Name and Phone/Email (e.g. Rahul, 9876543210 or rahul@email.com) to lock in your VIP spot.";
          return addBotMessage(reply, [], []);
        }
        const phoneOrEmail = q.match(/(\d{10}|[\w.-]+@[\w.-]+\.\w+)/);
        if (phoneOrEmail) {
          isWaitingForLead = false;
          leadData.contact = phoneOrEmail[0];
          leadData.name = query.replace(phoneOrEmail[0], '').replace(/,/g, '').trim() || "VIP Customer";
          
          try {
            const leads = JSON.parse(localStorage.getItem('one9_vip_leads') || '[]');
            leads.push({ ...leadData, timestamp: new Date().toISOString() });
            localStorage.setItem('one9_vip_leads', JSON.stringify(leads));
          } catch(e) {}

          const reply = `You're all set, ${leadData.name}! We've added ${leadData.contact} to the VIP Drop 002 notify list. We'll text/email you first before public release.`;
          return addBotMessage(reply, [2, 1], ["👕 Browse Store", "🏷️ Active Offers"]);
        }
      }

      // 3. Coupons
      if (q.includes("coupon") || q.includes("discount") || q.includes("offer") || q.includes("code") || q.includes("promo")) {
        const reply = `Here are our active store coupons:\n• WELCOME10 — 10% off on orders above ₹999\n• FLAT200 — Flat ₹200 off on orders above ₹1999\nApply them at checkout!`;
        return addBotMessage(reply, [1, 2], ["👕 Oversized Tees", "🧥 Hoodies"]);
      }

      // 4. Size Recommendation
      if (q.includes("size") || q.includes("fit") || q.includes("height") || q.includes("weight") || q.includes("measurement")) {
        if (q.match(/\d+\s*(cm|kg|lbs|feet|ft|inch)/)) {
          const reply = `Based on your specs, we recommend Medium (M) for a tailored street fit, or Large (L) if you love that authentic signature ONE9 oversized drop-shoulder aesthetic!`;
          return addBotMessage(reply, [1, 4], ["👕 View Acid Wash Tee", "🧥 View Graphic Hoodie"]);
        }
        const reply = `Our tops & hoodies feature a signature relaxed/oversized drop-shoulder cut. Tell me your height & weight (e.g., 5'9", 70kg), and I'll pick your exact size!`;
        return addBotMessage(reply, [], ["5'10, 72kg", "6'0, 80kg", "5'6, 60kg"]);
      }

      // 5. Product Recommendations
      if (q.includes("hoodie") || q.includes("sweatshirt")) {
        const reply = `Check out our Boxy Fit Graphic Hoodie (₹1,799)! Crafted from 320GSM fleece with heavy-duty ribbing for that premium fall.`;
        return addBotMessage(reply, [2], ["👕 View Tees", "👖 Cargo Pants"]);
      }

      if (q.includes("tee") || q.includes("tshirt") || q.includes("t-shirt")) {
        const reply = `Our Acid Wash & Drop-Shoulder Tees are absolute staples (240GSM pure cotton, signature boxy cut).`;
        return addBotMessage(reply, [1, 4], ["🧥 Graphic Hoodie", "🧢 Snapback Cap"]);
      }

      if (q.includes("pant") || q.includes("cargo") || q.includes("short")) {
        const reply = `Check out our Cargo Joggers (₹1,499) and Relaxed Cargo Shorts (₹1,099) — heavy-duty ripstop cotton with functional utility pockets.`;
        return addBotMessage(reply, [3, 6], ["👟 Retro Sneakers", "👕 Acid Wash Tee"]);
      }

      if (q.includes("shoe") || q.includes("sneaker")) {
        const reply = `Our Chunky Retro Sneakers (₹2,999) feature high-traction rubber soles and breathable mesh panels. Stock is running low!`;
        return addBotMessage(reply, [8], ["🧢 Snapback Cap", "🧥 Bomber Jacket"]);
      }

      if (q.includes("best") || q.includes("recommend") || q.includes("popular") || q.includes("trending")) {
        const reply = `Here are our top trending fits right now — crafted from heavy GSM cotton with signature streetwear cuts:`;
        return addBotMessage(reply, [1, 2, 8], ["🔥 Drop 002", "🏷️ Discount Codes"]);
      }

      // 6. Shipping & Return Policies
      if (q.includes("ship") || q.includes("delivery") || q.includes("cod") || q.includes("return") || q.includes("refund")) {
        const reply = `Shipping takes 3–5 business days across India (Free shipping above ₹999 + Cash on Delivery available). We offer 7-day hassle-free returns & exchanges!`;
        return addBotMessage(reply, [], ["📦 Track Order", "👕 Browse Shop"]);
      }

      // 7. Brand Story / General Fallback
      if (q.includes("brand") || q.includes("who") || q.includes("one9") || q.includes("about")) {
        const reply = `ONE9 is an independent streetwear label built for oversized fits, bold graphics, and everyday comfort — luxury quality without hype prices!`;
        return addBotMessage(reply, [1, 2], ["🔥 Drop 002", "🏷️ Coupons"]);
      }

      const reply = `I hear you! Whether you need fit recommendations, coupon codes, order tracking, or details on Drop 002, NovaAI is here to help!`;
      return addBotMessage(reply, [1, 2], ["👕 Best Sellers", "📦 Track Order", "🔥 Drop 002"]);
    }

    // Global Add To Cart handler
    window.NovaAI_AddToCart = function(productId, productName) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: productId, quantity: 1 })
      })
      .then(res => res.json())
      .then(data => {
        addBotMessage(`Added ${productName} to your cart! 🛍️`, [], ["🛒 View Cart", "💳 Checkout"]);
        document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
      })
      .catch(() => {
        window.location.href = `/cart/add?id=${productId}&quantity=1`;
      });
    };
  }

  initNovaAI();
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNovaAI);
  }
  window.addEventListener('load', initNovaAI);
})();
</script>
