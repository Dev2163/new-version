{% comment %}
  ONE9 Luxury Streetwear - NovaAI AI Shopping Assistant Snippet (Gold, Black & White Palette)
{% endcomment %}

<div id="nova-ai-root" class="nova-ai-container">
  <!-- Floating Action Button (FAB) -->
  <button 
    id="nova-ai-fab" 
    class="nova-ai-fab" 
    type="button" 
    aria-label="Open NovaAI Shopping Assistant" 
    title="NovaAI ✦ Shopping Assistant"
    onclick="const p=document.getElementById('nova-ai-panel'); if(p){ p.classList.toggle('active'); p.setAttribute('aria-hidden', !p.classList.contains('active')); }"
  >
    <div class="nova-ai-fab__glow"></div>
    <div class="nova-ai-fab__icon">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width:24px; height:24px;">
        <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="currentColor"/>
        <circle cx="19" cy="5" r="2.5" fill="#F4C430"/>
      </svg>
    </div>
    <span class="nova-ai-fab__badge">
      <span class="nova-ai-fab__pulse"></span>
      NovaAI
    </span>
  </button>

  <!-- Chat Drawer / Modal -->
  <div id="nova-ai-panel" class="nova-ai-panel" aria-hidden="true">
    <!-- Panel Header -->
    <div class="nova-ai-panel__header">
      <div class="nova-ai-panel__brand">
        <div class="nova-ai-panel__avatar">
          <svg viewBox="0 0 24 24" fill="none" style="width:24px; height:24px;">
            <path d="M12 2L14.5 9.5L22 12L14.5 14.5L12 22L9.5 14.5L2 12L9.5 9.5L12 2Z" fill="url(#nova-gold-grad)"/>
            <defs>
              <linearGradient id="nova-gold-grad" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse">
                <stop stop-color="#F4C430"/>
                <stop offset="1" stop-color="#FFD700"/>
              </linearGradient>
            </defs>
          </svg>
        </div>
        <div class="nova-ai-panel__info">
          <div class="nova-ai-panel__title">
            <span>NovaAI</span>
            <span class="nova-ai-panel__tag">STREETWEAR AI</span>
          </div>
          <div class="nova-ai-panel__status">
            <span class="status-dot"></span> Online &amp; Ready
          </div>
        </div>
      </div>

      <!-- Controls: Language Selector + Close -->
      <div class="nova-ai-panel__controls">
        <div class="nova-ai-lang-selector" title="Select Language">
          <button type="button" class="lang-btn active" data-lang="en">EN</button>
          <button type="button" class="lang-btn" data-lang="hi">HI</button>
          <button type="button" class="lang-btn" data-lang="gu">GUJ</button>
        </div>
        <button 
          id="nova-ai-close" 
          type="button" 
          class="nova-ai-panel__close" 
          aria-label="Close Assistant"
          onclick="const p=document.getElementById('nova-ai-panel'); if(p){ p.classList.remove('active'); p.setAttribute('aria-hidden', 'true'); }"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:16px; height:16px;">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    </div>

    <!-- Chat Messages Body -->
    <div id="nova-ai-messages" class="nova-ai-panel__messages">
      <!-- Welcome Message loaded by JS -->
    </div>

    <!-- Quick Reply Suggestions -->
    <div id="nova-ai-quick-replies" class="nova-ai-panel__quick-replies">
      <!-- Loaded dynamically -->
    </div>

    <!-- Input Footer -->
    <div class="nova-ai-panel__footer">
      <form id="nova-ai-form" class="nova-ai-panel__form">
        <input 
          type="text" 
          id="nova-ai-input" 
          class="nova-ai-panel__input" 
          placeholder="Ask NovaAI about fits, orders, drops..." 
          autocomplete="off" 
          required
        />
        <button type="submit" class="nova-ai-panel__send" aria-label="Send message">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px; height:18px;">
            <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13"/>
          </svg>
        </button>
      </form>
      <div class="nova-ai-panel__footer-tag">Powered by ONE9 AI Engine</div>
    </div>
  </div>
</div>

<style>
  /* NovaAI Luxury Gold, Black & White Design System */
