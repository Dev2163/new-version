  .nova-ai-panel__brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .nova-ai-panel__avatar {
    width: 38px;
    height: 38px;
    background: rgba(244, 196, 48, 0.12);
    border: 1px solid rgba(244, 196, 48, 0.6);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6px;
  }

  .nova-ai-panel__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nova-ai-panel__title {
    font-family: 'Orbitron', 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #FFFFFF;
