    --nova-black-card: rgba(14, 14, 18, 0.98);
    --nova-white: #FFFFFF;
    --nova-muted: #9E9E9E;
    --nova-border-gold: rgba(244, 196, 48, 0.35);
    --nova-user-bubble: linear-gradient(135deg, #1A1A22 0%, #252530 100%);
