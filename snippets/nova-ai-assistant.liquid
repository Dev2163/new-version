    z-index: -1;
    animation: novaGlowPulse 3.5s infinite linear;
  }

  @keyframes novaGlowPulse {
    0% { opacity: 0.3; filter: blur(6px); }
    50% { opacity: 0.55; filter: blur(12px); }
    100% { opacity: 0.3; filter: blur(6px); }
  }

  .nova-ai-fab__icon {
    width: 28px;
    height: 28px;
    color: #F4C430;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nova-ai-fab__badge {
    position: relative;
    font-family: 'Orbitron', 'Rajdhani', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.8px;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nova-ai-fab__pulse {
    width: 8px;
    height: 8px;
    background: #F4C430;
    border-radius: 50%;
    box-shadow: 0 0 10px #F4C430;
    animation: novaPulse 1.8s infinite;
  }

  @keyframes novaPulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(244, 196, 48, 0.8); }
    70% { transform: scale(1); box-shadow: 0 0 0 8px rgba(244, 196, 48, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(244, 196, 48, 0); }
  }

  /* Chat Panel Drawer */
  .nova-ai-panel {
    position: fixed !important;
    bottom: 90px !important;
    right: 24px !important;
    width: 385px !important;
    max-width: calc(100vw - 32px) !important;
    height: 600px !important;
    max-height: calc(100vh - 120px) !important;
    background: rgba(10, 10, 14, 0.98) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border: 1px solid rgba(244, 196, 48, 0.35) !important;
    border-radius: 20px !important;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.9), 0 0 35px rgba(244, 196, 48, 0.25) !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(20px) scale(0.95);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1) !important;
    z-index: 99999999 !important;
  }

  @media (max-width: 768px) {
    .nova-ai-panel {
      bottom: 140px !important;
      right: 16px !important;
      width: calc(100vw - 32px) !important;
      height: 540px !important;
