    font-size: 10px;
    font-weight: 700;
    padding: 4px 7px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .lang-btn.active {
    background: #F4C430;
    color: #000000;
    font-weight: 900;
  }

  .nova-ai-panel__close {
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #AAA;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .nova-ai-panel__close:hover {
    background: rgba(244, 196, 48, 0.2);
    border-color: #F4C430;
    color: #FFF;
  }

  /* Messages Area */
  .nova-ai-panel__messages {
    flex: 1;
    overflow-y: auto;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    scroll-behavior: smooth;
  }

  .nova-ai-panel__messages::-webkit-scrollbar {
    width: 4px;
  }
  .nova-ai-panel__messages::-webkit-scrollbar-thumb {
    background: rgba(244, 196, 48, 0.3);
    border-radius: 4px;
  }

  /* Message Bubbles */
  .nova-msg {
    display: flex;
    flex-direction: column;
    max-width: 88%;
    animation: msgFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes msgFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .nova-msg--bot {
    align-self: flex-start;
  }

  .nova-msg--user {
    align-self: flex-end;
  }

  .nova-msg__bubble {
    padding: 12px 14px;
    border-radius: 16px;
    font-size: 13px;
    line-height: 1.5;
    color: #FFFFFF;
    word-break: break-word;
  }

  .nova-msg--bot .nova-msg__bubble {
    background: var(--nova-bot-bubble);
    border: 1px solid rgba(244, 196, 48, 0.25);
    border-top-left-radius: 4px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
  }

  .nova-msg--user .nova-msg__bubble {
    background: var(--nova-user-bubble);
    border: 1px solid rgba(255, 255, 255, 0.2);
