{% comment %}
  ONE9 Luxury Streetwear - Premium Reviews Snippet
{% endcomment %}

<div class="reviews-snippet-wrapper" style="margin-top: 36px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
  <div class="reviews-header" style="margin-bottom: 16px;">
    <h3 style="font-family: 'Orbitron', sans-serif; font-size: 16px; font-weight: 800; color: #FFFFFF; letter-spacing: 1px;">CUSTOMER REVIEWS</h3>
    <p style="font-size: 12px; color: #888;">Real feedback from streetwear enthusiasts</p>
  </div>

  <!-- Rating Summary Card -->
  <div style="background: #0A0A0C; border: 1px solid rgba(244, 196, 48, 0.35); border-radius: 14px; padding: 18px; display: flex; flex-direction: column; gap: 14px; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; justify-content: space-between;">
      <div style="display: flex; align-items: center; gap: 12px;">
        <span style="font-family: 'Orbitron', sans-serif; font-size: 32px; font-weight: 900; color: #F4C430;">4.9</span>
        <div>
          <div style="color: #F4C430; font-size: 14px; letter-spacing: 1px;">★★★★★</div>
          <div style="font-size: 10px; color: #888;">148 Verified Purchases</div>
        </div>
      </div>
      <button type="button" onclick="alert('Review form submitted. Thank you!')" style="background: #F4C430; color: #000; font-family: 'Orbitron', sans-serif; font-weight: 800; font-size: 10px; border: none; border-radius: 6px; padding: 8px 12px; cursor: pointer;">
        ★ Write Review
      </button>
    </div>

    <!-- Rating Distribution Bars -->
    <div style="display: flex; flex-direction: column; gap: 4px;">
      <div style="display: flex; align-items: center; gap: 8px; font-size: 10px; color: #AAA;">
        <span>5 ★</span>
        <div style="flex: 1; height: 5px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;"><div style="width: 88%; height: 100%; background: #F4C430;"></div></div>
        <span>88%</span>
      </div>
      <div style="display: flex; align-items: center; gap: 8px; font-size: 10px; color: #AAA;">
        <span>4 ★</span>
        <div style="flex: 1; height: 5px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;"><div style="width: 9%; height: 100%; background: #F4C430;"></div></div>
        <span>9%</span>
      </div>
      <div style="display: flex; align-items: center; gap: 8px; font-size: 10px; color: #AAA;">
        <span>3 ★</span>
        <div style="flex: 1; height: 5px; background: rgba(255,255,255,0.1); border-radius: 3px; overflow: hidden;"><div style="width: 3%; height: 100%; background: #F4C430;"></div></div>
        <span>3%</span>
      </div>
    </div>
  </div>

  <!-- Review Cards -->
  <div style="display: flex; flex-direction: column; gap: 12px;">
    
    <div style="background: #101014; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 14px; display: flex; flex-direction: column; gap: 6px;">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <div style="width: 30px; height: 30px; background: rgba(244, 196, 48, 0.15); border: 1px solid rgba(244, 196, 48, 0.4); border-radius: 50%; color: #F4C430; font-weight: 800; font-size: 11px; display: flex; align-items: center; justify-content: center;">RV</div>
          <div>
            <div style="font-size: 12px; font-weight: 700; color: #FFF;">Rahul V. <span style="font-size: 9px; color: #00FF9D; background: rgba(0, 255, 157, 0.15); padding: 1px 4px; border-radius: 3px;">✓ Verified Buyer</span></div>
            <div style="font-size: 10px; color: #777;">Mumbai • 2 days ago</div>
          </div>
        </div>
        <div style="color: #F4C430; font-size: 11px;">★★★★★</div>
      </div>
      <div style="font-size: 12px; font-weight: 700; color: #FFF;">Absolute top quality 240GSM fabric!</div>
      <div style="font-size: 11px; line-height: 1.4; color: #BBB;">The oversized fit is exact. Drop shoulder hangs perfectly and after 3 washes the acid wash color hasn't faded. Heavy duty streetwear vibe.</div>
      <div style="font-size: 10px; color: #F4C430; font-weight: 700;">📸 Photo Review Attached</div>
    </div>

    <div style="background: #101014; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; padding: 14px; display: flex; flex-direction: column; gap: 6px;">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div style="display: flex; align-items: center; gap: 8px;">
          <div style="width: 30px; height: 30px; background: rgba(244, 196, 48, 0.15); border: 1px solid rgba(244, 196, 48, 0.4); border-radius: 50%; color: #F4C430; font-weight: 800; font-size: 11px; display: flex; align-items: center; justify-content: center;">AS</div>
          <div>
            <div style="font-size: 12px; font-weight: 700; color: #FFF;">Aman S. <span style="font-size: 9px; color: #00FF9D; background: rgba(0, 255, 157, 0.15); padding: 1px 4px; border-radius: 3px;">✓ Verified Buyer</span></div>
            <div style="font-size: 10px; color: #777;">Delhi • 4 days ago</div>
          </div>
        </div>
        <div style="color: #F4C430; font-size: 11px;">★★★★★</div>
      </div>
      <div style="font-size: 12px; font-weight: 700; color: #FFF;">Best boxy fit in India</div>
      <div style="font-size: 11px; line-height: 1.4; color: #BBB;">Fleece lining inside is super cozy and the hood stays standing up instead of flopping. Worth every rupee!</div>
    </div>

  </div>
</div>
