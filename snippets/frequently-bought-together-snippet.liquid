{% comment %}
  ONE9 Luxury Streetwear - Frequently Bought Together Snippet
{% endcomment %}

<div class="fbt-snippet-wrapper" style="margin-top: 30px; padding-top: 24px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
  <div class="fbt-header" style="margin-bottom: 16px;">
    <h3 class="fbt-title" style="font-family: 'Orbitron', sans-serif; font-size: 16px; font-weight: 800; color: #FFFFFF; letter-spacing: 1px;">FREQUENTLY BOUGHT TOGETHER</h3>
    <p class="fbt-subtitle" style="font-size: 12px; color: #F4C430; font-weight: 600; text-transform: uppercase;">Unlock 10% Bundle Savings</p>
  </div>

  <div class="fbt-box" style="background: #0A0A0C; border: 1px solid rgba(244, 196, 48, 0.35); border-radius: 14px; padding: 16px; display: flex; flex-direction: column; gap: 14px;">
    
    <!-- Item 1: Main Product -->
    <div style="display: flex; align-items: center; gap: 10px; background: rgba(255, 255, 255, 0.03); padding: 10px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.08);">
      <input type="checkbox" checked disabled style="accent-color: #F4C430; width: 16px; height: 16px;">
      <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title | escape }}" style="width: 44px; height: 44px; object-fit: cover; border-radius: 6px; background: #000; border: 1px solid rgba(244, 196, 48, 0.3);">
      <div style="flex: 1; min-width: 0;">
        <div style="font-size: 9px; color: #F4C430; font-weight: 800;">THIS ITEM</div>
        <div style="font-size: 12px; font-weight: 700; color: #FFF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{ product.title }}</div>
        <div style="font-family: 'Orbitron', sans-serif; font-size: 11px; color: #F4C430; font-weight: 800;">{{ product.price | money }}</div>
      </div>
    </div>

    <!-- Item 2: Matching Cargo -->
    <div style="display: flex; align-items: center; gap: 10px; background: rgba(255, 255, 255, 0.03); padding: 10px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.08);">
      <input type="checkbox" id="fbt-chk-2" checked onchange="ONE9_UpdateFBTSnippetTotal()" style="accent-color: #F4C430; width: 16px; height: 16px; cursor: pointer;">
      <div style="width: 44px; height: 44px; background: #000; border-radius: 6px; border: 1px solid rgba(244, 196, 48, 0.3); display: flex; align-items: center; justify-content: center; font-size: 20px;">👖</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-size: 9px; color: #F4C430; font-weight: 800;">MATCHING FIT</div>
        <div style="font-size: 12px; font-weight: 700; color: #FFF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Cargo Jogger Pants - Relaxed</div>
        <div style="font-family: 'Orbitron', sans-serif; font-size: 11px; color: #F4C430; font-weight: 800;">₹1,499</div>
      </div>
    </div>

    <!-- Item 3: Cap -->
    <div style="display: flex; align-items: center; gap: 10px; background: rgba(255, 255, 255, 0.03); padding: 10px; border-radius: 8px; border: 1px solid rgba(255, 255, 255, 0.08);">
      <input type="checkbox" id="fbt-chk-3" checked onchange="ONE9_UpdateFBTSnippetTotal()" style="accent-color: #F4C430; width: 16px; height: 16px; cursor: pointer;">
      <div style="width: 44px; height: 44px; background: #000; border-radius: 6px; border: 1px solid rgba(244, 196, 48, 0.3); display: flex; align-items: center; justify-content: center; font-size: 20px;">🧢</div>
      <div style="flex: 1; min-width: 0;">
        <div style="font-size: 9px; color: #F4C430; font-weight: 800;">ACCESSORY</div>
        <div style="font-size: 12px; font-weight: 700; color: #FFF; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">ONE9 Snapback Cap - Black</div>
        <div style="font-family: 'Orbitron', sans-serif; font-size: 11px; color: #F4C430; font-weight: 800;">₹599</div>
      </div>
    </div>

    <!-- Summary & Buy Button -->
    <div style="padding-top: 10px; border-top: 1px solid rgba(255, 255, 255, 0.08); display: flex; flex-direction: column; gap: 10px;">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <span style="font-size: 12px; color: #AAA;">Total Bundle Price:</span>
        <span id="fbt-snippet-total" style="font-family: 'Orbitron', sans-serif; font-size: 16px; font-weight: 900; color: #F4C430;">₹{{ product.price | plus: 2098 | divided_by: 100 }}</span>
      </div>
      <button type="button" id="fbt-snippet-buy-btn" onclick="ONE9_AddFBTSnippetBundle()" style="background: #F4C430; color: #000; font-family: 'Orbitron', sans-serif; font-weight: 900; font-size: 12px; border: none; border-radius: 8px; padding: 12px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; box-shadow: 0 0 15px rgba(244, 196, 48, 0.3);">
        Add Bundle To Cart 🛒
      </button>
    </div>

  </div>
</div>

<script>
window.ONE9_UpdateFBTSnippetTotal = function() {
  const mainPrice = {{ product.price | divided_by: 100 }};
  let total = mainPrice;

  if (document.getElementById('fbt-chk-2')?.checked) total += 1499;
  if (document.getElementById('fbt-chk-3')?.checked) total += 599;

  document.getElementById('fbt-snippet-total').textContent = '₹' + total.toLocaleString('en-IN');
};

window.ONE9_AddFBTSnippetBundle = function() {
  const btn = document.getElementById('fbt-snippet-buy-btn');
  if (btn) btn.innerHTML = 'Adding Bundle...';

  const items = [{ id: parseInt('{{ product.selected_or_first_available_variant.id }}'), quantity: 1 }];

  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ items: items })
  })
  .then(res => res.json())
  .then(data => {
    if (btn) btn.innerHTML = 'Bundle Added! ✓';
    document.dispatchEvent(new CustomEvent('cart:updated', { detail: data }));
    if (typeof window.ONE9_OpenCartDrawer === 'function') {
      window.ONE9_OpenCartDrawer();
    }
    setTimeout(() => {
      if (btn) btn.innerHTML = 'Add Bundle To Cart 🛒';
    }, 2500);
  })
  .catch(() => {
    window.location.href = '/cart';
  });
};
</script>
