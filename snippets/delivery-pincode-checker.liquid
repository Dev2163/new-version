{% comment %}
  ONE9 Luxury Streetwear - Live Delivery Pincode Checker & Trust Section
{% endcomment %}

<div class="one9-pincode-checker">
  <div class="one9-pincode-header">
    <span class="pincode-icon">📍</span>
    <span class="pincode-title">Check Delivery &amp; COD Availability</span>
  </div>

  <div class="one9-pincode-form">
    <input 
      type="text" 
      id="one9-pincode-input" 
      class="one9-pincode-input" 
      placeholder="Enter 6-digit Pincode (e.g. 380001)" 
      maxlength="6"
    />
    <button type="button" id="one9-pincode-btn" class="one9-pincode-btn" onclick="ONE9_CheckPincode()">
      Check
    </button>
  </div>

  <div id="one9-pincode-result" class="one9-pincode-result" style="display: none;">
    <!-- Result inserted dynamically -->
  </div>
</div>

<!-- Trust Badges Section -->
<div class="one9-trust-badges">
  <div class="trust-item">
    <span class="trust-icon">🚚</span>
    <div class="trust-text">
      <strong>Free Express Shipping</strong>
      <span>On orders above ₹999</span>
    </div>
  </div>
  <div class="trust-item">
    <span class="trust-icon">🔒</span>
    <div class="trust-text">
      <strong>256-Bit SSL Checkout</strong>
      <span>100% Encrypted &amp; Safe</span>
    </div>
  </div>
  <div class="trust-item">
    <span class="trust-icon">↩️</span>
    <div class="trust-text">
      <strong>7-Day Easy Exchange</strong>
      <span>Hassle-Free Returns</span>
    </div>
  </div>
  <div class="trust-item">
    <span class="trust-icon">⭐</span>
    <div class="trust-text">
      <strong>Heavyweight Quality</strong>
      <span>240+ GSM Premium Cotton</span>
    </div>
  </div>
  <div class="trust-item">
    <span class="trust-icon">💳</span>
    <div class="trust-text">
      <strong>Flexible Payment</strong>
      <span>UPI, Cards, EMI &amp; COD</span>
    </div>
  </div>
</div>

<style>
  /* Delivery Pincode Checker */
  .one9-pincode-checker {
    background: #0E0E12;
    border: 1px solid rgba(244, 196, 48, 0.35);
    border-radius: 12px;
    padding: 14px 16px;
    margin: 18px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .one9-pincode-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 700;
    color: #FFFFFF;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }

  .pincode-icon {
    font-size: 16px;
  }

  .one9-pincode-form {
    display: flex;
    gap: 8px;
  }

  .one9-pincode-input {
    flex: 1;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    padding: 8px 12px;
    color: #FFF;
    font-size: 13px;
    outline: none;
    transition: all 0.2s;
  }

  .one9-pincode-input:focus {
    border-color: #F4C430;
    box-shadow: 0 0 10px rgba(244, 196, 48, 0.25);
  }

  .one9-pincode-btn {
    background: #F4C430;
    color: #000;
    border: none;
    border-radius: 8px;
    font-weight: 800;
    font-size: 12px;
    padding: 8px 16px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .one9-pincode-btn:hover {
    background: #FFD700;
    transform: scale(1.03);
  }

  .one9-pincode-result {
    font-size: 12px;
    line-height: 1.5;
    padding: 8px 12px;
    border-radius: 6px;
    background: rgba(244, 196, 48, 0.08);
    border: 1px solid rgba(244, 196, 48, 0.2);
    color: #EEE;
    animation: fadeIn 0.3s ease;
  }

  /* Trust Badges Grid */
  .one9-trust-badges {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
    margin-top: 18px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
  }

  @media (max-width: 480px) {
    .one9-trust-badges {
      grid-template-columns: 1fr;
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .trust-icon {
    font-size: 20px;
    flex-shrink: 0;
  }

  .trust-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .trust-text strong {
    font-size: 11px;
    font-weight: 700;
    color: #FFF;
  }

  .trust-text span {
    font-size: 10px;
    color: #999;
  }
</style>

<script>
window.ONE9_CheckPincode = function() {
  const pinInput = document.getElementById('one9-pincode-input');
  const resultBox = document.getElementById('one9-pincode-result');
  if (!pinInput || !resultBox) return;

  const pin = pinInput.value.trim();
  if (!/^\d{6}$/.test(pin)) {
    resultBox.style.display = 'block';
    resultBox.style.borderColor = 'rgba(255, 80, 80, 0.4)';
    resultBox.innerHTML = '<span style="color: #FF5555;">⚠️ Please enter a valid 6-digit Indian Pincode.</span>';
    return;
  }

  // Calculate estimated delivery date (3 days from today)
  const today = new Date();
  const deliveryDate = new Date(today);
  deliveryDate.setDate(today.getDate() + 3);

  const options = { weekday: 'long', day: 'numeric', month: 'short' };
  const dateStr = deliveryDate.toLocaleDateString('en-IN', options);

  resultBox.style.display = 'block';
  resultBox.style.borderColor = 'rgba(244, 196, 48, 0.4)';
  resultBox.innerHTML = `
    <div style="color: #F4C430; font-weight: 800; margin-bottom: 4px;">✓ Delivery available for ${pin}</div>
    <div>📅 Estimated Delivery by <strong>${dateStr}</strong></div>
    <div>⚡ Express Air Shipping Available</div>
    <div>💵 Cash on Delivery (COD) Available</div>
  `;
};
</script>
