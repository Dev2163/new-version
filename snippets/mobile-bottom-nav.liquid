{% comment %}
  ONE9 Luxury Streetwear - Mobile App Bottom Navigation Bar
{% endcomment %}

<nav class="mobile-bottom-nav" aria-label="Mobile Navigation">
  <a href="/" class="mobile-bottom-nav__item {% if template == 'index' %}active{% endif %}">
    <svg viewBox="0 0 24 24">
      <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
    </svg>
    <span>Home</span>
  </a>

  <button type="button" class="mobile-bottom-nav__item" onclick="document.querySelector('.header__icon--search, [data-search-trigger]')?.click()">
    <svg viewBox="0 0 24 24">
      <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
    </svg>
    <span>Search</span>
  </button>

  <a href="/collections/all" class="mobile-bottom-nav__item {% if template contains 'collection' %}active{% endif %}">
    <svg viewBox="0 0 24 24">
      <path d="M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z"/>
    </svg>
    <span>Shop</span>
  </a>

  <a href="/pages/wishlist" class="mobile-bottom-nav__item" onclick="if(window.ONE9Wishlist){ return true; }">
    <svg viewBox="0 0 24 24">
      <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
    </svg>
    <span class="wishlist-count-badge mobile-bottom-nav__badge" style="display: none;">0</span>
    <span>Wishlist</span>
  </a>

  <a href="/cart" class="mobile-bottom-nav__item {% if template contains 'cart' %}active{% endif %}" onclick="if(document.querySelector('cart-drawer, #cart-drawer')){ document.querySelector('header-actions-cart, [data-cart-drawer-trigger]')?.click(); }">
    <svg viewBox="0 0 24 24">
      <path d="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"/>
    </svg>
    {%- if cart.item_count > 0 -%}
      <span class="mobile-bottom-nav__badge">{{ cart.item_count }}</span>
    {%- endif -%}
    <span>Cart</span>
  </a>
</nav>
