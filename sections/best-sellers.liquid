{% liquid
  assign heading = section.settings.heading | default: 'BEST SELLERS'
  assign view_all_text = section.settings.view_all_text | default: 'VIEW ALL PRODUCTS'
  assign view_all_link = section.settings.view_all_link | default: '/collections/all'
  assign products_limit = section.settings.products_limit | default: 6
  assign accent_color = section.settings.accent_color | default: '#F4C430'
  assign bg_color = section.settings.bg_color | default: '#0A0A0A'
  assign selected_collection = section.settings.collection
%}

<div class="best-sellers-wrapper" style="background-color: {{ bg_color }}; --best-sellers-accent: {{ accent_color }};">
  <div class="best-sellers section-padding">
    
    <div class="best-sellers__header">
      <h2 class="best-sellers__heading">{{ heading }}</h2>
      <a href="{{ view_all_link }}" class="best-sellers__view-all">
        {{- view_all_text -}}
        <svg class="best-sellers__view-all-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="best-sellers__grid">
      {% if selected_collection != blank and selected_collection.products_count > 0 %}
        {% for product in selected_collection.products limit: products_limit %}
          <div class="best-sellers__card">
            
            <!-- Image & Wishlist Button Container -->
            <div class="best-sellers__image-container">
              <button class="best-sellers__wishlist-btn" aria-label="Add to wishlist">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              </button>
              
              <a href="{{ product.url }}" class="best-sellers__image-link">
                {% if product.images.size > 1 %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title }}"
                    loading="lazy"
                    class="best-sellers__image best-sellers__image--primary"
                  >
                  <img
                    src="{{ product.images[1] | image_url: width: 600 }}"
                    alt="{{ product.images[1].alt | default: product.title }}"
                    loading="lazy"
                    class="best-sellers__image best-sellers__image--secondary"
                  >
                {% else %}
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    alt="{{ product.featured_image.alt | default: product.title }}"
                    loading="lazy"
                    class="best-sellers__image"
                  >
                {% endif %}
              </a>
            </div>

            <!-- Product Info -->
            <div class="best-sellers__info">
              <a href="{{ product.url }}" class="best-sellers__title-link">
                <p class="best-sellers__title">{{ product.title }}</p>
              </a>
              <p class="best-sellers__price">{{ product.price | money }}</p>

              <!-- Swatches Loop -->
              {%- liquid
                assign color_option = nil
                for option in product.options_with_values
                  assign name_downcase = option.name | downcase
                  if name_downcase contains 'color' or name_downcase contains 'colour' or name_downcase contains 'shade'
                    assign color_option = option
                    break
                  endif
                endfor
              -%}
              
              {% if color_option != blank %}
                <div class="best-sellers__swatches">
                  {% for value in color_option.values limit: 3 %}
                    {% if value.swatch %}
                      {% render 'swatch', swatch: value.swatch, label: value.name %}
                    {% else %}
                      <span
                        class="best-sellers__swatch"
                        style="background-color: {{ value.name | handle }};"
                        title="{{ value.name }}"
                      ></span>
                    {% endif %}
                  {% endfor %}
                  {% if color_option.values.size > 3 %}
                    <span class="best-sellers__swatches-more">+{{ color_option.values.size | minus: 3 }}</span>
                  {% endif %}
                </div>
              {% endif %}
            </div>

          </div>
        {% endfor %}
      {% else %}
        <!-- Placeholders if no collection is selected -->
        {% for i in (1..products_limit) %}
          <div class="best-sellers__card">
            <div class="best-sellers__image-container">
              <div class="best-sellers__image-placeholder">
                <span class="best-sellers__placeholder-icon">👕</span>
              </div>
            </div>
            <div class="best-sellers__info">
              <p class="best-sellers__title">Libra Balance Oversized Tee</p>
              <p class="best-sellers__price">£45.00</p>
              <div class="best-sellers__swatches">
                <span class="best-sellers__swatch" style="background-color: #556B2F;"></span>
                <span class="best-sellers__swatch" style="background-color: #111111;"></span>
                <span class="best-sellers__swatch" style="background-color: #8B4513;"></span>
                <span class="best-sellers__swatches-more">+2</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

  </div>
</div>

{% stylesheet %}
  .best-sellers-wrapper {
    width: 100%;
  }

  .best-sellers {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding-inline: var(--page-margin, 20px);
    padding-block: 50px;
  }

  .best-sellers__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
  }

  .best-sellers__heading {
    color: var(--best-sellers-accent);
    font-size: 20px;
    font-weight: 800;
    text-transform: uppercase;
    margin: 0;
    letter-spacing: 1px;
  }

  .best-sellers__view-all {
    color: var(--best-sellers-accent);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: text-shadow 0.3s ease;
  }

  .best-sellers__view-all:hover {
    text-shadow: 0 0 10px rgba(244, 196, 48, 0.7);
  }

  .best-sellers__view-all-icon {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .best-sellers__view-all:hover .best-sellers__view-all-icon {
    transform: translateX(4px);
  }

  .best-sellers__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .best-sellers__grid {
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 24px;
    }
  }

  .best-sellers__card {
    background-color: #111111;
    border: 1px solid #1E1E1E;
    border-radius: 16px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .best-sellers__card:hover {
    border-color: rgba(244, 196, 48, 0.3);
    box-shadow: 0 0 24px rgba(244, 196, 48, 0.1);
  }

  .best-sellers__image-container {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 10px;
    margin-bottom: 14px;
  }

  .best-sellers__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .best-sellers__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease, transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .best-sellers__image--secondary {
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 2;
  }

  /* Hover effect for image swap */
  .best-sellers__card:hover .best-sellers__image--primary {
    opacity: 0;
  }

  .best-sellers__card:hover .best-sellers__image--secondary {
    opacity: 1;
    transform: scale(1.03);
  }

  .best-sellers__card:hover .best-sellers__image:not(.best-sellers__image--secondary) {
    transform: scale(1.03);
  }

  .best-sellers__wishlist-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 5;
    background: rgba(10, 10, 10, 0.5);
    border: none;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    cursor: pointer;
    transition: all 0.3s ease;
    backdrop-filter: blur(4px);
  }

  .best-sellers__wishlist-btn:hover {
    background: var(--best-sellers-accent);
    color: #000000;
    transform: scale(1.1);
  }

  .best-sellers__wishlist-btn svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
  }

  .best-sellers__info {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .best-sellers__title-link {
    text-decoration: none;
    margin-bottom: 6px;
  }

  .best-sellers__title {
    color: #FFFFFF;
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    line-height: 1.4;
    transition: color 0.3s ease;
  }

  .best-sellers__title:hover {
    color: var(--best-sellers-accent);
  }

  .best-sellers__price {
    color: #E0E0E0;
    font-size: 13px;
    font-weight: 700;
    margin: 0 0 10px 0;
  }

  .best-sellers__swatches {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
  }

  .best-sellers__swatch,
  .best-sellers__swatches .swatch {
    display: inline-block;
    width: 14px !important;
    height: 14px !important;
    min-width: 14px !important;
    min-height: 14px !important;
    border-radius: 50% !important;
    border: 1px solid #444 !important;
    margin: 0 !important;
  }

  .best-sellers__swatches-more {
    font-size: 10px;
    color: #888888;
    font-weight: 700;
    margin-left: 2px;
  }

  /* Placeholder Styling */
  .best-sellers__image-placeholder {
    width: 100%;
    height: 100%;
    background-color: #1A1A1A;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .best-sellers__placeholder-icon {
    font-size: 32px;
    opacity: 0.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Best Sellers Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BEST SELLERS"
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "VIEW ALL PRODUCTS"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Product Limit",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F4C430"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    }
  ],
  "presets": [
    {
      "name": "Best Sellers Grid"
    }
  ]
}
{% endschema %}
