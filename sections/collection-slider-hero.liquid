<div id="PremiumHero-{{ section.id }}" class="premium-hero" style="background-color: {{ section.settings.bg_color }}; --ph-accent: {{ section.settings.accent_color }}; --ph-text: {{ section.settings.text_color }};">
  
  <!-- Background Elements -->
  <div class="ph-bg-elements">
    <div class="ph-bg-text">{{ section.settings.bg_text }}</div>
    <div class="ph-panels">
      <div class="ph-panel"></div>
      <div class="ph-panel"></div>
      <div class="ph-panel"></div>
    </div>
    <div class="ph-glow-ring"></div>
    <div class="ph-particles">
      <div class="particle p1"></div><div class="particle p2"></div><div class="particle p3"></div>
      <div class="particle p4"></div><div class="particle p5"></div>
    </div>
  </div>

  <div class="ph-container">
    
    <!-- Top Area (Pagination + Main Content) -->
    <div class="ph-top-area">
      
      <!-- Far Left Pagination -->
      <div class="ph-pagination">
        {% assign shoe_count = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'shoe' %}
            {% assign shoe_count = shoe_count | plus: 1 %}
            <div class="ph-page-num {% if shoe_count == 1 %}is-active{% endif %}" data-index="{{ shoe_count | minus: 1 }}">
              <span>0{{ shoe_count }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <!-- Left Text Content -->
      <div class="ph-left-content">
        {% if section.settings.subtitle != blank %}
          <div class="ph-subtitle-wrap">
            <span class="ph-subtitle-line"></span>
            <span class="ph-subtitle">{{ section.settings.subtitle }}</span>
          </div>
        {% endif %}
        
        <h1 class="ph-title">
          <span class="ph-title-1">{{ section.settings.title_1 }}</span><br>
          <span class="ph-title-2">{{ section.settings.title_2 }}</span>
        </h1>
        
        {% if section.settings.description != blank %}
          <p class="ph-desc">{{ section.settings.description | newline_to_br }}</p>
        {% endif %}
        
        <div class="ph-buttons">
          {% if section.settings.btn_1_text != blank %}
            <a href="{{ section.settings.btn_1_url }}" class="ph-btn ph-btn--primary">
              {{ section.settings.btn_1_text }}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          {% endif %}
          {% if section.settings.btn_2_text != blank %}
            <a href="{{ section.settings.btn_2_url }}" class="ph-btn ph-btn--secondary">
              {{ section.settings.btn_2_text }}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
            </a>
          {% endif %}
        </div>

        <!-- Middle Features (Below buttons) -->
        <div class="ph-mid-features">
          {% for block in section.blocks %}
            {% if block.type == 'mid_feature' %}
              <div class="ph-mid-feat" {{ block.shopify_attributes }}>
                <div class="ph-mid-icon">
                  {% if block.settings.icon != blank %}{{ block.settings.icon }}{% else %}<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle></svg>{% endif %}
                </div>
                <div class="ph-mid-text">
                  <strong>{{ block.settings.title }}</strong>
                  <span>{{ block.settings.desc }}</span>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <!-- Center Shoe Image -->
      <div class="ph-center-shoe">
        <div class="ph-main-image-wrap">
          {% assign first_shoe = section.blocks | where: 'type', 'shoe' | first %}
          {% assign main_image = first_shoe.settings.image | default: first_shoe.settings.product.featured_image %}
          {% if main_image != blank %}
            <img src="{{ main_image | image_url: width: 1000 }}" alt="Hero Shoe" class="ph-main-image" id="PH_MainImage">
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'ph-main-image placeholder' }}
          {% endif %}
        </div>
      </div>

      <!-- Right Side Thumbnails -->
      <div class="ph-right-thumbs">
        <div class="ph-view-360">
          <div class="ph-360-circle">
            <span>VIEW</span>
            <strong>360&deg;</strong>
          </div>
          <div class="ph-360-line"></div>
        </div>
        
        <div class="ph-thumbs-list">
          {% assign thumb_index = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'shoe' %}
              {% assign thumb_img = block.settings.image | default: block.settings.product.featured_image %}
              <div class="ph-thumb {% if thumb_index == 0 %}is-active{% endif %}" data-index="{{ thumb_index }}" data-img="{{ thumb_img | image_url: width: 1000 }}" {{ block.shopify_attributes }}>
                {% if thumb_img != blank %}
                  <img src="{{ thumb_img | image_url: width: 150 }}" alt="Thumb" class="ph-thumb-img">
                {% else %}
                  {{ 'product-2' | placeholder_svg_tag: 'ph-thumb-img placeholder' }}
                {% endif %}
              </div>
              {% assign thumb_index = thumb_index | plus: 1 %}
            {% endif %}
          {% endfor %}
          
          <div class="ph-scroll-down">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </div>
        </div>
      </div>
      
    </div>

    <!-- Bottom Features -->
    <div class="ph-bottom-features">
      {% for block in section.blocks %}
        {% if block.type == 'bottom_feature' %}
          <div class="ph-bot-feat" {{ block.shopify_attributes }}>
            <div class="ph-bot-icon">
              {% if block.settings.icon != blank %}{{ block.settings.icon }}{% else %}<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect></svg>{% endif %}
            </div>
            <div class="ph-bot-text">
              <h4>{{ block.settings.title }}</h4>
              <p>{{ block.settings.desc }}</p>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@500;700&family=Inter:wght@300;400;600;700&display=swap');

  .premium-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    color: var(--ph-text);
    font-family: 'Inter', sans-serif;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 0 0 0;
  }

  /* Background Elements */
  .ph-bg-elements {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    pointer-events: none;
    z-index: 1;
  }
  .ph-bg-text {
    position: absolute;
    font-family: 'Oswald', sans-serif;
    font-size: clamp(200px, 40vw, 600px);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 2px rgba(255,255,255,0.03);
    letter-spacing: -10px;
    line-height: 0.8;
  }
  .ph-panels {
    position: absolute;
    display: flex;
    gap: 30px;
    height: 120vh;
    transform: skewX(-12deg);
  }
  .ph-panel {
    width: 90px;
    height: 100%;
    background: var(--ph-accent);
    opacity: 0.3;
    box-shadow: 0 0 80px var(--ph-accent);
  }
  .ph-glow-ring {
    position: absolute;
    width: 800px;
    height: 350px;
    border: 2px solid var(--ph-accent);
    border-radius: 50%;
    opacity: 0.25;
    transform: rotate(-15deg);
    box-shadow: 0 0 40px var(--ph-accent), inset 0 0 40px var(--ph-accent);
  }
  .ph-particles {
    position: absolute;
    inset: 0;
  }
  .particle {
    position: absolute;
    width: 3px;
    height: 3px;
    background: var(--ph-accent);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--ph-accent);
    animation: floatParticle 10s infinite linear;
  }
  .p1 { top: 20%; left: 30%; animation-duration: 8s; }
  .p2 { top: 60%; left: 70%; animation-duration: 12s; }
  .p3 { top: 40%; left: 60%; animation-duration: 15s; }
  .p4 { top: 70%; left: 30%; animation-duration: 11s; }
  .p5 { top: 30%; left: 80%; animation-duration: 9s; }

  @keyframes floatParticle {
    0% { transform: translateY(0) translateX(0); opacity: 0; }
    50% { opacity: 1; }
    100% { transform: translateY(-100px) translateX(50px); opacity: 0; }
  }

  /* Main Container */
  .ph-container {
    position: relative;
    z-index: 10;
    max-width: 1700px;
    margin: 0 auto;
    width: 100%;
    padding: 0 3%;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Top Area */
  .ph-top-area {
    display: grid;
    grid-template-columns: 40px 1fr 1.2fr 80px;
    align-items: center;
    gap: 3rem;
  }

  /* Pagination */
  .ph-pagination {
    display: flex;
    flex-direction: column;
    gap: 20px;
    position: relative;
  }
  .ph-page-num {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    position: relative;
    cursor: pointer;
    transition: 0.3s;
    text-align: right;
    padding-right: 15px;
  }
  .ph-page-num::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 2px;
    height: 0;
    background: var(--ph-accent);
    transition: 0.3s;
  }
  .ph-page-num.is-active {
    color: var(--ph-accent);
    font-weight: 700;
  }
  .ph-page-num.is-active::after {
    height: 25px;
  }

  /* Left Content */
  .ph-left-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .ph-subtitle-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ph-subtitle-line {
    width: 3px;
    height: 16px;
    background-color: var(--ph-accent);
  }
  .ph-subtitle {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--ph-accent);
    text-transform: uppercase;
  }
  .ph-title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(60px, 7vw, 130px);
    line-height: 0.9;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -1px;
  }
  .ph-title-1 { color: var(--ph-text); }
  .ph-title-2 { color: var(--ph-accent); }
  .ph-desc {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.7);
    max-width: 400px;
    margin: 0;
  }
  .ph-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 10px;
  }
  .ph-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: 30px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 1px;
    transition: 0.3s;
    cursor: pointer;
  }
  .ph-btn--primary {
    background-color: var(--ph-accent);
    color: #000;
    box-shadow: 0 10px 20px rgba(255, 140, 0, 0.2);
  }
  .ph-btn--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px rgba(255, 140, 0, 0.4);
  }
  .ph-btn--secondary {
    background-color: rgba(255,255,255,0.03);
    color: var(--ph-text);
    border: 1px solid rgba(255,255,255,0.15);
  }
  .ph-btn--secondary:hover {
    border-color: var(--ph-text);
    background-color: rgba(255,255,255,0.1);
  }

  /* Mid Features */
  .ph-mid-features {
    display: flex;
    gap: 2rem;
    margin-top: 2rem;
  }
  .ph-mid-feat {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ph-mid-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ph-text);
  }
  .ph-mid-icon svg { width: 16px; height: 16px; }
  .ph-mid-text {
    display: flex;
    flex-direction: column;
    font-size: 11px;
  }
  .ph-mid-text strong {
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }
  .ph-mid-text span { color: rgba(255,255,255,0.5); }

  /* Center Shoe */
  .ph-center-shoe {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 5;
  }
  .ph-main-image-wrap {
    width: 100%;
    max-width: 850px;
    animation: floatShoe 6s ease-in-out infinite;
  }
  .ph-main-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 40px 30px rgba(0,0,0,0.9));
    transform: rotate(-15deg);
    transition: opacity 0.4s ease;
  }
  .ph-main-image.fade-out { opacity: 0; }
  @keyframes floatShoe {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }

  /* Right Thumbnails */
  .ph-right-thumbs {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 25px;
  }
  .ph-view-360 {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .ph-360-circle {
    width: 65px;
    height: 65px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    line-height: 1.2;
    letter-spacing: 1px;
  }
  .ph-360-circle strong { font-size: 15px; }
  .ph-360-line {
    width: 1px;
    height: 35px;
    background-color: rgba(255,255,255,0.2);
  }
  .ph-thumbs-list {
    display: flex;
    flex-direction: column;
    gap: 15px;
    align-items: center;
  }
  .ph-thumb {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.1);
    padding: 6px;
    cursor: pointer;
    transition: 0.3s;
    background: rgba(255,255,255,0.03);
  }
  .ph-thumb:hover { border-color: rgba(255,255,255,0.3); }
  .ph-thumb.is-active {
    border-color: var(--ph-accent);
    transform: scale(1.1);
  }
  .ph-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transform: rotate(-15deg);
  }
  .ph-scroll-down {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 10px;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
  }
  .ph-scroll-down:hover {
    color: #fff;
    border-color: #fff;
  }

  /* Bottom Features */
  .ph-bottom-features {
    width: 100%;
    border-top: 1px solid rgba(255,255,255,0.08);
    display: flex;
    justify-content: space-between;
    padding: 2rem 0;
  }
  .ph-bot-feat {
    display: flex;
    align-items: center;
    gap: 15px;
    flex: 1;
    justify-content: center;
  }
  .ph-bot-feat:not(:last-child) {
    border-right: 1px solid rgba(255,255,255,0.08);
  }
  .ph-bot-icon {
    color: var(--ph-text);
    display: flex;
  }
  .ph-bot-icon svg { width: 26px; height: 26px; }
  .ph-bot-text h4 {
    margin: 0 0 5px 0;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .ph-bot-text p {
    margin: 0;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .ph-top-area { grid-template-columns: 1fr 1fr auto; }
    .ph-pagination { display: none; }
    .ph-mid-features { flex-wrap: wrap; }
  }

  @media (max-width: 990px) {
    .ph-top-area {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 3rem;
    }
    .ph-left-content { align-items: center; }
    .ph-mid-features { justify-content: center; }
    .ph-right-thumbs { flex-direction: row; justify-content: center; flex-wrap: wrap; }
    .ph-thumbs-list { flex-direction: row; flex-wrap: wrap; justify-content: center; }
    .ph-360-line { width: 30px; height: 1px; }
    .ph-view-360 { flex-direction: row; }
    .ph-bottom-features { flex-direction: column; gap: 2rem; border-top: none; }
    .ph-bot-feat:not(:last-child) { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 2rem; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('PremiumHero-{{ section.id }}');
    if (!section) return;

    const mainImage = section.querySelector('#PH_MainImage');
    const thumbnails = section.querySelectorAll('.ph-thumb');
    const paginations = section.querySelectorAll('.ph-page-num');
    
    if (thumbnails.length === 0) return;

    let currentIndex = 0;
    let autoPlayInterval;

    function goToSlide(index) {
      if (index < 0 || index >= thumbnails.length) return;
      
      // Update Thumbs
      thumbnails.forEach(t => t.classList.remove('is-active'));
      thumbnails[index].classList.add('is-active');

      // Update Pagination
      paginations.forEach(p => p.classList.remove('is-active'));
      if(paginations[index]) paginations[index].classList.add('is-active');

      currentIndex = index;

      // Update Main Image
      const newImageUrl = thumbnails[index].getAttribute('data-img');
      if (newImageUrl && mainImage) {
        mainImage.classList.add('fade-out');
        setTimeout(() => {
          mainImage.src = newImageUrl;
          mainImage.onload = () => mainImage.classList.remove('fade-out');
        }, 300);
      }
    }

    function nextSlide() {
      let nextIndex = (currentIndex + 1) % thumbnails.length;
      goToSlide(nextIndex);
    }

    function startAutoPlay() {
      stopAutoPlay();
      if (thumbnails.length > 1) {
        autoPlayInterval = setInterval(nextSlide, 4000);
      }
    }

    function stopAutoPlay() {
      if (autoPlayInterval) clearInterval(autoPlayInterval);
    }

    thumbnails.forEach((thumb, index) => {
      thumb.addEventListener('click', () => {
        goToSlide(index);
        startAutoPlay();
      });
    });
    
    paginations.forEach((page, index) => {
      page.addEventListener('click', () => {
        goToSlide(index);
        startAutoPlay();
      });
    });

    section.addEventListener('mouseenter', stopAutoPlay);
    section.addEventListener('mouseleave', startAutoPlay);

    startAutoPlay();
  });
</script>

