<div class="custom-shoe-slider" id="shoeSlider-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  
  <!-- Left Column: Static Title -->
  <div class="custom-shoe-slider__left-title">
    <h2>{{ section.settings.left_title }}</h2>
  </div>

  <!-- Center Area: Background Text & Images -->
  <div class="custom-shoe-slider__center">
    <!-- Dynamic Background Text -->
    <div class="custom-shoe-slider__bg-text-container">
      {% for block in section.blocks %}
        <div class="custom-shoe-slider__bg-text slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {{ block.settings.bg_text }}
        </div>
      {% endfor %}
    </div>

    <!-- The Shoes -->
    <div class="custom-shoe-slider__images-container">
      {% for block in section.blocks %}
        {% assign slide_product = block.settings.product %}
        {% assign slide_image = block.settings.custom_image | default: slide_product.featured_image %}
        
        <div class="custom-shoe-slider__shoe-image slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
          {% if slide_image != blank %}
            {{ slide_image | image_url: width: 1000 | image_tag: class: 'shoe-img' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'shoe-img placeholder' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>

    <!-- Navigation Dots -->
    <div class="custom-shoe-slider__nav-dots">
      {% for block in section.blocks %}
        <button class="nav-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  </div>

  <!-- Right Column: Dynamic Info -->
  <div class="custom-shoe-slider__right-info">
    <div class="custom-shoe-slider__info-container">
      {% for block in section.blocks %}
        {% assign slide_product = block.settings.product %}
        {% assign slide_title = block.settings.custom_title | default: slide_product.title | default: "NIKE AIR MAX PRE-DAY." %}
        {% assign slide_price = slide_product.price | money | default: "$160" %}

        <div class="custom-shoe-slider__info-item slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
          <h3 class="shoe-title">{{ slide_title }}</h3>
          <p class="shoe-price">{{ slide_price }}</p>
        </div>
      {% endfor %}
    </div>
  </div>

</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@800;900&family=Rajdhani:wght@600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap');

  .custom-shoe-slider {
    position: relative;
    width: 100%;
    height: 600px;
    display: flex;
    flex-direction: row;
    align-items: center;
    overflow: hidden;
    padding: 0 8%;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
  }

  /* Left Title */
  .custom-shoe-slider__left-title {
    flex: 1;
    z-index: 10;
    display: flex;
    justify-content: flex-start;
  }
  .custom-shoe-slider__left-title h2 {
    font-family: 'Inter', sans-serif;
    font-size: {{ section.settings.left_title_size }}px;
    font-weight: 300;
    line-height: 1.05;
    color: {{ section.settings.text_color }};
    margin: 0;
    text-transform: uppercase;
    white-space: pre-line;
    letter-spacing: -2px;
  }

  /* Center Area */
  .custom-shoe-slider__center {
    flex: 2;
    position: relative;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 5;
  }

  /* Background Text */
  .custom-shoe-slider__bg-text-container {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
    pointer-events: none;
  }
  .custom-shoe-slider__bg-text {
    position: absolute;
    font-family: 'Inter', sans-serif;
    font-size: 25vw; /* Extremely large */
    font-weight: 900;
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.03 }}; /* Very faint */
    text-transform: uppercase;
    letter-spacing: 0;
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    white-space: nowrap;
    line-height: 0.8;
  }
  .custom-shoe-slider__bg-text.active {
    opacity: 1;
    transform: scale(1);
  }

  /* Shoe Images */
  .custom-shoe-slider__images-container {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 3;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .custom-shoe-slider__shoe-image {
    position: absolute;
    width: 90%;
    max-width: 800px;
    opacity: 0;
    transform: translateX(100px) rotate(10deg);
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .custom-shoe-slider__shoe-image.active {
    opacity: 1;
    transform: translateX(0) rotate(-15deg); /* Match Nike tilt */
  }
  .shoe-img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(-20px 30px 25px rgba(0,0,0,0.25)); /* Heavy drop shadow for floating effect */
  }
  .shoe-img.placeholder {
    fill: #333;
    background-color: transparent;
  }

  /* Nav Dots */
  .custom-shoe-slider__nav-dots {
    position: absolute;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 16px;
    z-index: 10;
  }
  .nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.3s ease;
  }
  .nav-dot.active {
    background: {{ section.settings.text_color }};
    border-color: {{ section.settings.text_color }};
    transform: scale(1.3);
  }

  /* Right Info */
  .custom-shoe-slider__right-info {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    z-index: 10;
  }
  .custom-shoe-slider__info-container {
    position: relative;
    width: 100%;
    height: 120px;
  }
  .custom-shoe-slider__info-item {
    position: absolute;
    top: 50%;
    right: 0;
    transform: translateY(-50%) translateX(30px);
    opacity: 0;
    text-align: left;
    transition: opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1), transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .custom-shoe-slider__info-item.active {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  .shoe-title {
    font-size: 16px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    margin: 0 0 12px 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.2;
    max-width: 180px;
  }
  .shoe-price {
    font-size: 20px;
    font-weight: 400;
    color: {{ section.settings.text_color }};
    margin: 0;
  }

  /* Responsive Design */
  @media (max-width: 990px) {
    .custom-shoe-slider {
      flex-direction: column;
      padding: 60px 5%;
    }
    .custom-shoe-slider__left-title,
    .custom-shoe-slider__right-info {
      text-align: center;
      width: 100%;
      flex: none;
    }
    .custom-shoe-slider__left-title h2 {
      font-size: 60px;
    }
    .custom-shoe-slider__info-item {
      right: 50%;
      transform: translateY(-50%) translateX(50%);
      text-align: center;
    }
    .custom-shoe-slider__info-item.active {
      transform: translateY(-50%) translateX(50%);
    }
    .custom-shoe-slider__bg-text {
      font-size: 100px;
    }
    .custom-shoe-slider__center {
      height: 400px;
      margin: 40px 0;
    }
    .custom-shoe-slider__nav-dots {
      bottom: -20px;
    }
  }
</style>

<script>
  function initCustomShoeSlider(sliderContainer) {
    const dots = sliderContainer.querySelectorAll('.nav-dot');
    let currentIndex = 0;
    const totalSlides = dots.length;
    let autoPlayInterval;
    
    function goToSlide(index) {
      // Remove active class from all elements in this specific slider
      sliderContainer.querySelectorAll('.slide-item, .nav-dot').forEach(el => {
        el.classList.remove('active');
      });
      
      // Add active class to corresponding items
      sliderContainer.querySelectorAll(`.slide-${index}`).forEach(el => {
        el.classList.add('active');
      });
      
      // Add active to the clicked dot
      const activeDot = sliderContainer.querySelector(`.nav-dot[data-index="${index}"]`);
      if (activeDot) activeDot.classList.add('active');
      
      currentIndex = parseInt(index);
    }

    function nextSlide() {
      if (totalSlides === 0) return;
      let nextIndex = (currentIndex + 1) % totalSlides;
      goToSlide(nextIndex);
    }

    function startAutoPlay() {
      stopAutoPlay();
      if (totalSlides > 1) {
        autoPlayInterval = setInterval(nextSlide, 4000); // 4 seconds per slide
      }
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
      }
    }

    // Attach click events
    dots.forEach(dot => {
      dot.addEventListener('click', function() {
        const index = this.getAttribute('data-index');
        goToSlide(index);
        startAutoPlay(); // Reset timer on click
      });
    });

    // Pause auto-scroll on hover, resume on mouse leave
    sliderContainer.addEventListener('mouseenter', stopAutoPlay);
    sliderContainer.addEventListener('mouseleave', startAutoPlay);

    // Handle Shopify Theme Editor events
    sliderContainer.addEventListener('shopify:block:select', function(event) {
      stopAutoPlay();
      const block = event.target;
      if (block.classList.contains('slide-item')) {
         const index = block.getAttribute('data-block-index');
         if(index !== null) goToSlide(index);
      } else {
         // Fallback if the event target is the wrapper (Shopify wraps blocks)
         const slideItem = block.querySelector('.slide-item');
         if (slideItem) {
           const index = slideItem.getAttribute('data-block-index');
           if(index !== null) goToSlide(index);
         }
      }
    });

    sliderContainer.addEventListener('shopify:block:deselect', function(event) {
      startAutoPlay();
    });

    // Start auto-play on init
    startAutoPlay();
  }

  document.addEventListener("DOMContentLoaded", function() {
    const sliders = document.querySelectorAll('.custom-shoe-slider');
    sliders.forEach(slider => initCustomShoeSlider(slider));
  });

  // Handle section reload in Theme Editor
  document.addEventListener('shopify:section:load', function(event) {
    const slider = event.target.querySelector('.custom-shoe-slider');
    if (slider) {
      initCustomShoeSlider(slider);
    }
  });
</script>

{% schema %}
{
  "name": "Carousel Shoes Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F4F4F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "textarea",
      "id": "left_title",
      "label": "Left Heading",
      "default": "JUST\nDO\nIT."
    },
    {
      "type": "range",
      "id": "left_title_size",
      "label": "Left Heading Size (Desktop)",
      "min": 40,
      "max": 150,
      "step": 2,
      "unit": "px",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Shoe Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product (Auto-fills Image, Title, Price)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Transparent PNG recommended, overrides Product image)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title (Overrides Product Title)"
        },
        {
          "type": "text",
          "id": "bg_text",
          "label": "Background Text",
          "default": "NIKE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carousel Shoes Hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
