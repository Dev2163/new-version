<div class="custom-shoe-slider" id="shoeSlider-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  
  <!-- Vertical Sidebar (ONE9) -->
  <div class="custom-shoe-slider__sidebar">
    <div class="custom-shoe-slider__sidebar-inner">
      <div class="sidebar-text">{{ section.settings.sidebar_text }}</div>
      <div class="sidebar-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
      </div>
      <div class="sidebar-line"></div>
    </div>
  </div>

  <!-- Background Text -->
  <div class="custom-shoe-slider__bg-text-container">
    {% for block in section.blocks %}
      <div class="custom-shoe-slider__bg-text slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        {{ block.settings.bg_text }}
      </div>
    {% endfor %}
  </div>

  <!-- Content Layer (Text & Button on Left) -->
  <div class="custom-shoe-slider__content-layer">
    <div class="custom-shoe-slider__info-container">
      {% for block in section.blocks %}
        {% assign slide_product = block.settings.product %}
        {% assign slide_title = block.settings.custom_title | default: slide_product.title | default: "WEAR YOUR\nUNIVERSE" %}
        
        <div class="custom-shoe-slider__info-item slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
          <h2 class="shoe-title">{{ slide_title | newline_to_br }}</h2>
          
          {% if section.settings.subtitle != blank %}
            <p class="shoe-subtitle">{{ section.settings.subtitle }}</p>
          {% endif %}
          
          <a href="{{ slide_product.url | default: '#' }}" class="shoe-btn">{{ section.settings.button_text }}</a>
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Shoe Image Layer (Right) -->
  <div class="custom-shoe-slider__image-layer">
    <div class="custom-shoe-slider__images-container">
      {% for block in section.blocks %}
        {% assign slide_product = block.settings.product %}
        {% assign slide_image = block.settings.custom_image | default: slide_product.featured_image %}
        
        <div class="custom-shoe-slider__shoe-image slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
          {% if slide_image != blank %}
            {{ slide_image | image_url: width: 1000 | image_tag: class: 'shoe-img' }}
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'shoe-img placeholder' }}
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  <!-- Navigation Dots -->
  <div class="custom-shoe-slider__nav-dots">
    {% for block in section.blocks %}
      <button class="nav-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
    {% endfor %}
  </div>

</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@800;900&family=Rajdhani:wght@600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap');

  .custom-shoe-slider {
    position: relative;
    width: 100%;
    height: 700px; /* Adjust as needed */
    display: flex;
    overflow: hidden;
    background-color: #000;
  }

  /* Vertical Sidebar */
  .custom-shoe-slider__sidebar {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 80px;
    z-index: 20;
    display: flex;
    justify-content: center;
    padding-top: 150px;
  }
  .custom-shoe-slider__sidebar-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }
  .sidebar-text {
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-family: 'Orbitron', sans-serif;
    font-size: 24px;
    font-weight: 800;
    color: #F0C454;
    letter-spacing: 4px;
    margin-bottom: 30px;
  }
  .sidebar-icon {
    width: 24px;
    height: 24px;
    color: #F0C454;
    margin-bottom: 20px;
  }
  .sidebar-line {
    width: 2px;
    background-color: #F0C454;
    flex-grow: 1;
    margin-bottom: 50px;
  }

  /* Background Text */
  .custom-shoe-slider__bg-text-container {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
    pointer-events: none;
  }
  .custom-shoe-slider__bg-text {
    position: absolute;
    font-family: 'Inter', sans-serif;
    font-size: 25vw; 
    font-weight: 900;
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.05);
    text-transform: uppercase;
    letter-spacing: -5px;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
    line-height: 0.8;
  }
  .custom-shoe-slider__bg-text.active {
    opacity: 1;
    transform: scale(1);
  }

  /* Content Layer */
  .custom-shoe-slider__content-layer {
    position: absolute;
    left: 80px; /* offset sidebar */
    top: 0;
    bottom: 0;
    width: 50%;
    z-index: 10;
    display: flex;
    align-items: center;
    padding-left: 5%;
  }
  .custom-shoe-slider__info-container {
    position: relative;
    width: 100%;
    height: 350px;
  }
  .custom-shoe-slider__info-item {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%) translateX(-40px);
    opacity: 0;
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: 0.1s;
    text-align: center; /* match image */
  }
  .custom-shoe-slider__info-item.active {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
  }
  
  /* Glowing Title */
  .shoe-title {
    font-family: 'Orbitron', sans-serif;
    font-size: clamp(40px, 5vw, 80px);
    font-weight: 900;
    color: #ffffff;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    line-height: 1.1;
    text-shadow: 0 0 20px rgba(255,255,255,0.4), 0 0 40px rgba(255,255,255,0.2);
  }
  
  /* Gold Subtitle */
  .shoe-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 18px;
    font-weight: 600;
    color: #F0C454;
    margin: 0 0 40px 0;
    letter-spacing: 0.5px;
  }

  /* Yellow Button */
  .shoe-btn {
    display: inline-block;
    background-color: #F0C454;
    color: #000000;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-decoration: none;
    padding: 15px 40px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    box-shadow: 0 0 30px rgba(240, 196, 84, 0.3);
  }
  .shoe-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 40px rgba(240, 196, 84, 0.5);
    background-color: #fce28b;
  }

  /* Image Layer */
  .custom-shoe-slider__image-layer {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 50%;
    z-index: 5;
  }
  .custom-shoe-slider__images-container {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .custom-shoe-slider__shoe-image {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    opacity: 0;
    transform: translateX(100px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .custom-shoe-slider__shoe-image.active {
    opacity: 1;
    transform: translateX(0);
  }
  .shoe-img {
    height: 100%;
    width: auto;
    object-fit: cover;
    object-position: right center;
    mask-image: linear-gradient(to right, transparent, black 20%);
    -webkit-mask-image: linear-gradient(to right, transparent, black 20%);
  }

  /* Nav Dots */
  .custom-shoe-slider__nav-dots {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 16px;
    z-index: 20;
  }
  .nav-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: all 0.4s ease;
  }
  .nav-dot:hover {
    border-color: rgba(255,255,255,0.8);
  }
  .nav-dot.active {
    background: #F0C454;
    border-color: #F0C454;
    transform: scale(1.4);
    box-shadow: 0 0 10px rgba(240, 196, 84, 0.5);
  }

  /* Mobile Pro Styles */
  @media (max-width: 990px) {
    .custom-shoe-slider {
      flex-direction: column;
      height: 100svh;
      padding-top: 60px;
    }
    
    .custom-shoe-slider__sidebar {
      display: none; /* Hide sidebar on mobile to save space */
    }

    .custom-shoe-slider__content-layer {
      position: relative;
      width: 100%;
      left: 0;
      height: 50%;
      align-items: flex-end;
      padding: 0 20px 20px;
      z-index: 10;
    }
    .custom-shoe-slider__info-container {
      height: auto;
    }
    .custom-shoe-slider__info-item {
      position: relative;
      top: 0;
      transform: translateY(20px);
      text-align: center;
    }
    .custom-shoe-slider__info-item.active {
      transform: translateY(0);
    }
    
    .shoe-title {
      font-size: clamp(32px, 8vw, 60px);
    }

    .custom-shoe-slider__image-layer {
      position: relative;
      width: 100%;
      height: 50%;
      z-index: 5;
    }
    .custom-shoe-slider__shoe-image {
      justify-content: center;
    }
    .shoe-img {
      mask-image: linear-gradient(to bottom, transparent, black 20%);
      -webkit-mask-image: linear-gradient(to bottom, transparent, black 20%);
      object-position: center;
      width: 100%;
      object-fit: contain;
    }
    
    .custom-shoe-slider__bg-text {
      font-size: 35vw;
    }
  }
</style>

<script>
  function initCustomShoeSlider(sliderContainer) {
    const dots = sliderContainer.querySelectorAll('.nav-dot');
    let currentIndex = 0;
    const totalSlides = dots.length;
    let autoPlayInterval;
    
    function goToSlide(index) {
      sliderContainer.querySelectorAll('.slide-item, .nav-dot').forEach(el => {
        el.classList.remove('active');
      });
      
      sliderContainer.querySelectorAll(`.slide-${index}`).forEach(el => {
        el.classList.add('active');
      });
      
      const activeDot = sliderContainer.querySelector(`.nav-dot[data-index="${index}"]`);
      if (activeDot) activeDot.classList.add('active');
      
      currentIndex = parseInt(index);
    }

    function nextSlide() {
      if (totalSlides === 0) return;
      let nextIndex = (currentIndex + 1) % totalSlides;
      goToSlide(nextIndex);
    }

    function startAutoPlay() {
      stopAutoPlay();
      if (totalSlides > 1) {
        autoPlayInterval = setInterval(nextSlide, 5000); 
      }
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
      }
    }

    dots.forEach(dot => {
      dot.addEventListener('click', function() {
        const index = this.getAttribute('data-index');
        goToSlide(index);
        startAutoPlay();
      });
    });

    sliderContainer.addEventListener('mouseenter', stopAutoPlay);
    sliderContainer.addEventListener('mouseleave', startAutoPlay);

    sliderContainer.addEventListener('shopify:block:select', function(event) {
      stopAutoPlay();
      const block = event.target;
      if (block.classList.contains('slide-item')) {
         const index = block.getAttribute('data-block-index');
         if(index !== null) goToSlide(index);
      } else {
         const slideItem = block.querySelector('.slide-item');
         if (slideItem) {
           const index = slideItem.getAttribute('data-block-index');
           if(index !== null) goToSlide(index);
         }
      }
    });

    sliderContainer.addEventListener('shopify:block:deselect', function(event) {
      startAutoPlay();
    });

    startAutoPlay();
  }

  document.addEventListener("DOMContentLoaded", function() {
    const sliders = document.querySelectorAll('.custom-shoe-slider');
    sliders.forEach(slider => initCustomShoeSlider(slider));
  });

  document.addEventListener('shopify:section:load', function(event) {
    const slider = event.target.querySelector('.custom-shoe-slider');
    if (slider) {
      initCustomShoeSlider(slider);
    }
  });
</script>

{% schema %}
{
  "name": "Carousel Shoes Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "sidebar_text",
      "label": "Sidebar Vertical Text",
      "default": "ONE9"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Engineered for warmth. Designed for movement."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Shoe Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product (Auto-fills Image, Title, Price)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Transparent PNG recommended, overrides Product image)"
        },
        {
          "type": "textarea",
          "id": "custom_title",
          "label": "Custom Title (Overrides Product Title)"
        },
        {
          "type": "text",
          "id": "bg_text",
          "label": "Background Text",
          "default": "NIKE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Carousel Shoes Hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
