<div class="custom-shoe-slider one9-hero" id="shoeSlider-{{ section.id }}" style="background-color: {{ section.settings.bg_color }};">
  
  <!-- Left Column: ONE9 Vertical Sidebar -->
  <div class="one9-sidebar">
    <div class="one9-sidebar__text">{{ section.settings.sidebar_text }}</div>
    <div class="one9-sidebar__icon">
      <!-- Decorative Eye Icon -->
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 4.5C7 4.5 2.73 7.61 1 12.5C2.73 17.39 7 20.5 12 20.5C17 20.5 21.27 17.39 23 12.5C21.27 7.61 17 4.5 12 4.5ZM12 18C8.96 18 6.5 15.54 6.5 12.5C6.5 9.46 8.96 7 12 7C15.04 7 17.5 9.46 17.5 12.5C17.5 15.54 15.04 18 12 18ZM12 9C10.07 9 8.5 10.57 8.5 12.5C8.5 14.43 10.07 16 12 16C13.93 16 15.5 14.43 15.5 12.5C15.5 10.57 13.93 9 12 9Z" fill="{{ section.settings.accent_color }}"/>
      </svg>
    </div>
    <div class="one9-sidebar__line" style="background-color: {{ section.settings.accent_color }};"></div>
  </div>

  <!-- Center-Left Content Area -->
  <div class="one9-content">
    <div class="one9-content__wrapper">
      {% for block in section.blocks %}
        {% assign slide_product = block.settings.product %}
        {% assign slide_title = block.settings.custom_title | default: slide_product.title | default: "WEAR YOUR UNIVERSE" %}
        
        <div class="one9-slide-info slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <h1 class="one9-title">{{ slide_title }}</h1>
          <p class="one9-subtitle" style="color: {{ section.settings.accent_color }};">{{ section.settings.subtitle }}</p>
          <a href="{{ slide_product.url | default: '#' }}" class="one9-btn" style="background-color: {{ section.settings.accent_color }}; box-shadow: 0 0 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.4 }};">SHOP NOW</a>
        </div>
      {% endfor %}
    </div>

    <!-- Navigation Dots -->
    <div class="custom-shoe-slider__nav-dots">
      {% for block in section.blocks %}
        <button class="nav-dot {% if forloop.first %}active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  </div>

  <!-- Right Image Area -->
  <div class="one9-images">
    {% for block in section.blocks %}
      {% assign slide_product = block.settings.product %}
      {% assign slide_image = block.settings.custom_image | default: slide_product.featured_image %}
      
      <div class="one9-image-wrapper slide-item slide-{{ forloop.index0 }} {% if forloop.first %}active{% endif %}" data-block-index="{{ forloop.index0 }}">
        {% if slide_image != blank %}
          {{ slide_image | image_url: width: 1000 | image_tag: class: 'shoe-img', loading: 'eager' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'shoe-img placeholder' }}
        {% endif %}
      </div>
    {% endfor %}
  </div>

</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@800;900&family=Michroma&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

  .custom-shoe-slider.one9-hero {
    position: relative;
    width: 100%;
    height: 800px;
    display: flex;
    flex-direction: row;
    align-items: stretch;
    overflow: hidden;
    box-sizing: border-box;
    font-family: 'Inter', sans-serif;
  }

  /* Vertical Sidebar */
  .one9-sidebar {
    width: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: 100px;
    border-right: 1px solid rgba(255,255,255,0.05);
    z-index: 10;
  }
  .one9-sidebar__text {
    font-family: 'Orbitron', sans-serif;
    color: {{ section.settings.accent_color }};
    font-size: 32px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 5px;
    writing-mode: vertical-rl;
    text-orientation: upright;
    margin-bottom: 30px;
  }
  .one9-sidebar__icon {
    margin-bottom: 30px;
  }
  .one9-sidebar__line {
    width: 2px;
    height: 150px;
    border-radius: 2px;
  }

  /* Center Content */
  .one9-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 5%;
    position: relative;
    z-index: 5;
  }
  .one9-content__wrapper {
    position: relative;
    height: 400px; /* enough space to stack text */
  }
  
  .one9-slide-info {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    width: 100%;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .one9-slide-info.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(-50%) translateX(0);
  }
  /* Slide out to left when hiding, slide in from right when appearing (managed via js or simple fade) */
  .one9-slide-info:not(.active) {
    transform: translateY(-50%) translateX(-30px);
  }

  .one9-title {
    font-family: 'Michroma', sans-serif;
    font-size: clamp(40px, 6vw, 90px);
    font-weight: 700;
    color: {{ section.settings.text_color }};
    line-height: 1.1;
    margin: 0 0 20px 0;
    text-transform: uppercase;
    white-space: pre-line;
    text-shadow: 0 0 20px rgba(255,255,255,0.3);
  }
  
  .one9-subtitle {
    font-size: clamp(16px, 2vw, 22px);
    font-weight: 600;
    letter-spacing: 0.5px;
    margin: 0 0 40px 0;
  }

  .one9-btn {
    display: inline-block;
    color: #000;
    font-family: 'Inter', sans-serif;
    font-weight: 700;
    font-size: 16px;
    padding: 15px 40px;
    border-radius: 4px;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.3s ease;
  }
  .one9-btn:hover {
    transform: translateY(-3px) scale(1.05);
    filter: brightness(1.1);
  }

  /* Nav Dots */
  .custom-shoe-slider__nav-dots {
    display: flex;
    gap: 15px;
    margin-top: 40px;
  }
  .nav-dot {
    width: 40px;
    height: 4px;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .nav-dot.active {
    background: {{ section.settings.accent_color }};
    width: 60px;
  }

  /* Right Images */
  .one9-images {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }
  .one9-image-wrapper {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .one9-image-wrapper.active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0) scale(1);
  }
  .one9-image-wrapper:not(.active) {
    transform: translateX(100px) scale(0.9);
  }

  .shoe-img {
    max-width: 120%;
    max-height: 120%;
    object-fit: contain;
    filter: drop-shadow(0 30px 40px rgba(0,0,0,0.7));
  }
  
  .placeholder {
    fill: #333;
    width: 80%;
  }

  /* Responsive Design - Mobile */
  @media (max-width: 990px) {
    .custom-shoe-slider.one9-hero {
      flex-direction: column;
      height: 100svh;
      padding: 0;
      justify-content: center;
    }
    
    .one9-sidebar {
      position: absolute;
      top: 20px;
      left: 20px;
      width: auto;
      height: auto;
      flex-direction: row;
      border: none;
      padding: 0;
      z-index: 20;
    }
    .one9-sidebar__text {
      writing-mode: horizontal-tb;
      letter-spacing: 3px;
      margin: 0 15px 0 0;
      font-size: 24px;
    }
    .one9-sidebar__icon, .one9-sidebar__line {
      display: none; /* Hide on mobile to save space */
    }

    .one9-content {
      padding: 0 20px;
      order: 2;
      align-items: center;
      text-align: center;
      flex: 0 0 auto;
      margin-bottom: 40px;
    }
    .one9-slide-info {
      position: relative;
      top: auto;
      left: auto;
      transform: none !important;
      display: none;
    }
    .one9-slide-info.active {
      display: block;
    }
    .one9-content__wrapper {
      height: auto;
    }
    .one9-title {
      font-size: 40px;
    }
    
    .one9-images {
      order: 1;
      width: 100%;
      height: 40vh;
      margin-top: 80px; /* push down below header */
    }
    .shoe-img {
      max-width: 90%;
    }
    
    .custom-shoe-slider__nav-dots {
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const sliderContainer = document.getElementById('shoeSlider-{{ section.id }}');
    if (!sliderContainer) return;
    initOne9Slider(sliderContainer);
  });

  document.addEventListener("shopify:section:load", function(event) {
    if(event.target.querySelector('.one9-hero')) {
      initOne9Slider(event.target);
    }
  });

  function initOne9Slider(sliderContainer) {
    const dots = sliderContainer.querySelectorAll('.nav-dot');
    let currentIndex = 0;
    const totalSlides = dots.length;
    let autoPlayInterval;

    function goToSlide(index) {
      if(index < 0 || index >= totalSlides) return;
      
      sliderContainer.querySelectorAll('.slide-item.active').forEach(el => el.classList.remove('active'));
      dots.forEach(dot => dot.classList.remove('active'));
      
      sliderContainer.querySelectorAll(`.slide-${index}`).forEach(el => el.classList.add('active'));
      if(dots[index]) dots[index].classList.add('active');
      
      currentIndex = index;
    }

    function nextSlide() {
      let nextIndex = (currentIndex + 1) % totalSlides;
      goToSlide(nextIndex);
    }

    function startAutoPlay() {
      autoPlayInterval = setInterval(nextSlide, 4000);
    }

    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        goToSlide(index);
        startAutoPlay();
      });
    });

    // Start auto-play on init
    startAutoPlay();
    
    // Pause on hover
    sliderContainer.addEventListener('mouseenter', stopAutoPlay);
    sliderContainer.addEventListener('mouseleave', startAutoPlay);
  }
</script>

{% schema %}
{
  "name": "Shoe Slider Hero (ONE9)",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Yellow)",
      "default": "#F4D03F"
    },
    {
      "type": "text",
      "id": "sidebar_text",
      "label": "Sidebar Vertical Text",
      "default": "ONE9"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Engineered for warmth. Designed for movement."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Shoe Slide",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Shoe Image (Optional)",
          "info": "Leave blank to use product image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title",
          "info": "Overrides product title. Example: WEAR YOUR\nUNIVERSE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoe Slider Hero (ONE9)",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "custom_title": "WEAR YOUR\nUNIVERSE"
          }
        },
        {
          "type": "slide",
          "settings": {
            "custom_title": "OWN THE\nSTREETS"
          }
        }
      ]
    }
  ]
}
{% endschema %}
