<div class="custom-footer-wrapper" style="background-color: {{ section.settings.bg_color | default: '#0A0A0A' }}; color: {{ section.settings.text_color | default: '#E0E0E0' }};">
  <div class="page-width">
    <div class="custom-footer">
      
      <!-- Column 1: Brand -->
      <div class="footer-col brand-col">
        <h2 class="footer-logo">{{ section.settings.brand_logo_text | default: 'ONE9' }}</h2>
        <p class="brand-text">
          {{ section.settings.brand_text | default: 'Zodiac streetwear inspired by your energy.<br>Built different. Worn everywhere.' }}
        </p>
        <div class="social-icons">
          {%- if section.settings.instagram_link != blank or section.settings.show_socials -%}
            <a href="{{ section.settings.instagram_link | default: '#' }}" target="_blank" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.whatsapp_link != blank or section.settings.show_socials -%}
            <a href="{{ section.settings.whatsapp_link | default: '#' }}" target="_blank" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Column 2: SHOP -->
      <div class="footer-col">
        <h3 class="col-heading">{{ section.settings.shop_heading | default: 'SHOP' }}</h3>
        <ul class="footer-links">
          {%- if section.settings.shop_menu != blank -%}
            {%- for link in section.settings.shop_menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/collections/all">Shop All</a></li>
            <li><a href="/collections/men">Men</a></li>
            <li><a href="/collections/women">Women</a></li>
            <li><a href="/collections/new-arrivals">New Arrivals</a></li>
            <li><a href="/pages/contact">Contact</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 3: HELP -->
      <div class="footer-col">
        <h3 class="col-heading">{{ section.settings.help_heading | default: 'HELP' }}</h3>
        <ul class="footer-links">
          {%- if section.settings.help_menu != blank -%}
            {%- for link in section.settings.help_menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/contact">Track Your Order</a></li>
            <li><a href="/pages/contact">Shipping & Delivery</a></li>
            <li><a href="/pages/contact">Returns & Exchanges</a></li>
            <li><a href="/pages/contact">FAQs</a></li>
            <li><a href="/pages/contact">Size Guide</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 4: ABOUT -->
      <div class="footer-col">
        <h3 class="col-heading">{{ section.settings.about_heading | default: 'ABOUT' }}</h3>
        <ul class="footer-links">
          {%- if section.settings.about_menu != blank -%}
            {%- for link in section.settings.about_menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          {%- else -%}
            <li><a href="/pages/about">Our Story</a></li>
            <li><a href="/pages/about">Sustainability</a></li>
            <li><a href="/pages/about">Careers</a></li>
            <li><a href="/pages/about">Press</a></li>
          {%- endif -%}
        </ul>
      </div>

      <!-- Column 5: CONTACT -->
      <div class="footer-col contact-col">
        <h3 class="col-heading">{{ section.settings.contact_heading | default: 'CONTACT' }}</h3>
        <ul class="contact-list">
          {%- if section.settings.address != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              <span>{{ section.settings.address }}</span>
            </li>
          {%- endif -%}
          {%- if section.settings.phone != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              <span>{{ section.settings.phone }}</span>
            </li>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
            <li>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              <span>{{ section.settings.email }}</span>
            </li>
          {%- endif -%}
        </ul>
        <a href="{{ section.settings.btn_link | default: '/pages/contact' }}" class="btn-get-in-touch">{{ section.settings.btn_text | default: 'GET IN TOUCH' }}</a>
      </div>

    </div>

    <!-- Bottom Copyright Bar -->
    <div style="border-top: 1px solid rgba(255,255,255,0.08); margin-top: 40px; padding-top: 24px; text-align: center; font-size: 13px; color: #777; font-family: 'Rajdhani', sans-serif;">
      {{ section.settings.copyright_text | default: '© 2026 ONE9 Streetwear. All rights reserved.' }}
    </div>
  </div>
</div>

{% stylesheet %}
  .custom-footer-wrapper {
    background-color: #0A0A0A;
    color: #E0E0E0;
    padding: 60px 0 40px;
    font-family: var(--font-body-family, sans-serif);
  }

  .custom-footer {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr 1.4fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    animation: footerFadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes footerFadeIn {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 1024px) {
    .custom-footer {
      grid-template-columns: repeat(3, 1fr);
    }
    .brand-col {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 768px) {
    .custom-footer-wrapper {
      padding: 40px 0 30px;
    }
    .custom-footer {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 20px;
      padding: 0 24px;
    }
    .brand-col, .contact-col {
      grid-column: 1 / -1;
      text-align: center;
    }
    .social-icons {
      justify-content: center;
    }
    .contact-list li {
      justify-content: center;
    }
    .footer-logo {
      font-size: 32px;
    }
  }

  .footer-logo {
    font-size: 38px;
    font-weight: 900;
    margin: 0 0 16px 0;
    letter-spacing: 2px;
    color: #F4C430;
    font-family: "Orbitron", "Rajdhani", sans-serif;
    text-transform: uppercase;
    transition: all 0.4s ease;
    cursor: default;
    text-shadow: 0 0 15px rgba(244, 196, 48, 0.25);
  }

  .footer-logo:hover {
    text-shadow: 0 0 20px rgba(244, 196, 48, 0.6);
    transform: scale(1.02);
  }

  .brand-text {
    font-size: 15px;
    line-height: 1.8;
    color: #B0B0B0;
    margin-bottom: 24px;
  }

  .social-icons {
    display: flex;
    gap: 16px;
  }

  .social-icons a {
    color: #FFFFFF;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .social-icons a svg {
    width: 24px;
    height: 24px;
  }

  .social-icons a:hover {
    color: #F4C430;
    transform: scale(1.2) translateY(-3px);
    filter: drop-shadow(0 4px 6px rgba(244, 196, 48, 0.3));
  }

  .col-heading {
    font-size: 16px;
    font-weight: 700;
    color: #FFFFFF;
    margin-bottom: 24px;
    letter-spacing: 1px;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: #B0B0B0;
    text-decoration: none;
    font-size: 15px;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
  }

  .footer-links a:hover {
    color: #F4C430;
    transform: translateX(6px);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #B0B0B0;
    font-size: 15px;
  }

  .contact-list svg {
    width: 18px;
    height: 18px;
    color: #FFFFFF;
    flex-shrink: 0;
  }

  .btn-get-in-touch {
    display: inline-block;
    background-color: #F4C430;
    color: #000000;
    font-weight: 800;
    font-size: 14px;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.4s ease;
    box-shadow: 0 4px 15px rgba(244, 196, 48, 0.15);
    position: relative;
    overflow: hidden;
  }

  .btn-get-in-touch:hover {
    background-color: #FFFFFF;
    color: #000000;
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(255, 255, 255, 0.4);
  }
{% endstylesheet %}

