{% stylesheet %}
  .custom-footer-wrapper {
    background-color: #0A0A0A;
    color: #E0E0E0;
    padding: 60px 0 40px;
    font-family: var(--font-body-family, sans-serif);
  }

  .custom-footer {
    display: grid;
    grid-template-columns: 1.2fr 1fr 1fr 1fr 1.4fr;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
    animation: footerFadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes footerFadeIn {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media screen and (max-width: 1024px) {
    .custom-footer {
      grid-template-columns: repeat(3, 1fr);
    }
    .brand-col {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 768px) {
    .custom-footer {
      grid-template-columns: 1fr;
      gap: 30px;
    }
  }

  .footer-logo {
    font-size: 38px;
    font-weight: 900;
    margin: 0 0 16px 0;
    letter-spacing: 2px;
    color: #F4C430;
    font-family: "Orbitron", "Rajdhani", sans-serif;
    text-transform: uppercase;
    transition: all 0.4s ease;
    cursor: default;
    text-shadow: 0 0 15px rgba(244, 196, 48, 0.25);
  }

  .footer-logo:hover {
    text-shadow: 0 0 20px rgba(244, 196, 48, 0.6);
    transform: scale(1.02);
  }

  .brand-text {
    font-size: 15px;
    line-height: 1.8;
    color: #B0B0B0;
    margin-bottom: 24px;
  }

  .social-icons {
    display: flex;
    gap: 16px;
  }

  .social-icons a {
    color: #FFFFFF;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .social-icons a svg {
    width: 24px;
    height: 24px;
  }

  .social-icons a:hover {
    color: #F4C430;
    transform: scale(1.2) translateY(-3px);
    filter: drop-shadow(0 4px 6px rgba(244, 196, 48, 0.3));
  }

  .col-heading {
    font-size: 16px;
    font-weight: 700;
    color: #FFFFFF;
    margin-bottom: 24px;
    letter-spacing: 1px;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-links a {
    color: #B0B0B0;
    text-decoration: none;
    font-size: 15px;
    transition: all 0.3s ease;
    display: inline-block;
    position: relative;
  }

  .footer-links a:hover {
    color: #F4C430;
    transform: translateX(6px);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #B0B0B0;
    font-size: 15px;
  }

  .contact-list svg {
    width: 18px;
    height: 18px;
    color: #FFFFFF;
    flex-shrink: 0;
  }

  .btn-get-in-touch {
    display: inline-block;
    background-color: #F4C430;
    color: #000000;
    font-weight: 800;
    font-size: 14px;
    padding: 12px 24px;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.4s ease;
    box-shadow: 0 4px 15px rgba(244, 196, 48, 0.15);
    position: relative;
    overflow: hidden;
  }

  .btn-get-in-touch:hover {
    background-color: #FFFFFF;
    color: #000000;
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(255, 255, 255, 0.4);
  }
{% endstylesheet %}

