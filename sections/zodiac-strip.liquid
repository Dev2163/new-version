{% liquid
  assign heading = section.settings.heading | default: 'FIND YOUR SIGN'
  assign accent_color = section.settings.accent_color | default: '#F4C430'
  assign bg_color = section.settings.bg_color | default: '#0A0A0A'
  assign current_handle = collection.handle | downcase
%}

<div class="zodiac-strip-wrapper" style="background-color: {{ bg_color }}; --zodiac-accent: {{ accent_color }};">
  <div class="zodiac-strip section-padding">
    
    <div class="zodiac-strip__header">
      <span class="zodiac-strip__line zodiac-strip__line--left"></span>
      <h2 class="zodiac-strip__title">{{ heading }}</h2>
      <span class="zodiac-strip__line zodiac-strip__line--right"></span>
    </div>

    <div class="zodiac-strip__items">
      {% for block in section.blocks %}
        {% liquid
          assign sign_name = block.settings.sign_name
          assign sign_handle = sign_name | handleize
          assign default_link = '/collections/' | append: sign_handle
          assign sign_link = block.settings.sign_link | default: default_link
          assign is_active = false
          if current_handle == sign_handle
            assign is_active = true
          endif
        %}
        
        <a href="{{ sign_link }}" class="zodiac-strip__item {% if is_active %}zodiac-strip__item--active{% endif %}" {{ block.shopify_attributes }}>
          <div class="zodiac-strip__icon">
            {% if block.settings.custom_icon_svg != blank %}
              {{ block.settings.custom_icon_svg }}
            {% elsif block.settings.custom_icon_image != blank %}
              <img
                src="{{ block.settings.custom_icon_image | image_url: width: 80 }}"
                alt="{{ sign_name }}"
                loading="lazy"
                class="zodiac-strip__custom-img"
              >
            {% else %}
              {% case sign_handle %}
                {% when 'aries' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21V9M12 9a5 5 0 1 0-8-4M12 9a5 5 0 1 1 8-4" /></svg>
                {% when 'taurus' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="14" r="5" /><path d="M4 6c0 4 3 6 8 6s8-2 8-6" /></svg>
                {% when 'gemini' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 4h14M5 20h14M9 4v16M15 4v16" /></svg>
                {% when 'cancer' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="9" r="3" /><circle cx="6" cy="15" r="3" /><path d="M18 6C10 6 6 10 6 15M6 18c8 0 12-4 12-9" /></svg>
                {% when 'leo' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="16" r="3" /><path d="M8.5 14C10 10 14 6 18 6a3 3 0 0 1 3 3c0 4-4 8-4 13" /></svg>
                {% when 'virgo' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h2v12a3 3 0 0 0 6 0V6v11a3 3 0 0 0 6 0V6c0 5 4 6 4 3s-3-6-5-1" /></svg>
                {% when 'libra' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 20h14M5 17h4a3 3 0 1 1 6 0h4" /></svg>
                {% when 'scorpio' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5v10a3 3 0 0 0 6 0V5v10a3 3 0 0 0 6 0V5v7a3 3 0 0 0 3 3h1c2 2 0 0 0 2-2v-2m0 0l-2 2m2-2l2 2" /></svg>
                {% when 'sagittarius' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 4L5 19M14 4h6v6M7.5 13.5l3 3" /></svg>
                {% when 'capricorn' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12V6a3 3 0 0 1 6 0v11a3 3 0 0 0 6 0v-4a2 2 0 1 1 4 0v2a3 3 0 0 1-3 3h-1" /></svg>
                {% when 'aquarius' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 10l3-3 4 4 4-4 5 5M4 17l3-3 4 4 4-4 5 5" /></svg>
                {% when 'pisces' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4c4 4 4 12 0 16M18 4c-4 4-4 12 0 16M5 12h14" /></svg>
              {% endcase %}
            {% endif %}
          </div>
          <span class="zodiac-strip__name">{{ sign_name }}</span>
        </a>
      {% endfor %}
    </div>

  </div>
</div>

{% stylesheet %}
  .zodiac-strip-wrapper {
    width: 100%;
    border-block: 1px solid rgba(255, 255, 255, 0.05);
  }

  .zodiac-strip {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding-inline: var(--page-margin, 20px);
    padding-block: 30px;
  }

  .zodiac-strip__header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-bottom: 24px;
    width: 100%;
  }

  .zodiac-strip__title {
    color: var(--zodiac-accent);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    white-space: nowrap;
    margin: 0;
  }

  .zodiac-strip__line {
    height: 1px;
    flex-grow: 1;
  }

  .zodiac-strip__line--left {
    background: linear-gradient(90deg, transparent, var(--zodiac-accent));
    opacity: 0.4;
  }

  .zodiac-strip__line--right {
    background: linear-gradient(90deg, var(--zodiac-accent), transparent);
    opacity: 0.4;
  }

  .zodiac-strip__items {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    overflow-x: auto;
    scrollbar-width: none; /* Hide scrollbar Firefox */
    padding-block: 10px;
    -webkit-overflow-scrolling: touch;
  }

  .zodiac-strip__items::-webkit-scrollbar {
    display: none; /* Hide scrollbar Chrome/Safari */
  }

  @media screen and (min-width: 1024px) {
    .zodiac-strip__items {
      justify-content: space-between;
      gap: 16px;
      overflow-x: visible;
    }
  }

  .zodiac-strip__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: #888888;
    padding: 12px 14px;
    border: 1px solid transparent;
    border-radius: 8px;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    min-width: 76px;
    flex-shrink: 0;
  }

  .zodiac-strip__item:hover,
  .zodiac-strip__item--active {
    color: var(--zodiac-accent);
    border-color: rgba(244, 196, 48, 0.35);
    background-color: rgba(244, 196, 48, 0.04);
  }

  .zodiac-strip__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
  }

  .zodiac-strip__icon svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    transition: transform 0.3s ease;
  }

  .zodiac-strip__item:hover .zodiac-strip__icon svg {
    transform: scale(1.1);
  }

  .zodiac-strip__name {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-top: 8px;
  }

  .zodiac-strip__custom-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Zodiac Strip",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FIND YOUR SIGN"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F4C430"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    }
  ],
  "blocks": [
    {
      "type": "sign",
      "name": "Zodiac Sign",
      "settings": [
        {
          "type": "text",
          "id": "sign_name",
          "label": "Sign Name",
          "placeholder": "Aries"
        },
        {
          "type": "url",
          "id": "sign_link",
          "label": "Link Override"
        },
        {
          "type": "image_picker",
          "id": "custom_icon_image",
          "label": "Custom Icon Image (Optional)",
          "info": "Upload a custom PNG/SVG icon file instead of SVG code."
        },
        {
          "type": "html",
          "id": "custom_icon_svg",
          "label": "Custom Icon SVG (Override)",
          "info": "Paste custom SVG code here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zodiac Strip",
      "blocks": [
        { "type": "sign", "settings": { "sign_name": "Aries" } },
        { "type": "sign", "settings": { "sign_name": "Taurus" } },
        { "type": "sign", "settings": { "sign_name": "Gemini" } },
        { "type": "sign", "settings": { "sign_name": "Cancer" } },
        { "type": "sign", "settings": { "sign_name": "Leo" } },
        { "type": "sign", "settings": { "sign_name": "Virgo" } },
        { "type": "sign", "settings": { "sign_name": "Libra" } },
        { "type": "sign", "settings": { "sign_name": "Scorpio" } },
        { "type": "sign", "settings": { "sign_name": "Sagittarius" } },
        { "type": "sign", "settings": { "sign_name": "Capricorn" } },
        { "type": "sign", "settings": { "sign_name": "Aquarius" } },
        { "type": "sign", "settings": { "sign_name": "Pisces" } }
      ]
    }
  ]
}
{% endschema %}
