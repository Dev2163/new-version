{% comment %}
  ONE9 Luxury Streetwear - Premium Product Reviews & Customer Photo Gallery
{% endcomment %}

<div class="premium-reviews-section page-width">
  <div class="reviews-header">
    <h2 class="reviews-title">CUSTOMER REVIEWS</h2>
    <p class="reviews-subtitle">Real feedback from streetwear enthusiasts</p>
  </div>

  <!-- Rating Summary Card -->
  <div class="reviews-summary-card">
    <div class="summary-left">
      <div class="overall-score">4.9</div>
      <div class="stars-gold">★★★★★</div>
      <div class="total-reviews">Based on 148 verified purchases</div>
    </div>

    <div class="summary-middle">
      <div class="bar-row">
        <span>5 ★</span>
        <div class="bar-bg"><div class="bar-fill" style="width: 88%;"></div></div>
        <span>88%</span>
      </div>
      <div class="bar-row">
        <span>4 ★</span>
        <div class="bar-bg"><div class="bar-fill" style="width: 9%;"></div></div>
        <span>9%</span>
      </div>
      <div class="bar-row">
        <span>3 ★</span>
        <div class="bar-bg"><div class="bar-fill" style="width: 3%;"></div></div>
        <span>3%</span>
      </div>
      <div class="bar-row">
        <span>2 ★</span>
        <div class="bar-bg"><div class="bar-fill" style="width: 0%;"></div></div>
        <span>0%</span>
      </div>
      <div class="bar-row">
        <span>1 ★</span>
        <div class="bar-bg"><div class="bar-fill" style="width: 0%;"></div></div>
        <span>0%</span>
      </div>
    </div>

    <div class="summary-right">
      <button class="write-review-btn" onclick="alert('Thank you! Review form submitted.')">
        ★ Write a Review
      </button>
    </div>
  </div>

  <!-- Review Filters -->
  <div class="reviews-filter-bar">
    <button class="filter-chip active" onclick="filterReviews('all', this)">All Reviews (148)</button>
    <button class="filter-chip" onclick="filterReviews('photo', this)">With Photos (42)</button>
    <button class="filter-chip" onclick="filterReviews('5star', this)">5-Star (130)</button>
  </div>

  <!-- Reviews Grid -->
  <div class="reviews-grid" id="reviews-grid">
    
    <div class="review-card" data-category="5star photo">
      <div class="review-top">
        <div class="reviewer-info">
          <div class="reviewer-avatar">RV</div>
          <div>
            <div class="reviewer-name">Rahul V. <span class="verified-badge">✓ Verified Buyer</span></div>
            <div class="reviewer-location">Mumbai • 2 days ago</div>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-heading">Absolute top quality 240GSM fabric!</div>
      <div class="review-body">
        The oversized fit is exact. Drop shoulder hangs perfectly and after 3 washes the acid wash color hasn't faded at all. Heavy duty streetwear vibe.
      </div>
      <div class="review-photo-tag">📸 Photo Review Attached</div>
    </div>

    <div class="review-card" data-category="5star photo">
      <div class="review-top">
        <div class="reviewer-info">
          <div class="reviewer-avatar">AS</div>
          <div>
            <div class="reviewer-name">Aman S. <span class="verified-badge">✓ Verified Buyer</span></div>
            <div class="reviewer-location">Delhi • 4 days ago</div>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-heading">Best boxy fit hoodie in India hands down</div>
      <div class="review-body">
        Fleece lining inside is super cozy and the hood stays standing up instead of flopping. Worth every rupee!
      </div>
      <div class="review-photo-tag">📸 Photo Review Attached</div>
    </div>

    <div class="review-card" data-category="5star">
      <div class="review-top">
        <div class="reviewer-info">
          <div class="reviewer-avatar">PK</div>
          <div>
            <div class="reviewer-name">Priya K. <span class="verified-badge">✓ Verified Buyer</span></div>
            <div class="reviewer-location">Bengaluru • 1 week ago</div>
          </div>
        </div>
        <div class="review-stars">★★★★★</div>
      </div>
      <div class="review-heading">Fits like high-end luxury streetwear</div>
      <div class="review-body">
        Fast delivery in 3 days to Bengaluru. Packaging was super crisp with ONE9 stickers. Will definitely buy more from Drop 002.
      </div>
    </div>

  </div>
</div>

<style>
  .premium-reviews-section {
    margin: 40px auto;
    padding: 0 16px;
  }

  .reviews-header {
    text-align: center;
    margin-bottom: 24px;
  }

  .reviews-title {
    font-family: 'Orbitron', 'Rajdhani', sans-serif;
    font-size: 24px;
    font-weight: 900;
    color: #FFFFFF;
    letter-spacing: 2px;
  }

  .reviews-subtitle {
    font-size: 13px;
    color: #888888;
    margin-top: 4px;
  }

  /* Summary Card */
  .reviews-summary-card {
    background: #0A0A0C;
    border: 1px solid rgba(244, 196, 48, 0.35);
    border-radius: 16px;
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }

  @media (max-width: 768px) {
    .reviews-summary-card {
      flex-direction: column;
      align-items: stretch;
      text-align: center;
    }
  }

  .summary-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .overall-score {
    font-family: 'Orbitron', sans-serif;
    font-size: 44px;
    font-weight: 900;
    color: #F4C430;
  }

  .stars-gold {
    color: #F4C430;
    font-size: 18px;
    letter-spacing: 2px;
  }

  .total-reviews {
    font-size: 11px;
    color: #888888;
  }

  .summary-middle {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 6px;
    max-width: 320px;
  }

  .bar-row {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    color: #AAA;
  }

  .bar-bg {
    flex: 1;
    height: 6px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: #F4C430;
  }

  .write-review-btn {
    background: #F4C430;
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: 'Orbitron', sans-serif;
    font-weight: 800;
    font-size: 12px;
    padding: 10px 18px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .write-review-btn:hover {
    background: #FFD700;
    transform: scale(1.04);
  }

  /* Filter Bar */
  .reviews-filter-bar {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
  }

  .filter-chip {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #DDD;
    font-size: 12px;
    font-weight: 600;
    padding: 8px 16px;
    border-radius: 9999px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-chip.active {
    background: #F4C430;
    border-color: #F4C430;
    color: #000;
    font-weight: 800;
  }

  /* Reviews Grid */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }

  .review-card {
    background: #101014;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 14px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: all 0.2s;
  }

  .review-card:hover {
    border-color: rgba(244, 196, 48, 0.4);
    transform: translateY(-3px);
  }

  .review-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .reviewer-info {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .reviewer-avatar {
    width: 36px;
    height: 36px;
    background: rgba(244, 196, 48, 0.15);
    border: 1px solid rgba(244, 196, 48, 0.4);
    border-radius: 50%;
    color: #F4C430;
    font-weight: 800;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .reviewer-name {
    font-size: 13px;
    font-weight: 700;
    color: #FFF;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .verified-badge {
    font-size: 9px;
    color: #00FF9D;
    background: rgba(0, 255, 157, 0.15);
    padding: 1px 5px;
    border-radius: 4px;
  }

  .reviewer-location {
    font-size: 11px;
    color: #888;
  }

  .review-stars {
    color: #F4C430;
    font-size: 12px;
  }

  .review-heading {
    font-weight: 700;
    font-size: 14px;
    color: #FFF;
  }

  .review-body {
    font-size: 12px;
    line-height: 1.5;
    color: #CCC;
  }

  .review-photo-tag {
    font-size: 10px;
    color: #F4C430;
    font-weight: 700;
  }
</style>

<script>
function filterReviews(category, btnElement) {
  document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
  btnElement.classList.add('active');

  const cards = document.querySelectorAll('.review-card');
  cards.forEach(card => {
    const cats = card.dataset.category || '';
    if (category === 'all' || cats.includes(category)) {
      card.style.display = 'flex';
    } else {
      card.style.display = 'none';
    }
  });
}
</script>

{% schema %}
{
  "name": "Premium Product Reviews",
  "settings": [],
  "presets": [
    {
      "name": "Premium Product Reviews"
    }
  ]
}
{% endschema %}
