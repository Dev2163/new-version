{% comment %}
  ONE9 Luxury Streetwear - Contact & Support Section
{% endcomment %}

<div class="main-contact section-{{ section.id }}" style="background-color: #050505; color: #ffffff; padding: 60px 0;">
  <div class="page-width">
    <!-- Heading -->
    <div style="text-align: center; max-width: 700px; margin: 0 auto 48px auto;">
      <span style="font-family: 'Rajdhani', sans-serif; font-size: 14px; font-weight: 700; color: #f4c430; letter-spacing: 2px; text-transform: uppercase;">24/7 CONCIERGE & SUPPORT</span>
      <h1 style="font-family: 'Orbitron', sans-serif; font-size: clamp(28px, 4.5vw, 44px); font-weight: 900; text-transform: uppercase; margin: 10px 0 16px 0; color: #ffffff;">
        GET IN TOUCH
      </h1>
      <p style="font-family: 'Rajdhani', sans-serif; font-size: 16px; color: #a0a0a0;">
        Have questions about sizing, orders, or worldwide shipping? Our client support team is here to assist you.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 40px; margin-bottom: 60px;">
      <!-- Contact Channels Cards -->
      <div style="display: flex; flex-direction: column; gap: 20px;">
        <!-- Direct WhatsApp -->
        <div class="glass-panel" style="padding: 24px; border-radius: 10px; display: flex; align-items: center; gap: 16px;">
          <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(37, 211, 102, 0.15); color: #25D366; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
            </svg>
          </div>
          <div>
            <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">WHATSAPP VIP CHAT</div>
            <div style="font-family: 'Rajdhani', sans-serif; font-size: 13px; color: #a0a0a0; margin-top: 2px;">Instant responses for VIP inquiries</div>
            <a href="https://wa.me/447000000000" target="_blank" style="color: #25D366; font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 700; text-decoration: none; margin-top: 6px; display: inline-block;">Message on WhatsApp &rarr;</a>
          </div>
        </div>

        <!-- Email Concierge -->
        <div class="glass-panel" style="padding: 24px; border-radius: 10px; display: flex; align-items: center; gap: 16px;">
          <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(244, 196, 48, 0.15); color: #f4c430; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </div>
          <div>
            <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">CLIENT CARE EMAIL</div>
            <div style="font-family: 'Rajdhani', sans-serif; font-size: 13px; color: #a0a0a0; margin-top: 2px;">support@one9clothing.com</div>
            <a href="mailto:support@one9clothing.com" style="color: #f4c430; font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 700; text-decoration: none; margin-top: 6px; display: inline-block;">Send an Email &rarr;</a>
          </div>
        </div>
      </div>

      <!-- FAQ Accordion -->
      <div class="glass-panel" style="padding: 32px; border-radius: 12px;">
        <h3 style="font-family: 'Orbitron', sans-serif; font-size: 18px; font-weight: 800; color: #ffffff; text-transform: uppercase; margin-bottom: 20px;">
          FREQUENTLY ASKED QUESTIONS
        </h3>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          <details style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 12px;">
            <summary style="font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 700; color: #f4c430; cursor: pointer; outline: none;">
              WHAT IS THE SHIPPING TIME FOR ORDERS?
            </summary>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 14px; color: #b0b0b0; margin-top: 8px; line-height: 1.6;">
              Domestic express orders take 1-3 business days. International orders typically arrive within 3-7 business days via priority DHL/FedEx.
            </p>
          </details>

          <details style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 12px;">
            <summary style="font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 700; color: #f4c430; cursor: pointer; outline: none;">
              HOW DO I RETURN OR EXCHANGE AN ITEM?
            </summary>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 14px; color: #b0b0b0; margin-top: 8px; line-height: 1.6;">
              We offer a 30-day money-back return policy. Simply submit your order number in our online returns portal.
            </p>
          </details>

          <details style="border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 12px;">
            <summary style="font-family: 'Orbitron', sans-serif; font-size: 13px; font-weight: 700; color: #f4c430; cursor: pointer; outline: none;">
              ARE YOUR PRODUCTS 100% ORIGINAL?
            </summary>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 14px; color: #b0b0b0; margin-top: 8px; line-height: 1.6;">
              Yes, all ONE9 products are 100% original, designed in-house and manufactured with custom serial authentication tags.
            </p>
          </details>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact & Support",
  "presets": [
    {
      "name": "Contact & Support"
    }
  ]
}
{% endschema %}
