<div class="custom-product-wrapper">
  <!-- Left Brand Bar -->
  <div class="cp-sidebar">
    <div class="cp-vertical-brand">
      <div class="cp-text-group">
        ONE9
      </div>
      <div class="cp-zodiac-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="#F4C430" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
          <circle cx="12" cy="12" r="3"></circle>
        </svg>
      </div>
      <div class="cp-gold-line"></div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="cp-main-container page-width">
    
    <!-- Breadcrumbs -->
    <nav class="cp-breadcrumbs" aria-label="breadcrumbs">
      <a href="/">Home</a> &gt;
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a> &gt;
      {% endif %}
      <span>{{ product.title }}</span>
    </nav>

    <!-- Product Layout Grid -->
    <div class="cp-layout-grid">
      
      <!-- LEFT COL: Gallery & Details -->
      <div class="cp-left-col">
        <!-- Gallery -->
        <div class="cp-gallery">
          <div class="cp-thumbnails">
            {% for media in product.media %}
              <div class="cp-thumb {% if forloop.first %}is-active{% endif %}" data-media-id="{{ media.id }}" onclick="switchImage('{{ media | image_url: width: 1000 }}')">
                {{ media | image_url: width: 150, height: 150, crop: 'center' | image_tag: loading: 'lazy' }}
              </div>
            {% endfor %}
            <!-- Scroll Arrow Mock -->
            <div class="cp-thumb-scroll">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="#888" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </div>
          </div>
          <div class="cp-main-image">
            {{ product.featured_media | image_url: width: 1000 | image_tag: class: 'main-img-view', loading: 'eager', id: 'MainProductImage' }}
            <button class="cp-zoom-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            </button>
          </div>
        </div>

        <!-- Product Details text block -->
        <div class="cp-details-block">
          <h3>PRODUCT DETAILS</h3>
          <div class="cp-desc">
            {{ product.description }}
          </div>
        </div>
      </div>

      <!-- RIGHT COL: Info & Form -->
      <div class="cp-right-col">
        {%- form 'product', product, id: 'product-form-custom', class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="variant-id-input">

          <div class="cp-badge">NEW</div>
          <h1 class="cp-title">{{ product.title }}</h1>
          
          <div class="cp-reviews">
            <span class="stars">★★★★★</span>
            <span class="count">(128 reviews)</span>
          </div>

          <div class="cp-price-section">
            <span class="cp-price">{{ product.price | money }}</span>
            <p class="cp-tax-text">Tax included. <a href="#">Shipping</a> calculated at checkout.</p>
          </div>

          <!-- Variants -->
          {% unless product.has_only_default_variant %}
            <div class="cp-variants">
              {% for option in product.options_with_values %}
                <div class="cp-option-group">
                  <div class="cp-option-header">
                    <label class="cp-option-label">{{ option.name | upcase }}: <span class="cp-selected-val">{{ option.selected_value }}</span></label>
                    {% if option.name == 'Size' %}
                      <a href="#" class="cp-size-guide"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#F4C430" stroke-width="2"><path d="M2 12h20M4 12v4M8 12v3M12 12v4M16 12v3M20 12v4"/></svg> Size Guide</a>
                    {% endif %}
                  </div>
                  
                  <div class="cp-option-values {% if option.name == 'Color' or option.name == 'Colour' %}is-color{% else %}is-text{% endif %}">
                    {% for value in option.values %}
                      <div class="cp-val-btn {% if option.selected_value == value %}is-active{% endif %}" data-option-name="{{ option.name }}" data-value="{{ value | escape }}" onclick="selectVariant(this)">
                        {% if option.name == 'Color' or option.name == 'Colour' %}
                          <span class="swatch-circle" style="background-color: {{ value | handle }};" title="{{ value }}"></span>
                        {% else %}
                          {{ value }}
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <!-- Buttons -->
          <div class="cp-buy-buttons">
            <button type="submit" name="add" class="cp-btn cp-btn-add">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
              ADD TO CART
            </button>
            <button type="button" class="cp-btn cp-btn-buy">BUY IT NOW</button>
          </div>

          <!-- Feature Icons -->
          <div class="cp-features-row">
            <div class="cp-feat">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><path d="M12 2v20M17 5l-5 5-5-5M17 19l-5-5-5 5"/></svg>
              <span>TOUCH ON THE OUTSIDE.<br>WARM ON THE INSIDE.</span>
            </div>
            <div class="cp-feat">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              <span>BUILT DIFFERENT.<br>WORN EVERYWHERE.</span>
            </div>
            <div class="cp-feat">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><path d="M2 12l10-7 10 7-10 7-10-7z"/><path d="M2 17l10 7 10-7"/></svg>
              <span>DESIGNED FOR EVERYDAY.<br>MADE TO LAST.</span>
            </div>
          </div>

          <!-- Accordions -->
          <div class="cp-accordions">
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">MATERIAL & CARE <span class="icon">+</span></button>
              <div class="cp-acc-content"><p>Premium materials used. Engineered for warmth. Designed for movement.</p></div>
            </div>
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">SHIPPING & RETURNS <span class="icon">+</span></button>
              <div class="cp-acc-content"><p>Free shipping on orders over £100. 30-day return policy applies.</p></div>
            </div>
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">SIZE GUIDE <span class="icon">+</span></button>
              <div class="cp-acc-content"><p>Fits true to size. Relaxed/oversized fit.</p></div>
            </div>
          </div>
          
        {%- endform -%}
      </div>
    </div>
    
    <!-- Bottom Trust Strip -->
    <div class="cp-trust-strip">
      <div class="trust-item">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><path d="M1 3h15v13H1zM16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        <div class="trust-text"><strong>FREE SHIPPING</strong><br>On orders over £100</div>
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <div class="trust-text"><strong>EASY RETURNS</strong><br>30-day return policy</div>
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
        <div class="trust-text"><strong>SECURE CHECKOUT</strong><br>100% secure payments</div>
      </div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="#F4C430" stroke-width="1.5"><rect x="2" y="5" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
        <div class="trust-text"><strong>COD / UPI / CARDS</strong><br>Multiple payment options</div>
      </div>
    </div>

  </div>
</div>

<script>
  function switchImage(url) {
    document.getElementById('MainProductImage').src = url;
    document.querySelectorAll('.cp-thumb').forEach(t => t.classList.remove('is-active'));
    event.currentTarget.classList.add('is-active');
  }

  function selectVariant(btn) {
    const parent = btn.closest('.cp-option-values');
    parent.querySelectorAll('.cp-val-btn').forEach(b => b.classList.remove('is-active'));
    btn.classList.add('is-active');
    const group = btn.closest('.cp-option-group');
    group.querySelector('.cp-selected-val').textContent = btn.getAttribute('data-value');
  }

  function toggleAcc(btn) {
    const item = btn.closest('.cp-acc-item');
    const content = item.querySelector('.cp-acc-content');
    const icon = btn.querySelector('.icon');
    if (content.style.maxHeight) {
      content.style.maxHeight = null;
      icon.textContent = '+';
    } else {
      content.style.maxHeight = content.scrollHeight + "px";
      icon.textContent = '-';
    }
  }
</script>

{% stylesheet %}
  .custom-product-wrapper {
    background-color: #050505;
    color: #E0E0E0;
    min-height: 100vh;
    font-family: var(--font-body-family, sans-serif);
    position: relative;
    padding-bottom: 60px;
  }

  /* Left Brand Sidebar */
  .cp-sidebar {
    position: absolute;
    top: 0;
    left: 0;
    bottom: 0;
    width: 80px;
    border-right: 1px solid #1A1A1A;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 40px;
    z-index: 10;
  }
  .cp-vertical-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }
  .cp-text-group {
    transform: rotate(90deg);
    font-family: "Orbitron", "Rajdhani", sans-serif;
    font-size: 28px;
    font-weight: 900;
    color: #F4C430;
    text-shadow: 0 0 10px rgba(244, 196, 48, 0.4);
    white-space: nowrap;
    margin-top: 30px;
    margin-bottom: 40px;
    letter-spacing: 4px;
  }
  .cp-zodiac-icon {
    margin-bottom: 24px;
    animation: eyePulse 3s infinite ease-in-out;
  }
  .cp-zodiac-icon svg {
    width: 28px;
    height: 28px;
  }
  @keyframes eyePulse {
    0%, 100% { filter: drop-shadow(0 0 2px #F4C430); }
    50% { filter: drop-shadow(0 0 10px #F4C430); }
  }
  .cp-gold-line {
    width: 2px;
    background: linear-gradient(to bottom, #F4C430, transparent);
    flex-grow: 1;
    margin-bottom: 40px;
  }

  /* Main Container */
  .cp-main-container {
    padding-left: 120px;
    padding-right: 40px;
    padding-top: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Breadcrumbs */
  .cp-breadcrumbs {
    font-size: 13px;
    color: #888;
    margin-bottom: 30px;
    display: flex;
    gap: 8px;
  }
  .cp-breadcrumbs a {
    color: #888;
    text-decoration: none;
    transition: color 0.3s;
  }
  .cp-breadcrumbs a:hover {
    color: #FFF;
  }
  .cp-breadcrumbs span {
    color: #FFF;
  }

  /* Layout Grid */
  .cp-layout-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 450px;
    gap: 60px;
    align-items: start;
  }
  .cp-left-col {
    min-width: 0;
  }

  /* LEFT COL */
  .cp-gallery {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
  }
  .cp-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 90px;
    flex-shrink: 0;
  }
  .cp-thumb {
    border: 2px solid #222;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    background: #111;
    transition: border-color 0.3s;
    height: 90px;
  }
  .cp-thumb.is-active, .cp-thumb:hover {
    border-color: #F4C430;
  }
  .cp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.8;
  }
  .cp-thumb.is-active img {
    opacity: 1;
  }
  .cp-thumb-scroll {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 40px;
    cursor: pointer;
    background: #111;
    border-radius: 8px;
    border: 1px solid #222;
  }
  .cp-thumb-scroll:hover {
    border-color: #F4C430;
  }
  .cp-main-image {
    flex-grow: 1;
    border: 1px solid #222;
    border-radius: 12px;
    background: #0A0A0A;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    max-height: 700px;
  }
  .cp-main-image img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }
  .cp-zoom-btn {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: rgba(0,0,0,0.6);
    border: 1px solid #333;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFF;
    cursor: pointer;
    transition: background 0.3s;
  }
  .cp-zoom-btn:hover {
    background: rgba(0,0,0,0.9);
    border-color: #F4C430;
    color: #F4C430;
  }

  .cp-details-block {
    margin-top: 40px;
    max-width: 100%;
    overflow: hidden;
  }
  .cp-details-block h3 {
    font-size: 16px;
    font-weight: 800;
    margin-bottom: 16px;
    color: #FFF;
    letter-spacing: 1px;
  }
  .cp-desc {
    color: #B0B0B0;
    font-size: 15px;
    line-height: 1.6;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .cp-desc ul {
    margin-top: 16px;
    padding-left: 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
  }
  .cp-desc li {
    margin-bottom: 8px;
  }

  /* RIGHT COL */
  .cp-badge {
    display: inline-block;
    background-color: #F4C430;
    color: #000;
    font-size: 11px;
    font-weight: 800;
    padding: 4px 8px;
    border-radius: 4px;
    margin-bottom: 16px;
  }
  .cp-title {
    font-size: 32px;
    font-weight: 900;
    color: #FFF;
    margin: 0 0 12px 0;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .cp-reviews {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 24px;
    font-size: 14px;
  }
  .cp-reviews .stars {
    color: #F4C430;
    font-size: 16px;
  }
  .cp-reviews .count {
    color: #888;
  }
  .cp-price-section {
    margin-bottom: 30px;
    border-bottom: 1px solid #1A1A1A;
    padding-bottom: 24px;
  }
  .cp-price {
    font-size: 28px;
    font-weight: 700;
    color: #FFF;
    display: block;
    margin-bottom: 8px;
  }
  .cp-tax-text {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .cp-tax-text a {
    color: #F4C430;
    text-decoration: underline;
  }

  /* Variants */
  .cp-variants {
    margin-bottom: 30px;
  }
  .cp-option-group {
    margin-bottom: 24px;
  }
  .cp-option-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .cp-option-label {
    font-size: 13px;
    font-weight: 700;
    color: #FFF;
    text-transform: uppercase;
  }
  .cp-selected-val {
    color: #B0B0B0;
    font-weight: 400;
  }
  .cp-size-guide {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #F4C430;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #F4C430;
    padding-bottom: 2px;
  }
  .cp-option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cp-val-btn {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .cp-option-values.is-color .cp-val-btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid transparent;
    padding: 2px;
  }
  .cp-option-values.is-color .cp-val-btn.is-active {
    border-color: #F4C430;
  }
  .swatch-circle {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #333;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .cp-option-values.is-text .cp-val-btn {
    border: 1px solid #333;
    background: #111;
    color: #B0B0B0;
    padding: 10px 20px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    min-width: 48px;
  }
  .cp-option-values.is-text .cp-val-btn:hover {
    border-color: #666;
    color: #FFF;
  }
  .cp-option-values.is-text .cp-val-btn.is-active {
    border-color: #F4C430;
    color: #FFF;
    background: rgba(244, 196, 48, 0.1);
  }

  /* Buttons */
  .cp-buy-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 30px;
  }
  .cp-btn {
    width: 100%;
    padding: 16px;
    font-size: 15px;
    font-weight: 800;
    text-transform: uppercase;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s ease;
  }
  .cp-btn-add {
    background-color: #F4C430;
    color: #000;
    border: none;
    box-shadow: 0 4px 15px rgba(244, 196, 48, 0.2);
  }
  .cp-btn-add:hover {
    background-color: #FFF;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(255,255,255, 0.3);
  }
  .cp-btn-buy {
    background-color: transparent;
    color: #F4C430;
    border: 1px solid #F4C430;
  }
  .cp-btn-buy:hover {
    background-color: rgba(244, 196, 48, 0.1);
  }

  /* Feature Icons */
  .cp-features-row {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 30px;
    border-bottom: 1px solid #1A1A1A;
  }
  .cp-feat {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    flex: 1;
  }
  .cp-feat svg {
    flex-shrink: 0;
  }
  .cp-feat span {
    font-size: 10px;
    font-weight: 700;
    color: #B0B0B0;
    line-height: 1.4;
  }

  /* Accordions */
  .cp-accordions {
    border-top: 1px solid #1A1A1A;
  }
  .cp-acc-item {
    border-bottom: 1px solid #1A1A1A;
  }
  .cp-acc-btn {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: none;
    border: none;
    color: #FFF;
    font-size: 14px;
    font-weight: 700;
    padding: 20px 0;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .cp-acc-btn .icon {
    font-size: 18px;
    color: #F4C430;
    transition: transform 0.3s;
  }
  .cp-acc-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
  }
  .cp-acc-content p {
    margin: 0 0 20px 0;
    color: #B0B0B0;
    font-size: 14px;
    line-height: 1.6;
  }

  /* Bottom Trust Strip */
  .cp-trust-strip {
    margin-top: 60px;
    border-top: 1px solid #1A1A1A;
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    position: relative;
    padding: 0 20px;
  }
  .trust-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 40px;
    width: 1px;
    background-color: #333;
  }
  .trust-text {
    font-size: 12px;
    color: #888;
    line-height: 1.4;
  }
  .trust-text strong {
    color: #FFF;
    font-size: 13px;
    text-transform: uppercase;
  }

  /* Responsive */
  @media screen and (max-width: 1024px) {
    .cp-layout-grid {
      grid-template-columns: 1fr;
    }
    .cp-gallery {
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    .cp-trust-strip {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }
  @media screen and (max-width: 768px) {
    .cp-sidebar {
      display: none;
    }
    .cp-main-container {
      padding-left: 20px;
      padding-right: 20px;
    }
    .cp-gallery {
      flex-direction: column-reverse;
    }
    .cp-thumbnails {
      flex-direction: row;
      width: 100%;
      overflow-x: auto;
    }
    .cp-features-row {
      flex-direction: column;
      gap: 24px;
    }
    .cp-trust-strip {
