<div class="custom-product-wrapper">
  <!-- Left Brand Bar -->
  <div class="cp-sidebar">
    <div class="cp-vertical-brand">
      <div class="letter-container" style="display: flex; flex-direction: column; align-items: center;">
        <span class="letter">O</span>
        <span class="letter">N</span>
        <span class="letter">E</span>
        <span class="letter">9</span>
      </div>
      <div class="cp-zodiac-icon">
        <svg width="28" height="28" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="22" cy="7" r="1.5" fill="#F4C430" />
          <circle cx="15" cy="8.5" r="1.5" fill="#F4C430" />
          <circle cx="29" cy="8.5" r="1.5" fill="#F4C430" />
          <circle cx="9" cy="13" r="1.5" fill="#F4C430" />
          <circle cx="35" cy="13" r="1.5" fill="#F4C430" />
          <g class="eye-blink-anim">
            <path d="M6 22 Q22 6 38 22 Q22 38 6 22 Z" stroke="#F4C430" stroke-width="2.5" fill="none" />
            <circle cx="22" cy="22" r="4.5" stroke="#F4C430" stroke-width="2.5" fill="none" />
            <circle cx="22" cy="22" r="2" fill="#F4C430" />
          </g>
          <circle cx="22" cy="37" r="1.5" fill="#F4C430" />
          <circle cx="15" cy="35.5" r="1.5" fill="#F4C430" />
          <circle cx="29" cy="35.5" r="1.5" fill="#F4C430" />
          <circle cx="9" cy="31" r="1.5" fill="#F4C430" />
          <circle cx="35" cy="31" r="1.5" fill="#F4C430" />
        </svg>
      </div>
      <div class="cp-gold-line"></div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="cp-main-container page-width">
    
    <!-- Breadcrumbs -->
    <nav class="cp-breadcrumbs" aria-label="breadcrumbs">
      <a href="/">Home</a> &gt;
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a> &gt;
      {% endif %}
      <span>{{ product.title }}</span>
    </nav>

    <!-- Product Layout Grid -->
    <div class="cp-layout-grid">
      
      <!-- LEFT COL: Gallery & Details -->
      <div class="cp-left-col">
        <!-- Gallery -->
        <div class="cp-gallery">
          <div class="cp-thumbnails">
            {% for media in product.media limit: 5 %}
              <div class="cp-thumb {% if forloop.first %}is-active{% endif %}" data-media-id="{{ media.id }}" onclick="switchImage('{{ media | image_url: width: 1000 }}', this)">
                {{ media | image_url: width: 150, height: 150, crop: 'center' | image_tag: loading: 'lazy' }}
                {% if forloop.index == 5 and product.media.size > 5 %}
                  <div class="cp-thumb-more">
                    +{{ product.media.size | minus: 4 }}
                  </div>
                {% endif %}
              </div>
            {% endfor %}
          </div>
          <div class="cp-main-image" style="background-color: #FFFFFF;" onmousemove="zoomImage(event)" onmouseenter="showZoom()" onmouseleave="hideZoom()">
            {{ product.featured_media | image_url: width: 1000 | image_tag: class: 'main-img-view', loading: 'eager', id: 'MainProductImage' }}
            <div class="cp-zoom-lens" id="ZoomLens"></div>
          </div>
        </div>
      </div>

      <!-- RIGHT COL: Info & Form -->
      <div class="cp-right-col" style="position: relative;">
        <!-- Zoom Result -->
        <div class="cp-zoom-result" id="ZoomResult"></div>
        {%- form 'product', product, id: 'product-form-custom', class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" id="variant-id-input">

          <h1 class="cp-title">{{ product.title }}</h1>
          
          <div class="cp-price-section">
            <span class="cp-price">{{ product.price | money }}</span>
          </div>

          <!-- Related Colors from Metafield -->
          {%- assign related_colors = product.metafields.custom.related_colors.value -%}
          {%- if related_colors != blank -%}
            <div class="cp-option-group" style="margin-top: 25px;">
              <div class="cp-option-header">
                <label class="cp-option-label" style="font-size: 11px; letter-spacing: 1px; color: #888; text-transform: uppercase; font-weight: 700;">Color Options</label>
              </div>
              <div class="cp-option-values is-color" style="gap: 12px; margin-top: 8px;">
                
                <!-- Current product swatch ALWAYS shown exactly once -->
                {%- assign unique_color_ids = product.id | append: "" -%}
                <a href="{{ product.url }}" class="cp-val-btn is-active" style="padding: 2px; border-radius: 8px; border: 2px solid #F4C430; overflow: hidden; display: inline-flex; width: 64px; height: 64px; background: #fff;">
                  <img src="{{ product.featured_media | image_url: width: 120 }}" alt="{{ product.title }}" style="width: 100%; height: 100%; object-fit: contain; border-radius: 4px;">
                </a>
                
                <!-- Related products swatches (Filtered for duplicates) -->
                {%- for related_item in related_colors -%}
                  {%- assign item_id_str = related_item.id | append: "" -%}
                  {%- unless unique_color_ids contains item_id_str -%}
                    <a href="{{ related_item.url }}" class="cp-val-btn" style="padding: 2px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); overflow: hidden; display: inline-flex; width: 64px; height: 64px; transition: all 0.3s ease; background: #fff;" title="{{ related_item.title }}" onmouseover="this.style.borderColor='#ffffff'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'">
                      {%- assign swatch_img = related_item.featured_media | default: related_item.image -%}
                      {%- if swatch_img -%}
                        <img src="{{ swatch_img | image_url: width: 120 }}" alt="{{ related_item.title }}" style="width: 100%; height: 100%; object-fit: contain; border-radius: 4px;">
                      {%- endif -%}
                    </a>
                    {%- assign unique_color_ids = unique_color_ids | append: "," | append: item_id_str -%}
                  {%- endunless -%}
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          <!-- Variants -->
          {% unless product.has_only_default_variant %}
            <div class="cp-variants">
              {% for option in product.options_with_values %}
                <div class="cp-option-group">
                  <div class="cp-option-header">
                    <label class="cp-option-label">{{ option.name }}</label>
                  </div>
                  
                  <div class="cp-option-values {% if option.name == 'Color' or option.name == 'Colour' or option.name == 'Colors' %}is-color{% else %}is-text{% endif %}">
                    {% for value in option.values %}
                      <div class="cp-val-btn {% if option.selected_value == value %}is-active{% endif %}" data-option-name="{{ option.name }}" data-value="{{ value | escape }}" onclick="selectVariant(this)">
                        {% if option.name == 'Color' or option.name == 'Colour' or option.name == 'Colors' %}
                          {%- assign variant_image = nil -%}
                          {%- for variant in product.variants -%}
                            {%- if variant.options contains value and variant.featured_media -%}
                              {%- assign variant_image = variant.featured_media -%}
                              {%- break -%}
                            {%- endif -%}
                          {%- endfor -%}
                          
                          {% if variant_image %}
                            <img src="{{ variant_image | image_url: width: 100 }}" alt="{{ value }}" class="variant-img-swatch">
                          {% else %}
                            <span class="swatch-circle" style="background-color: {{ value | split: ' ' | last | handle }};" title="{{ value }}"></span>
                          {% endif %}
                        {% else %}
                          {{ value }}
                        {% endif %}
                      </div>
                    {% endfor %}
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <!-- Stock Urgency Indicator -->
          {%- if product.available -%}
            <div class="cp-stock-urgency" style="display: flex; align-items: center; gap: 8px; margin: 16px 0; color: #f4c430; font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 700; text-transform: uppercase;">
              <span class="stock-pulse" style="width: 8px; height: 8px; border-radius: 50%; background: #f4c430; display: inline-block; animation: pulseGlow 1.5s infinite;"></span>
              <span>In Stock • Ships Within 24 Hours</span>
            </div>
          {%- endif -%}

          <!-- Buttons & Sticky Bar Target -->
          <div class="cp-buy-buttons-new" id="main-buy-buttons">
            {% if product.available %}
              <button type="submit" name="add" class="cp-btn cp-btn-add" style="background: #f4c430; color: #000; font-family: 'Orbitron', sans-serif; font-weight: 800; font-size: 14px; letter-spacing: 1px; width: 100%; padding: 16px; border: none; border-radius: 6px; cursor: pointer; transition: all 0.3s ease;">
                ADD TO CART
              </button>
            {% else %}
              <button type="button" class="cp-btn cp-btn-soldout" disabled style="background: #222; color: #777; font-family: 'Orbitron', sans-serif; font-weight: 700; width: 100%; padding: 16px; border: none; border-radius: 6px; cursor: not-allowed;">
                SOLD OUT
              </button>
            {% endif %}

            <!-- Dynamic Delivery Countdown -->
            <div class="cp-delivery-estimate" style="margin-top: 14px; display: flex; align-items: center; gap: 10px; font-family: 'Rajdhani', sans-serif; font-size: 13px; color: #b0b0b0;">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#f4c430" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <span>Order within <strong style="color: #f4c430;" id="pdp-countdown">04h 28m</strong> for Express Delivery</span>
            </div>

            <!-- PDP Trust Badges -->
            <div class="pdp-trust-grid" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-top: 20px; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.08);">
              <div style="display: flex; align-items: center; gap: 8px; color: #ccc; font-size: 12px; font-family: 'Rajdhani', sans-serif;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f4c430" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>100% Authentic</span>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; color: #ccc; font-size: 12px; font-family: 'Rajdhani', sans-serif;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f4c430" stroke-width="2"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                <span>Global Express</span>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; color: #ccc; font-size: 12px; font-family: 'Rajdhani', sans-serif;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f4c430" stroke-width="2"><polyline points="23 4 23 10 17 10"></polyline><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path></svg>
                <span>30-Day Returns</span>
              </div>
              <div style="display: flex; align-items: center; gap: 8px; color: #ccc; font-size: 12px; font-family: 'Rajdhani', sans-serif;">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f4c430" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                <span>Secure Checkout</span>
              </div>
            </div>
          </div>

          <!-- Accordions -->
          <div class="cp-accordions">
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">
                <span class="acc-title"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg> PRODUCT DETAILS</span>
                <span class="icon">+</span>
              </button>
              <div class="cp-acc-content">
                <div class="cp-desc">
                  {{ product.description }}
                </div>
              </div>
            </div>
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">
                <span class="acc-title"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path></svg> CARE & MAINTENANCE</span>
                <span class="icon">+</span>
              </button>
              <div class="cp-acc-content"><p>Wipe with a clean, dry cloth when needed.</p></div>
            </div>
            <div class="cp-acc-item">
              <button type="button" class="cp-acc-btn" onclick="toggleAcc(this)">
                <span class="acc-title"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg> SIZE & FIT</span>
                <span class="icon">+</span>
              </button>
              <div class="cp-acc-content"><p>Fits true to size.</p></div>
            </div>
          </div>
          
        {%- endform -%}

        <!-- Sticky ATC Bar for PDP Mobile & Desktop -->
        <div id="one9-sticky-atc-bar" class="sticky-atc-bar">
          <div style="display: flex; align-items: center; gap: 12px;">
            <img src="{{ product.featured_media | image_url: width: 100 }}" alt="{{ product.title }}" style="width: 44px; height: 44px; object-fit: contain; border-radius: 4px; background: #fff;">
            <div>
              <div style="font-family: 'Orbitron', sans-serif; font-size: 12px; font-weight: 700; color: #fff;">{{ product.title | truncate: 25 }}</div>
              <div style="font-family: 'Rajdhani', sans-serif; font-size: 13px; font-weight: 700; color: #f4c430;">{{ product.price | money }}</div>
            </div>
          </div>
          <button type="button" onclick="document.querySelector('#main-buy-buttons button[name=add]')?.click()" style="background: #f4c430; color: #000; font-family: 'Orbitron', sans-serif; font-weight: 800; font-size: 12px; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer; text-transform: uppercase;">
            ADD TO CART
          </button>
        </div>

        <script>
          (function() {
            const mainButtons = document.getElementById('main-buy-buttons');
            const stickyBar = document.getElementById('one9-sticky-atc-bar');
            if (mainButtons && stickyBar) {
              const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                  if (!entry.isIntersecting) {
                    stickyBar.classList.add('visible');
                  } else {
                    stickyBar.classList.remove('visible');
                  }
                });
              }, { threshold: 0.1 });
              observer.observe(mainButtons);
            }
          })();
        </script>
      </div>
    </div>
  </div>
</div>

<script>
  function switchImage(url, element) {
    const mainImg = document.getElementById('MainProductImage');
    mainImg.src = url;
    mainImg.removeAttribute('srcset');
    document.querySelectorAll('.cp-thumb').forEach(t => t.classList.remove('is-active'));
    if (element) {
      element.classList.add('is-active');
    }
  }

  const productVariantsData = {{ product.variants | json }};

  function selectVariant(btn) {
    const parent = btn.closest('.cp-option-values');
    if (parent) {
      parent.querySelectorAll('.cp-val-btn').forEach(b => b.classList.remove('is-active'));
      btn.classList.add('is-active');
    }
    const group = btn.closest('.cp-option-group');
    const selectedValEl = group?.querySelector('.cp-selected-val');
    if (selectedValEl) {
      selectedValEl.textContent = btn.getAttribute('data-value');
    }

    // Collect all selected values across option groups
    const selectedOptions = [];
    document.querySelectorAll('.cp-option-group').forEach(g => {
      const activeBtn = g.querySelector('.cp-val-btn.is-active');
      if (activeBtn) {
        selectedOptions.push(activeBtn.getAttribute('data-value'));
      }
    });

    const clickedValue = btn.getAttribute('data-value');
    let matchedVariant = productVariantsData.find(v => {
      return Array.isArray(v.options) && v.options.every((optVal, idx) => selectedOptions[idx] === optVal);
    });

    if (!matchedVariant) {
      matchedVariant = productVariantsData.find(v => Array.isArray(v.options) && v.options.includes(clickedValue));
    }

    if (matchedVariant) {
      const variantInput = document.getElementById('variant-id-input');
      if (variantInput) {
        variantInput.value = matchedVariant.id;
      }

      const priceEl = document.querySelector('.cp-price');
      if (priceEl && matchedVariant.price) {
        const amount = (matchedVariant.price / 100).toFixed(2);
        priceEl.textContent = '£' + amount;
      }

      const buyButtonsContainer = document.getElementById('main-buy-buttons');
      const stockUrgency = document.querySelector('.cp-stock-urgency');

      if (buyButtonsContainer) {
        if (matchedVariant.available) {
          buyButtonsContainer.innerHTML = `
            <button type="submit" name="add" class="cp-btn cp-btn-add" style="background: #f4c430; color: #000; font-family: 'Orbitron', sans-serif; font-weight: 800; font-size: 14px; letter-spacing: 1px; width: 100%; padding: 16px; border: none; border-radius: 6px; cursor: pointer; transition: all 0.3s ease;">
              ADD TO CART
            </button>
          `;
          if (stockUrgency) {
            stockUrgency.style.display = 'flex';
            stockUrgency.innerHTML = `<span class="stock-pulse" style="width: 8px; height: 8px; border-radius: 50%; background: #f4c430; display: inline-block; animation: pulseGlow 1.5s infinite;"></span><span>In Stock • Ships Within 24 Hours</span>`;
          }
        } else {
          buyButtonsContainer.innerHTML = `
            <button type="button" class="cp-btn cp-btn-soldout" disabled style="background: #222; color: #777; font-family: 'Orbitron', sans-serif; font-weight: 700; width: 100%; padding: 16px; border: none; border-radius: 6px; cursor: not-allowed;">
              SOLD OUT
            </button>
          `;
          if (stockUrgency) {
            stockUrgency.style.display = 'flex';
            stockUrgency.innerHTML = `<span style="width: 8px; height: 8px; border-radius: 50%; background: #ff4d4d; display: inline-block;"></span><span style="color: #ff4d4d;">Out of Stock</span>`;
          }
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const firstAvailable = productVariantsData.find(v => v.available);
    if (firstAvailable && !{{ product.selected_or_first_available_variant.available | json }}) {
      const variantInput = document.getElementById('variant-id-input');
      if (variantInput) variantInput.value = firstAvailable.id;

      if (Array.isArray(firstAvailable.options)) {
        firstAvailable.options.forEach(optVal => {
          const btn = document.querySelector(`.cp-val-btn[data-value="${optVal.replace(/"/g, '\\"')}"]`);
          if (btn) btn.click();
        });
      }
    }
  });

  function toggleAcc(btn) {
    const item = btn.closest('.cp-acc-item');
    const content = item.querySelector('.cp-acc-content');
    const icon = btn.querySelector('.icon');
    if (content.style.maxHeight) {
      content.style.maxHeight = null;
      icon.textContent = '+';
    } else {
      content.style.maxHeight = content.scrollHeight + "px";
      icon.textContent = '-';
    }
  }

  function zoomImage(e) {
    const mainImg = document.getElementById('MainProductImage');
    const lens = document.getElementById('ZoomLens');
    const result = document.getElementById('ZoomResult');

    const rect = mainImg.getBoundingClientRect();
    let x = e.clientX - rect.left;
    let y = e.clientY - rect.top;

    let lensX = x - (lens.offsetWidth / 2);
    let lensY = y - (lens.offsetHeight / 2);

    if (lensX > rect.width - lens.offsetWidth) { lensX = rect.width - lens.offsetWidth; }
    if (lensX < 0) { lensX = 0; }
    if (lensY > rect.height - lens.offsetHeight) { lensY = rect.height - lens.offsetHeight; }
    if (lensY < 0) { lensY = 0; }

    lens.style.left = lensX + "px";
    lens.style.top = lensY + "px";

    const ratioX = result.offsetWidth / lens.offsetWidth;
    const ratioY = result.offsetHeight / lens.offsetHeight;

    result.style.backgroundImage = "url('" + mainImg.src + "')";
    result.style.backgroundSize = (rect.width * ratioX) + "px " + (rect.height * ratioY) + "px";
    result.style.backgroundPosition = "-" + (lensX * ratioX) + "px -" + (lensY * ratioY) + "px";
  }

  function showZoom() {
    document.getElementById('ZoomLens').style.display = "block";
    document.getElementById('ZoomResult').style.display = "block";
  }

  function hideZoom() {
    document.getElementById('ZoomLens').style.display = "none";
    document.getElementById('ZoomResult').style.display = "none";
  }

  // Swipe to change image on mobile
  let touchstartX = 0;
  let touchendX = 0;

  function handleGesture() {
    const thumbs = document.querySelector('.cp-thumbnails');
    if (touchendX < touchstartX - 50) {
      const activeThumb = document.querySelector('.cp-thumb.is-active');
      if (activeThumb && activeThumb.nextElementSibling) {
        activeThumb.nextElementSibling.click();
        const thumb = activeThumb.nextElementSibling;
        if(thumbs) thumbs.scrollTo({ left: thumb.offsetLeft - thumbs.offsetWidth / 2 + thumb.offsetWidth / 2, behavior: 'smooth' });
      }
    }
    if (touchendX > touchstartX + 50) {
      const activeThumb = document.querySelector('.cp-thumb.is-active');
      if (activeThumb && activeThumb.previousElementSibling) {
        activeThumb.previousElementSibling.click();
        const thumb = activeThumb.previousElementSibling;
        if(thumbs) thumbs.scrollTo({ left: thumb.offsetLeft - thumbs.offsetWidth / 2 + thumb.offsetWidth / 2, behavior: 'smooth' });
      }
    }
  }

  const mainImageContainer = document.querySelector('.cp-main-image');
  if (mainImageContainer) {
    mainImageContainer.addEventListener('touchstart', e => {
      touchstartX = e.changedTouches[0].screenX;
    }, {passive: true});

    mainImageContainer.addEventListener('touchend', e => {
      touchendX = e.changedTouches[0].screenX;
      handleGesture();
    }, {passive: true});
  }
</script>

{% stylesheet %}

  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@800;900&family=Rajdhani:wght@600;700&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap');

  .custom-product-wrapper {
    background-color: #050505;
    color: #E0E0E0;
    min-height: 100vh;
    font-family: var(--font-body-family, sans-serif);
    position: relative;
    padding-bottom: 60px;
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }

  /* Left Brand Sidebar */
  .cp-sidebar {
    width: 80px;
    flex-shrink: 0;
    padding-top: 40px;
    border-right: 1px solid rgba(255,255,255,0.05);
    position: sticky;
    top: 0;
    height: 100vh;
  }
  .cp-vertical-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
  }
  .cp-vertical-brand .letter {
    font-family: "Orbitron", "Rajdhani", sans-serif;
    font-size: 42px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: 1px;
    color: #F4C430;
    text-shadow: 0 0 12px rgba(244, 196, 48, 0.6);
    display: block;
    text-transform: uppercase;
  }
  .cp-zodiac-icon {
    width: 28px;
    height: 28px;
    margin-top: 24px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cp-zodiac-icon svg {
    width: 28px;
    height: 28px;
  }
  .eye-blink-anim {
    transform-origin: 22px 22px;
    animation: eyeBlink 4s infinite;
  }
  @keyframes eyeBlink {
    0%, 93%, 100% { transform: scaleY(1); }
    96.5% { transform: scaleY(0.1); }
  }
  .cp-gold-line {
    width: 2px;
    height: 200px;
    background: linear-gradient(to bottom, #F4C430, transparent);
    margin-bottom: 40px;
  }

  /* Main Container */
  .cp-main-container {
    flex: 1;
    padding-left: 40px;
    padding-right: 40px;
    padding-top: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Breadcrumbs */
  .cp-breadcrumbs {
    font-size: 13px;
    color: #888;
    margin-bottom: 30px;
    display: flex;
    gap: 8px;
  }
  .cp-breadcrumbs a {
    color: #888;
    text-decoration: none;
    transition: color 0.3s;
  }
  .cp-breadcrumbs a:hover {
    color: #FFF;
  }
  .cp-breadcrumbs span {
    color: #FFF;
  }

  /* Layout Grid */
  .cp-layout-grid {
    display: flex;
    justify-content: center;
    gap: 80px;
    align-items: flex-start;
    max-width: 1200px;
    margin: 0 auto;
  }
  .cp-left-col {
    flex: 1;
    max-width: 610px;
    position: sticky;
    top: 40px;
    align-self: flex-start;
  }
  .cp-right-col {
    width: 450px;
    flex-shrink: 0;
  }

  /* LEFT COL */
  .cp-gallery {
    display: flex;
    gap: 20px;
    margin-bottom: 40px;
    width: 100%;
  }
  .cp-thumbnails {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 90px;
    flex-shrink: 0;
  }
  .cp-thumb {
    border: 2px solid #222;
    border-radius: 8px;
    overflow: hidden;
    cursor: pointer;
    background: #FFFFFF;
    transition: border-color 0.3s;
    height: 90px;
    position: relative;
  }
  .cp-thumb.is-active, .cp-thumb:hover {
    border-color: #F4C430;
  }
  .cp-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.8;
  }
  .cp-thumb.is-active img {
    opacity: 1;
  }
  .cp-thumb-more {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    color: #FFF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    font-weight: 800;
    font-family: "Orbitron", "Rajdhani", sans-serif;
  }
  .cp-main-image {
    flex-grow: 1;
    border: 1px solid #222;
    border-radius: 12px;
    background: #FFFFFF;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    max-height: 500px;
    max-width: 500px;
  }
  .cp-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cp-zoom-btn {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: rgba(0,0,0,0.6);
    border: 1px solid #333;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFF;
    cursor: pointer;
    transition: background 0.3s;
  }
  .cp-zoom-btn:hover {
    background: rgba(0,0,0,0.9);
    border-color: #F4C430;
    color: #F4C430;
  }
  .cp-zoom-lens {
    position: absolute;
    border: 1px solid #F4C430;
    width: 150px;
    height: 150px;
    background: rgba(244, 196, 48, 0.2);
    display: none;
    pointer-events: none;
  }
  .cp-zoom-result {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 500px;
    z-index: 10;
    background-color: #0A0A0A;
    background-repeat: no-repeat;
    display: none;
    border: 1px solid #222;
    border-radius: 12px;
  }

  .cp-details-block {
    margin-top: 40px;
    max-width: 100%;
    overflow: hidden;
  }
  .cp-details-block h3 {
    font-size: 16px;
    font-weight: 800;
    margin-bottom: 16px;
    color: #FFF;
    letter-spacing: 1px;
  }
  .cp-desc {
    color: #B0B0B0;
    font-size: 15px;
    line-height: 1.6;
  }


  /* RIGHT COL */
  .cp-title {
    font-family: "Orbitron", "Rajdhani", sans-serif;
    text-transform: uppercase;
    font-size: 38px;
    font-weight: 800;
    color: #FFF;
    margin: 0 0 16px 0;
    line-height: 1.2;
    letter-spacing: 1px;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
  }
  .cp-price-section {
    margin-bottom: 30px;
    border-bottom: 1px solid #1A1A1A;
    padding-bottom: 24px;
  }
  .cp-price {
    font-family: "Orbitron", "Rajdhani", sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #F4C430; /* Gold */
    text-shadow: 0 0 8px rgba(244, 196, 48, 0.4);
    display: block;
    margin-bottom: 8px;
  }
  .cp-tax-text {
    font-size: 12px;
    color: #888;
    margin: 0;
  }
  .cp-tax-text a {
    color: #F4C430;
    text-decoration: underline;
  }

  /* Variants */
  .cp-variants {
    margin-bottom: 30px;
  }
  .cp-option-group {
    margin-bottom: 24px;
  }
  .cp-option-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .cp-option-label {
    font-size: 13px;
    font-weight: 700;
    color: #FFF;
    text-transform: uppercase;
  }
  .cp-selected-val {
    color: #B0B0B0;
    font-weight: 400;
  }
  .cp-size-guide {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #F4C430;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid #F4C430;
    padding-bottom: 2px;
  }
  .cp-option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .cp-val-btn {
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .cp-option-values.is-color .cp-val-btn {
    width: 70px;
    height: 70px;
    border-radius: 8px;
    border: 2px solid #333;
    padding: 4px;
    background: #FFF;
  }
  .cp-option-values.is-color .cp-val-btn.is-active {
    border-color: #FFF;
  }
  .variant-img-swatch {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
  }
  .swatch-circle {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #333;
    border: 1px solid rgba(0,0,0,0.1);
  }
  .cp-option-values.is-text .cp-val-btn {
    border: 1px solid #333;
    background: transparent;
    color: #B0B0B0;
    padding: 10px;
    border-radius: 4px;
    font-size: 14px;
    font-weight: 600;
    min-width: 48px;
    text-align: center;
  }
  .cp-option-values.is-text .cp-val-btn:hover {
    border-color: #666;
    color: #FFF;
  }
  .cp-option-values.is-text .cp-val-btn.is-active {
    border-color: #F4C430;
    color: #FFF;
    background: rgba(244, 196, 48, 0.1);
  }

  /* Buttons New */
  .cp-buy-buttons-new {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
    align-items: flex-start;
  }
  .cp-btn {
    width: 100%;
    height: 52px;
    border-radius: 50px;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.3s;
    border: none;
    font-family: inherit;
  }
  .cp-btn-add {
    background: #FFF;
    color: #000;
  }
  .cp-btn-add:hover {
    background: #EEE;
  }
  .cp-btn-soldout {
    background: #888;
    color: #111;
    cursor: not-allowed;
  }
  .cp-delivery-estimate {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #CCC;
    font-size: 13px;
    margin-top: -4px;
    padding-left: 4px;
  }
  .cp-delivery-estimate strong {
    color: #FFF;
  }

  /* Feature Icons */
  .cp-features-row {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
    padding-bottom: 30px;
    border-bottom: 1px solid #1A1A1A;
  }
  .cp-feat {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    flex: 1;
  }
  .cp-feat svg {
    flex-shrink: 0;
  }
  .cp-feat span {
    font-size: 10px;
    font-weight: 700;
    color: #B0B0B0;
    line-height: 1.4;
  }

  /* Accordions New */
  .cp-accordions {
    border-top: 1px solid #333;
  }
  .cp-acc-item {
    border-bottom: 1px solid #333;
  }
  .cp-acc-btn {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    color: #FFF;
    font-size: 14px;
    font-weight: 700;
    padding: 20px 0;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .cp-acc-btn .acc-title {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .cp-acc-btn .icon {
    font-size: 20px;
    font-weight: 400;
    color: #888;
    transition: transform 0.3s;
  }
  .cp-acc-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-out;
    color: #B0B0B0;
    font-size: 14px;
    line-height: 1.6;
  }
  .cp-acc-content > div, .cp-acc-content > p {
    padding-bottom: 20px;
  }
  /* Force custom HTML inside description to stack vertically in narrow accordion */
  .cp-desc {
    width: 100%;
    overflow-x: hidden;
  }
  .cp-desc * {
    box-sizing: border-box;
  }
  .cp-desc [style*="display: flex"],
  .cp-desc [style*="display:flex"],
  .cp-desc [class*="flex"] {
    flex-direction: column !important;
    flex-wrap: nowrap !important;
    gap: 20px !important;
  }
  .cp-desc [style*="display: grid"],
  .cp-desc [style*="display:grid"],
  .cp-desc [class*="grid"] {
    grid-template-columns: 1fr !important;
    gap: 20px !important;
  }
  .cp-desc [class*="col"], 
  .cp-desc [class*="column"] {
    width: 100% !important;
    max-width: 100% !important;
    flex: 0 0 100% !important;
  }
  /* Normalize font sizes for the accordion */
  .cp-desc h1, .cp-desc h2, .cp-desc h3, .cp-desc h4, .cp-desc h5, .cp-desc h6, 
  .cp-desc [class*="heading"], .cp-desc [class*="title"] {
    font-size: 18px !important;
    line-height: 1.3 !important;
    margin-top: 12px !important;
    margin-bottom: 8px !important;
  }
  .cp-desc p, .cp-desc span, .cp-desc li, .cp-desc div {
    font-size: 14px !important;
    line-height: 1.6 !important;
  }
  
  /* Zoom Container */

  .cp-trust-strip {
    margin-top: 60px;
    border-top: 1px solid #1A1A1A;
    padding-top: 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    position: relative;
    padding: 0 20px;
  }
  .trust-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 40px;
    width: 1px;
    background-color: #333;
  }
  .trust-text {
    font-size: 12px;
    color: #888;
    line-height: 1.4;
  }
  .trust-text strong {
    color: #FFF;
    font-size: 13px;
    text-transform: uppercase;
  }

  /* Responsive */
  @media screen and (max-width: 1024px) {
    .cp-layout-grid {
      grid-template-columns: 1fr;
    }
    .cp-gallery {
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    .cp-trust-strip {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }
  }

  @media screen and (max-width: 768px) {
    .custom-product-wrapper {
      flex-direction: row !important;
    }
    .cp-sidebar {
      display: flex !important;
      width: 50px !important;
      padding-top: 20px !important;
    }
    .cp-vertical-brand .letter {
      font-size: 16px !important;
      line-height: 1.2 !important;
    }
    .cp-zodiac-icon svg {
      width: 20px !important;
      height: 20px !important;
    }
    .cp-main-container {
      padding: 10px !important;
      width: calc(100% - 50px) !important;
      max-width: calc(100% - 50px) !important;
      flex: 1 !important;
    }
    .cp-layout-grid {
      display: flex !important;
      flex-direction: column !important;
      gap: 20px !important;
    }
    .cp-left-col {
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 !important;
      position: relative !important;
    }
    .cp-right-col {
      width: 100% !important;
      max-width: 100% !important;
      padding: 0 !important;
    }
    .cp-gallery {
      display: flex !important;
      flex-direction: column-reverse !important;
      gap: 15px !important;
      width: 100% !important;
    }
    .cp-thumbnails {
      display: flex !important;
      flex-direction: row !important;
      width: 100% !important;
      overflow-x: auto !important;
      flex-wrap: nowrap !important;
      -webkit-overflow-scrolling: touch !important;
      padding-bottom: 5px !important;
      gap: 10px !important;
      scrollbar-width: none !important;
      -ms-overflow-style: none !important;
    }
    .cp-thumbnails::-webkit-scrollbar {
      display: none !important;
    }
    .cp-thumb {
      height: 50px !important;
      width: 50px !important;
      flex-shrink: 0 !important;
    }
    .cp-title {
      font-size: 22px !important;
    }
    .cp-price {
      font-size: 18px !important;
    }
    .cp-features-row {
      flex-direction: column !important;
      gap: 15px !important;
    }
    .cp-trust-strip {
      grid-template-columns: 1fr !important;
    }
    .cp-zoom-result, .cp-zoom-lens {
      display: none !important;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Custom Product",
  "settings": [],
  "presets": [
    {
      "name": "Custom Product"
    }
  ]
}
{% endschema %}
