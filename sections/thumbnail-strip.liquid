<div class="thumbnail-strip-{{ section.id }}">
  <div class="thumbnail-strip-{{ section.id }}__container">
    {% for block in section.blocks %}
      <a href="{{ block.settings.product_url | default: '#' }}" class="thumbnail-strip-{{ section.id }}__card" {{ block.shopify_attributes }}>
        {% if block.settings.image != blank %}
          {{ block.settings.image | image_url: width: 400 | image_tag: class: 'thumbnail-strip-' | append: section.id | append: '__image' }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'thumbnail-strip-' | append: section.id | append: '__image thumbnail-strip-' | append: section.id | append: '__placeholder' }}
        {% endif %}
        <div class="thumbnail-strip-{{ section.id }}__overlay">
          <div class="thumbnail-strip-{{ section.id }}__info">
            <div class="thumbnail-strip-{{ section.id }}__color-wrap">
              <span class="thumbnail-strip-{{ section.id }}__dot" style="background-color: {{ block.settings.color_hex }};"></span>
              <span class="thumbnail-strip-{{ section.id }}__text">{{ block.settings.color_name }}</span>
            </div>
            <span class="thumbnail-strip-{{ section.id }}__price">{{ block.settings.price }}</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

<style>
  .thumbnail-strip-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 20px 40px;
    width: 100%;
    box-sizing: border-box;
  }
  
  .thumbnail-strip-{{ section.id }}__container {
    display: flex;
    justify-content: center;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .thumbnail-strip-{{ section.id }}__card {
    flex: 1 1 25%;
    max-width: 280px;
    aspect-ratio: 1 / 1;
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid rgba(255,255,255,0.05);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
  }
  
  .thumbnail-strip-{{ section.id }}__card:hover {
    transform: scale(1.02);
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 4px 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }};
  }
  
  .thumbnail-strip-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .thumbnail-strip-{{ section.id }}__placeholder {
    fill: #333;
    background: {{ section.settings.card_bg_color }};
  }
  
  .thumbnail-strip-{{ section.id }}__overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 16px;
    background: linear-gradient(to top, rgba(0,0,0,0.9), transparent);
    display: flex;
    align-items: flex-end;
  }
  
  .thumbnail-strip-{{ section.id }}__info {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  
  .thumbnail-strip-{{ section.id }}__color-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .thumbnail-strip-{{ section.id }}__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: block;
  }
  
  .thumbnail-strip-{{ section.id }}__text {
    color: {{ section.settings.text_color }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .thumbnail-strip-{{ section.id }}__price {
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 400;
  }
  
  @media (max-width: 768px) {
    .thumbnail-strip-{{ section.id }} {
      padding: 20px;
    }
    .thumbnail-strip-{{ section.id }}__container {
      justify-content: flex-start;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding-bottom: 10px;
      -webkit-overflow-scrolling: touch;
    }
    .thumbnail-strip-{{ section.id }}__container::-webkit-scrollbar {
      height: 4px;
    }
    .thumbnail-strip-{{ section.id }}__container::-webkit-scrollbar-track {
      background: {{ section.settings.card_bg_color }}; 
    }
    .thumbnail-strip-{{ section.id }}__container::-webkit-scrollbar-thumb {
      background: #333; 
      border-radius: 4px;
    }
    .thumbnail-strip-{{ section.id }}__card {
      flex: 0 0 70%;
      scroll-snap-align: center;
    }
  }
</style>

{% schema %}
{
  "name": "Thumbnail Strip",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Hover Accent Color",
      "default": "#F4C430"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "thumbnail",
      "name": "Thumbnail",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "color_name",
          "label": "Color Name",
          "default": "Black"
        },
        {
          "type": "color",
          "id": "color_hex",
          "label": "Color Swatch",
          "default": "#000000"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "£129.99"
        },
        {
          "type": "url",
          "id": "product_url",
          "label": "Product Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Thumbnail Strip",
      "blocks": [
        { "type": "thumbnail", "settings": { "color_name": "Black", "color_hex": "#000000", "price": "£129.99" } },
        { "type": "thumbnail", "settings": { "color_name": "Olive", "color_hex": "#556b2f", "price": "£129.99" } },
        { "type": "thumbnail", "settings": { "color_name": "Brown", "color_hex": "#5c4033", "price": "£129.99" } },
        { "type": "thumbnail", "settings": { "color_name": "Sand", "color_hex": "#c2b280", "price": "£129.99" } }
      ]
    }
  ]
}
{% endschema %}
