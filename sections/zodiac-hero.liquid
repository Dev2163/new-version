{% style %}
  .zodiac-hero-{{ section.id }} {
    position: relative;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    overflow: hidden;
    padding: 60px 0;
    min-height: 80vh;
    display: flex;
    align-items: center;
    font-family: var(--font-body-family), sans-serif;
  }
  .zodiac-hero-{{ section.id }} .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 25vw;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    z-index: 1;
    pointer-events: none;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .zodiac-hero-{{ section.id }} .hero-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    z-index: 2;
    position: relative;
    gap: 40px;
  }
  .zodiac-hero-{{ section.id }} .hero-content {
    flex: 1;
    max-width: 600px;
  }
  .zodiac-hero-{{ section.id }} .hero-subtitle {
    color: {{ section.settings.accent_color }};
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 2px;
    margin-bottom: 15px;
    font-size: 14px;
  }
  .zodiac-hero-{{ section.id }} .hero-title {
    font-size: clamp(40px, 6vw, 80px);
    font-weight: 900;
    line-height: 1;
    margin-bottom: 25px;
    text-transform: uppercase;
    font-family: 'Anton', 'Impact', sans-serif;
    color: #ffffff;
  }
  .zodiac-hero-{{ section.id }} .hero-title span {
    color: {{ section.settings.accent_color }};
  }
  .zodiac-hero-{{ section.id }} .hero-text {
    font-size: 18px;
    line-height: 1.6;
    margin-bottom: 40px;
    color: #cccccc;
    max-width: 450px;
  }
  .zodiac-hero-{{ section.id }} .hero-buttons {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .zodiac-hero-{{ section.id }} .btn-primary {
    background-color: {{ section.settings.accent_color }};
    color: #000;
    padding: 15px 30px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 1px;
    border: 2px solid {{ section.settings.accent_color }};
    transition: all 0.3s ease;
  }
  .zodiac-hero-{{ section.id }} .btn-primary:hover {
    background-color: transparent;
    color: {{ section.settings.accent_color }};
  }
  .zodiac-hero-{{ section.id }} .btn-secondary {
    background-color: transparent;
    color: #fff;
    padding: 15px 30px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 1px;
    border: 2px solid rgba(255,255,255,0.2);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s ease;
  }
  .zodiac-hero-{{ section.id }} .btn-secondary:hover {
    border-color: #fff;
  }
  .zodiac-hero-{{ section.id }} .hero-image-wrapper {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
  }
  .zodiac-hero-{{ section.id }} .hero-image {
    max-width: 100%;
    height: auto;
    z-index: 2;
    position: relative;
  }
  .zodiac-hero-{{ section.id }} .hero-splash {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background-image: url('{{ section.settings.splash_image | img_url: "master" }}');
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 1;
    opacity: 0.8;
  }
  .zodiac-hero-{{ section.id }} .hero-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 120px;
    height: 120px;
    border: 1px dashed rgba(255,255,255,0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    animation: rotateBadge 15s linear infinite;
    z-index: 3;
  }
  .zodiac-hero-{{ section.id }} .hero-badge-inner {
    color: {{ section.settings.accent_color }};
    font-weight: bold;
    font-size: 14px;
  }
  
  @keyframes rotateBadge {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  .zodiac-hero-{{ section.id }} .hero-nav {
    position: absolute;
    right: 40px;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 20px;
    z-index: 3;
  }
  .zodiac-hero-{{ section.id }} .hero-nav-item {
    color: #555;
    font-size: 14px;
    cursor: pointer;
    transition: color 0.3s;
  }
  .zodiac-hero-{{ section.id }} .hero-nav-item.active {
    color: {{ section.settings.accent_color }};
    font-weight: bold;
  }

  @media (max-width: 990px) {
    .zodiac-hero-{{ section.id }} .hero-container {
      flex-direction: column;
      text-align: center;
      padding-top: 60px;
    }
    .zodiac-hero-{{ section.id }} .hero-content {
      max-width: 100%;
    }
    .zodiac-hero-{{ section.id }} .hero-buttons {
      justify-content: center;
    }
    .zodiac-hero-{{ section.id }} .hero-nav {
      display: none;
    }
  }
{% endstyle %}

<section class="zodiac-hero-{{ section.id }}">
  {% if section.settings.bg_text != blank %}
    <div class="hero-bg-text">{{ section.settings.bg_text }}</div>
  {% endif %}
  
  <div class="hero-container">
    <div class="hero-content">
      {% if section.settings.subtitle != blank %}
        <div class="hero-subtitle">{{ section.settings.subtitle }}</div>
      {% endif %}
      
      {% if section.settings.title != blank %}
        <h1 class="hero-title">{{ section.settings.title }}</h1>
      {% endif %}
      
      {% if section.settings.text != blank %}
        <div class="hero-text">{{ section.settings.text }}</div>
      {% endif %}
      
      <div class="hero-buttons">
        {% if section.settings.btn_1_text != blank %}
          <a href="{{ section.settings.btn_1_link }}" class="btn-primary">{{ section.settings.btn_1_text }} &rarr;</a>
        {% endif %}
        {% if section.settings.btn_2_text != blank %}
          <a href="{{ section.settings.btn_2_link }}" class="btn-secondary">{{ section.settings.btn_2_text }} &#9658;</a>
        {% endif %}
      </div>
    </div>
    
    <div class="hero-image-wrapper">
      {% if section.settings.splash_image %}
        <div class="hero-splash"></div>
      {% endif %}
      
      {% if section.settings.badge_text != blank %}
        <div class="hero-badge">
          <div class="hero-badge-inner">{{ section.settings.badge_text }}</div>
        </div>
      {% endif %}
      
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 800 | image_tag: class: 'hero-image', loading: 'lazy' }}
      {% else %}
        {{ 'image' | placeholder_svg_tag: 'hero-image placeholder-svg' }}
      {% endif %}
    </div>
  </div>
  
  {% if section.settings.show_side_nav %}
    <div class="hero-nav">
      <div class="hero-nav-item active">01</div>
      <div class="hero-nav-item">02</div>
      <div class="hero-nav-item">03</div>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Zodiac Hero",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c99a3c"
    },
    {
      "type": "text",
      "id": "bg_text",
      "label": "Background Large Text",
      "default": "VSYT"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "NEW COLLECTION"
    },
    {
      "type": "html",
      "id": "title",
      "label": "Title",
      "default": "ELEVATE YOUR <br><span>EVERYDAY STYLE</span>",
      "info": "Use <span> for accent color"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Premium oversized t-shirts crafted for comfort, designed to make a statement."
    },
    {
      "type": "text",
      "id": "btn_1_text",
      "label": "Button 1 Text",
      "default": "EXPLORE COLLECTION"
    },
    {
      "type": "url",
      "id": "btn_1_link",
      "label": "Button 1 Link"
    },
    {
      "type": "text",
      "id": "btn_2_text",
      "label": "Button 2 Text",
      "default": "VIEW LOOKBOOK"
    },
    {
      "type": "url",
      "id": "btn_2_link",
      "label": "Button 2 Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "splash_image",
      "label": "Background Splash Image (Optional)"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "NEW DROP"
    },
    {
      "type": "checkbox",
      "id": "show_side_nav",
      "label": "Show Side Navigation",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Zodiac Hero"
    }
  ]
}
{% endschema %}
