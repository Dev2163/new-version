{% style %}
  .zodiac-hotspot-hero-{{ section.id }} {
    position: relative;
    background-color: {{ section.settings.bg_color }};
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: var(--font-body-family), sans-serif;
  }
  
  .zh-background-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60vw;
    height: 60vw;
    max-width: 800px;
    max-height: 800px;
    border: 1px solid rgba(201, 154, 60, 0.3);
    border-radius: 50%;
    box-shadow: 0 0 80px rgba(201, 154, 60, 0.1) inset, 0 0 80px rgba(201, 154, 60, 0.1);
    z-index: 1;
    pointer-events: none;
  }

  .zh-bottom-glow {
    position: absolute;
    bottom: -100px;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 200px;
    background: radial-gradient(ellipse at center, rgba(201, 154, 60, 0.4) 0%, rgba(0,0,0,0) 70%);
    z-index: 1;
    pointer-events: none;
  }

  .zh-container {
    position: relative;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 60px 20px;
  }

  .zh-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 700px;
    display: flex;
    justify-content: center;
  }

  .zh-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 2;
  }

  /* Hotspot Styling */
  .zh-hotspot {
    position: absolute;
    z-index: 10;
  }

  .zh-dot {
    width: 12px;
    height: 12px;
    background-color: {{ section.settings.accent_color }};
    border-radius: 50%;
    position: absolute;
    top: -6px;
    left: -6px;
    box-shadow: 0 0 10px {{ section.settings.accent_color }}, 0 0 20px {{ section.settings.accent_color }};
    animation: zhPulse 2s infinite;
    cursor: pointer;
  }

  @keyframes zhPulse {
    0% { box-shadow: 0 0 0 0 rgba(201, 154, 60, 0.7); }
    70% { box-shadow: 0 0 0 15px rgba(201, 154, 60, 0); }
    100% { box-shadow: 0 0 0 0 rgba(201, 154, 60, 0); }
  }

  /* Hotspot Text Content */
  .zh-content {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 220px;
    opacity: 1;
    transition: opacity 0.3s;
  }

  /* Left facing hotspot (Dot is on the right, text is on the left) */
  .zh-hotspot.dir-left .zh-content {
    right: 30px;
    text-align: right;
  }
  
  .zh-hotspot.dir-left .zh-content::before {
    content: '';
    position: absolute;
    top: 10px;
    right: -30px;
    width: 25px;
    height: 1px;
    background: {{ section.settings.accent_color }};
  }

  /* Right facing hotspot (Dot is on the left, text is on the right) */
  .zh-hotspot.dir-right .zh-content {
    left: 30px;
    text-align: left;
  }

  .zh-hotspot.dir-right .zh-content::before {
    content: '';
    position: absolute;
    top: 10px;
    left: -30px;
    width: 25px;
    height: 1px;
    background: {{ section.settings.accent_color }};
  }

  .zh-title {
    color: {{ section.settings.accent_color }};
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 5px;
    letter-spacing: 1px;
  }

  .zh-desc {
    color: #cccccc;
    font-size: 12px;
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .zh-content {
      width: 140px;
    }
    .zh-hotspot.dir-left .zh-content {
      right: 20px;
    }
    .zh-hotspot.dir-right .zh-content {
      left: 20px;
    }
    .zh-hotspot.dir-left .zh-content::before {
      right: -20px;
      width: 15px;
    }
    .zh-hotspot.dir-right .zh-content::before {
      left: -20px;
      width: 15px;
    }
    .zh-background-ring {
      width: 90vw;
      height: 90vw;
    }
  }
{% endstyle %}

<section class="zodiac-hotspot-hero-{{ section.id }}">
  <div class="zh-background-ring"></div>
  <div class="zh-bottom-glow"></div>

  <div class="zh-container">
    <div class="zh-image-wrapper">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 1000 | image_tag: class: 'zh-image', loading: 'lazy' }}
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'zh-image placeholder-svg' }}
      {% endif %}

      {% for block in section.blocks %}
        <div class="zh-hotspot dir-{{ block.settings.direction }}" style="top: {{ block.settings.top_pos }}%; left: {{ block.settings.left_pos }}%;" {{ block.shopify_attributes }}>
          <div class="zh-dot"></div>
          <div class="zh-content">
            {% if block.settings.title != blank %}
              <div class="zh-title">{{ block.settings.title }}</div>
            {% endif %}
            {% if block.settings.text != blank %}
              <div class="zh-desc">{{ block.settings.text }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Animated Hotspots",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#c99a3c"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Main Image"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "PREMIUM FEATURE"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe your premium product feature here."
        },
        {
          "type": "range",
          "id": "top_pos",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position (Top)",
          "default": 50
        },
        {
          "type": "range",
          "id": "left_pos",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position (Left)",
          "default": 50
        },
        {
          "type": "select",
          "id": "direction",
          "label": "Text Direction",
          "options": [
            { "value": "left", "label": "Text on Left" },
            { "value": "right", "label": "Text on Right" }
          ],
          "default": "right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Animated Hotspots",
      "blocks": [
        {
          "type": "hotspot",
          "settings": {
            "title": "RIBBED CREW NECK",
            "text": "Durable ribbed neck for a perfect fit and long lasting shape.",
            "top_pos": 15,
            "left_pos": 65,
            "direction": "right"
          }
        },
        {
          "type": "hotspot",
          "settings": {
            "title": "PREMIUM COTTON",
            "text": "High quality 240 GSM super combed cotton for ultimate comfort.",
            "top_pos": 65,
            "left_pos": 30,
            "direction": "left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
