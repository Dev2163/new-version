<section class="shoe-categories-section" style="background-color: {{ section.settings.bg_color }}; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;">
  <div class="page-width">
    <div class="shoe-categories__list">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="shoe-categories__link" {{ block.shopify_attributes }} style="color: {{ section.settings.text_color }};">
          {{ block.settings.title }}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .shoe-categories-section {
    width: 100%;
    border-bottom: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.1 }};
    border-top: 1px solid {{ section.settings.text_color | color_modify: 'alpha', 0.1 }};
  }
  .shoe-categories__list {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 40px;
  }
  .shoe-categories__link {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.5px;
    padding: 10px 0;
    position: relative;
    transition: opacity 0.3s ease;
    white-space: nowrap;
  }
  .shoe-categories__link:hover {
    opacity: 0.7;
  }
  .shoe-categories__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: {{ section.settings.text_color }};
    transition: width 0.3s ease;
  }
  .shoe-categories__link:hover::after {
    width: 100%;
  }

  @media screen and (max-width: 768px) {
    .shoe-categories__list {
      flex-direction: column;
      gap: 15px;
      align-items: flex-start;
      padding-left: 20px;
    }
    .shoe-categories__link {
      font-size: 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Shoe Categories",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Link",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Category Name",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoe Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Sachin's Legacy Sneakers" } },
        { "type": "category", "settings": { "title": "Sports Shoes" } },
        { "type": "category", "settings": { "title": "New Launches" } }
      ]
    }
  ]
}
{% endschema %}
