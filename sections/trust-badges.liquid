{% liquid
  assign bg_color = section.settings.bg_color | default: '#000000'
  assign text_color = section.settings.text_color | default: '#FFFFFF'
  assign icon_color = section.settings.icon_color | default: '#F4C430'
%}

<div class="trust-badges-wrapper" style="background-color: {{ bg_color }};">
  <div class="trust-badges page-width">
    <div class="trust-badges__grid">
      {% for block in section.blocks %}
        <div class="trust-badge__item" {{ block.shopify_attributes }}>
          <div class="trust-badge__icon" style="color: {{ icon_color }};">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            {% endif %}
          </div>
          <div class="trust-badge__content">
            <h4 class="trust-badge__title" style="color: {{ text_color }};">{{ block.settings.title }}</h4>
            <p class="trust-badge__subtitle" style="color: {{ text_color | color_modify: 'alpha', 0.7 }};">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .trust-badges-wrapper {
    width: 100%;
    padding: 24px 0;
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
  }
  .trust-badges {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .trust-badges__grid {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .trust-badge__item {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 1;
    position: relative;
    padding: 12px;
    border-radius: 8px;
    transition: background-color 0.3s ease, transform 0.3s ease;
    cursor: default;
  }
  
  /* Vertical divider lines between items */
  .trust-badge__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -10px;
    top: 15%;
    height: 70%;
    width: 1px;
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* Hover Effects */
  .trust-badge__item:hover {
    background-color: rgba(255, 255, 255, 0.04);
    transform: translateY(-2px);
  }

  .trust-badge__item:hover .trust-badge__icon svg {
    transform: scale(1.15);
    filter: drop-shadow(0 0 8px {{ icon_color | color_modify: 'alpha', 0.5 }});
  }

  .trust-badge__item:hover .trust-badge__title {
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
  }

  .trust-badge__icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trust-badge__icon svg {
    width: 100%;
    height: 100%;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), filter 0.3s ease;
  }

  .trust-badge__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .trust-badge__title {
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: text-shadow 0.3s ease;
  }

  .trust-badge__subtitle {
    font-size: 13px;
    margin: 0;
    line-height: 1.3;
  }

  /* Responsive Design - Tablet */
  @media screen and (max-width: 989px) {
    .trust-badges__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
    .trust-badge__item {
      padding: 16px;
    }
    .trust-badge__item::after {
      display: none !important; /* Hide dividers on grid view */
    }
  }

  /* Responsive Design - Mobile */
  @media screen and (max-width: 749px) {
    .trust-badges__grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .trust-badges-wrapper {
      padding: 20px 0;
    }
    .trust-badge__item {
      padding: 12px;
      justify-content: flex-start;
    }
    .trust-badge__icon {
      width: 32px;
      height: 32px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Badges",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#F4C430"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
