<div class="custom-marquee-{{ section.id }}">
  <div class="custom-marquee-{{ section.id }}__track">
    <div class="custom-marquee-{{ section.id }}__content">
      {%- for i in (1..10) -%}
        <span class="custom-marquee-{{ section.id }}__text">{{ section.settings.text }}</span>
        <span class="custom-marquee-{{ section.id }}__icon">✦</span>
      {%- endfor -%}
    </div>
    <div class="custom-marquee-{{ section.id }}__content">
      {%- for i in (1..10) -%}
        <span class="custom-marquee-{{ section.id }}__text">{{ section.settings.text }}</span>
        <span class="custom-marquee-{{ section.id }}__icon">✦</span>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .custom-marquee-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
    padding: 12px 0;
    position: relative;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  
  .custom-marquee-{{ section.id }}__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
  }
  
  .custom-marquee-{{ section.id }}__content {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }
  
  .custom-marquee-{{ section.id }}__text {
    color: {{ section.settings.text_color }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    white-space: nowrap;
    margin: 0 24px;
  }
  
  .custom-marquee-{{ section.id }}__icon {
    color: {{ section.settings.text_color }};
    font-size: 12px;
  }
  
  @keyframes marquee-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "Custom Marquee",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "BUILT DIFFERENT. WORN EVERYWHERE."
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Animation Speed (seconds)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 30
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text and Icon Color",
      "default": "#8A7B5C"
    }
  ],
  "presets": [
    {
      "name": "Custom Marquee",
      "category": "Custom"
    }
  ]
}
{% endschema %}
