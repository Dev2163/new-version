{% comment %}
  ONE9 Luxury Streetwear - Customer Reviews Section
{% endcomment %}

<div class="customer-reviews section-{{ section.id }}" style="background-color: {{ section.settings.bg_color | default: '#0a0a0a' }}; color: #ffffff; padding: {{ section.settings.padding_top | default: 60 }}px 0 {{ section.settings.padding_bottom | default: 60 }}px 0;">
  <div class="page-width">
    <div class="section-heading text-center" style="margin-bottom: 48px;">
      <h2 style="font-family: 'Orbitron', sans-serif; font-size: clamp(24px, 4vw, 36px); font-weight: 800; text-transform: uppercase; color: #ffffff; margin-bottom: 8px;">
        {{ section.settings.title | default: 'VERIFIED REVIEWS' }}
      </h2>
      <p style="font-family: 'Rajdhani', sans-serif; font-size: 15px; color: #f4c430; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 600;">
        {{ section.settings.subtitle | default: 'RATED 4.9/5 BY OVER 10,000+ CUSTOMERS WORLDWIDE' }}
      </p>
    </div>

    <div class="reviews-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="review-card glass-panel" style="padding: 28px; border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;" {{ block.shopify_attributes }}>
            <div>
              <!-- Stars -->
              <div class="stars" style="color: #f4c430; display: flex; gap: 4px; margin-bottom: 16px;">
                {%- for i in (1..5) -%}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                {%- endfor -%}
              </div>
              <p style="font-family: 'Rajdhani', sans-serif; font-size: 15px; line-height: 1.6; color: #e0e0e0; margin-bottom: 20px; font-style: italic;">
                "{{ block.settings.comment }}"
              </p>
            </div>
            <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
              <div>
                <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">
                  {{ block.settings.author }}
                </div>
                <div style="font-family: 'Rajdhani', sans-serif; font-size: 12px; color: #888888;">
                  {{ block.settings.location | default: 'Verified Buyer' }}
                </div>
              </div>
              <span style="background: rgba(244, 196, 48, 0.15); color: #f4c430; border: 1px solid rgba(244, 196, 48, 0.3); font-size: 10px; font-family: 'Orbitron', sans-serif; font-weight: 700; padding: 4px 8px; border-radius: 4px; text-transform: uppercase;">
                Verified
              </span>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <!-- Fallback Reviews -->
        <div class="review-card glass-panel" style="padding: 28px; border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <div class="stars" style="color: #f4c430; display: flex; gap: 4px; margin-bottom: 16px;">
              {%- for i in (1..5) -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>{%- endfor -%}
            </div>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 15px; line-height: 1.6; color: #e0e0e0; margin-bottom: 20px; font-style: italic;">
              "The luxury heavyweight fabric is unmatched. Fits perfectly oversized and feels extremely premium."
            </p>
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
            <div>
              <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">ALEX R.</div>
              <div style="font-family: 'Rajdhani', sans-serif; font-size: 12px; color: #888888;">London, UK</div>
            </div>
            <span style="background: rgba(244, 196, 48, 0.15); color: #f4c430; border: 1px solid rgba(244, 196, 48, 0.3); font-size: 10px; font-family: 'Orbitron', sans-serif; font-weight: 700; padding: 4px 8px; border-radius: 4px; text-transform: uppercase;">Verified</span>
          </div>
        </div>

        <div class="review-card glass-panel" style="padding: 28px; border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <div class="stars" style="color: #f4c430; display: flex; gap: 4px; margin-bottom: 16px;">
              {%- for i in (1..5) -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>{%- endfor -%}
            </div>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 15px; line-height: 1.6; color: #e0e0e0; margin-bottom: 20px; font-style: italic;">
              "Best streetwear drop of the season. Delivery was super fast to NYC and packaging was 10/10."
            </p>
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
            <div>
              <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">DOMINIC T.</div>
              <div style="font-family: 'Rajdhani', sans-serif; font-size: 12px; color: #888888;">New York, USA</div>
            </div>
            <span style="background: rgba(244, 196, 48, 0.15); color: #f4c430; border: 1px solid rgba(244, 196, 48, 0.3); font-size: 10px; font-family: 'Orbitron', sans-serif; font-weight: 700; padding: 4px 8px; border-radius: 4px; text-transform: uppercase;">Verified</span>
          </div>
        </div>

        <div class="review-card glass-panel" style="padding: 28px; border-radius: 12px; display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <div class="stars" style="color: #f4c430; display: flex; gap: 4px; margin-bottom: 16px;">
              {%- for i in (1..5) -%}<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>{%- endfor -%}
            </div>
            <p style="font-family: 'Rajdhani', sans-serif; font-size: 15px; line-height: 1.6; color: #e0e0e0; margin-bottom: 20px; font-style: italic;">
              "Unbelievable quality and attention to detail. Will definitely order more pieces from future drops."
            </p>
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
            <div>
              <div style="font-family: 'Orbitron', sans-serif; font-size: 14px; font-weight: 700; color: #ffffff;">SOPHIA K.</div>
              <div style="font-family: 'Rajdhani', sans-serif; font-size: 12px; color: #888888;">Berlin, Germany</div>
            </div>
            <span style="background: rgba(244, 196, 48, 0.15); color: #f4c430; border: 1px solid rgba(244, 196, 48, 0.3); font-size: 10px; font-family: 'Orbitron', sans-serif; font-weight: 700; padding: 4px 8px; border-radius: 4px; text-transform: uppercase;">Verified</span>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Reviews",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "VERIFIED REVIEWS"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subheading",
      "default": "RATED 4.9/5 BY OVER 10,000+ CUSTOMERS WORLDWIDE"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0a0a0a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Item",
      "settings": [
        {
          "type": "textarea",
          "id": "comment",
          "label": "Comment",
          "default": "The quality of the heavy cotton hoodie is insane. Easily beats brands 3x the price. Customer service was super quick with size exchange."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "MARCUS V."
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location / Verified Label",
          "default": "London, UK"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "comment": "The luxury heavyweight fabric is unmatched. Fits perfectly oversized.",
            "author": "ALEX R.",
            "location": "London, UK"
          }
        },
        {
          "type": "review",
          "settings": {
            "comment": "Best streetwear drop of the season. Delivery was super fast to NYC.",
            "author": "DOMINIC T.",
            "location": "New York, USA"
          }
        },
        {
          "type": "review",
          "settings": {
            "comment": "Unbelievable quality and attention to detail. Will definitely order again.",
            "author": "SOPHIA K.",
            "location": "Berlin, Germany"
          }
        }
      ]
    }
  ]
}
{% endschema %}
