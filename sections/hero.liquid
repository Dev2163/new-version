<div class="custom-hero-container-{{ section.id }}">
  <!-- HERO PART -->
  <div class="custom-hero-{{ section.id }}">
    
    <!-- Far Left Sidebar -->
    <div class="custom-hero-{{ section.id }}__sidebar">
      <div class="custom-hero-{{ section.id }}__vertical-text">
        {% assign brand_letters = section.settings.vertical_text | split: "," %}
        {% for letter in brand_letters %}
          <span>{{ letter }}</span>
        {% endfor %}
      </div>
      <div class="custom-hero-{{ section.id }}__icon">
        <svg width="44" height="44" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Top dots -->
          <circle cx="22" cy="7" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="15" cy="8.5" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="29" cy="8.5" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="9" cy="13" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="35" cy="13" r="1.5" fill="{{ section.settings.accent_color }}" />
          
          <!-- Blinking Eye Group -->
          <g class="eye-blink-anim">
            <path d="M6 22 Q22 6 38 22 Q22 38 6 22 Z" stroke="{{ section.settings.accent_color }}" stroke-width="2.5" fill="none" />
            <circle cx="22" cy="22" r="4.5" stroke="{{ section.settings.accent_color }}" stroke-width="2.5" fill="none" />
            <circle cx="22" cy="22" r="2" fill="{{ section.settings.accent_color }}" />
          </g>

          <!-- Bottom dots -->
          <circle cx="22" cy="37" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="15" cy="35.5" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="29" cy="35.5" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="9" cy="31" r="1.5" fill="{{ section.settings.accent_color }}" />
          <circle cx="35" cy="31" r="1.5" fill="{{ section.settings.accent_color }}" />
        </svg>
      </div>
      <div class="custom-hero-{{ section.id }}__line"></div>
    </div>
    
    <!-- Main Content Row (Flex reversed if image is left) -->
    <div class="custom-hero-{{ section.id }}__content-row {% if section.settings.image_position == 'left' %}image-left{% endif %}">
      
      <!-- Text Column -->
      <div class="custom-hero-{{ section.id }}__main">
        <h1 class="custom-hero-{{ section.id }}__title">{{ section.settings.title }}</h1>
        <p class="custom-hero-{{ section.id }}__subtitle">{{ section.settings.subtitle }}</p>
        <a href="{{ section.settings.button_link }}" class="custom-hero-{{ section.id }}__button">{{ section.settings.button_text }}</a>
      </div>
      
      <!-- Image Column -->
      <div class="custom-hero-{{ section.id }}__image-col">
        <div class="custom-hero-{{ section.id }}__image-glow">
          {%- if section.settings.image != blank -%}
            {% assign hero_img_class = 'custom-hero-' | append: section.id | append: '__image custom-hero-slideshow-image' %}
            {{ section.settings.image | image_url: width: 1200 | image_tag: class: hero_img_class, id: 'heroMainImage' }}
          {%- else -%}
            {% assign hero_img_class_placeholder = 'custom-hero-' | append: section.id | append: '__image custom-hero-slideshow-image custom-hero-' | append: section.id | append: '__image--placeholder' %}
            {{ 'lifestyle-1' | placeholder_svg_tag: hero_img_class_placeholder }}
          {%- endif -%}
        </div>
      </div>
      
    </div>
  </div>

  <!-- MARQUEE PART -->
  {% if section.settings.show_marquee %}
  <div class="custom-marquee-{{ section.id }}">
    <div class="custom-marquee-{{ section.id }}__track">
      <div class="custom-marquee-{{ section.id }}__content">
        {%- for i in (1..10) -%}
          <span class="custom-marquee-{{ section.id }}__text">{{ section.settings.marquee_text }}</span>
          <span class="custom-marquee-{{ section.id }}__icon">✦</span>
        {%- endfor -%}
      </div>
      <div class="custom-marquee-{{ section.id }}__content">
        {%- for i in (1..10) -%}
          <span class="custom-marquee-{{ section.id }}__text">{{ section.settings.marquee_text }}</span>
          <span class="custom-marquee-{{ section.id }}__icon">✦</span>
        {%- endfor -%}
      </div>
    </div>
  </div>
  {% endif %}

  <!-- THUMBNAIL STRIP PART -->
  {% if section.blocks.size > 0 %}
  <div class="thumbnail-strip-{{ section.id }}">
    <div class="thumbnail-strip-{{ section.id }}__container">
      {% for block in section.blocks %}
        {% if block.type == 'thumbnail' %}
        <a href="{{ block.settings.product_url | default: '#' }}" class="thumbnail-strip-{{ section.id }}__card" {{ block.shopify_attributes }}>
          <div class="thumbnail-strip-{{ section.id }}__image-wrapper">
            {% if block.settings.image != blank %}
              {% assign thumb_img_class = 'thumbnail-strip-' | append: section.id | append: '__image' %}
              {{ block.settings.image | image_url: width: 400 | image_tag: class: thumb_img_class }}
            {% else %}
              {% assign thumb_placeholder_class = 'thumbnail-strip-' | append: section.id | append: '__image thumbnail-strip-' | append: section.id | append: '__placeholder' %}
              {{ 'product-1' | placeholder_svg_tag: thumb_placeholder_class }}
            {% endif %}
          </div>
          <div class="thumbnail-strip-{{ section.id }}__info">
            <div class="thumbnail-strip-{{ section.id }}__color-wrap">
              <span class="thumbnail-strip-{{ section.id }}__dot" style="background-color: {{ block.settings.color_hex }};"></span>
              <span class="thumbnail-strip-{{ section.id }}__text">{{ block.settings.color_name }}</span>
            </div>
            <span class="thumbnail-strip-{{ section.id }}__price">{{ block.settings.price }}</span>
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

<style>
  .custom-hero-container-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  /* --- HERO CSS --- */
  .custom-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 700px;
    display: flex;
    color: {{ section.settings.text_color }};
  }
  .custom-hero-{{ section.id }}__sidebar {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 40px;
    width: 120px;
    flex-shrink: 0;
  }
  .custom-hero-{{ section.id }}__content-row {
    flex: 1;
    display: flex;
    flex-direction: row;
    align-items: stretch;
  }
  .custom-hero-{{ section.id }}__content-row.image-left {
    flex-direction: row-reverse;
  }
  
  .custom-hero-{{ section.id }}__vertical-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 60px;
    font-weight: 900;
    color: {{ section.settings.accent_color }};
    font-family: 'Archivo Black', 'Anton', sans-serif;
    text-transform: uppercase;
    margin-bottom: 24px;
    letter-spacing: -2px;
  }
  .custom-hero-{{ section.id }}__vertical-text span {
    display: block;
    line-height: 0.85;
    margin-bottom: 2px;
  }
  .custom-hero-{{ section.id }}__icon {
    margin: 32px 0;
  }
  
  .eye-blink-anim {
    transform-origin: 22px 22px;
    animation: eyeBlink 4s infinite;
  }
  
  @keyframes eyeBlink {
    0%, 93%, 100% { transform: scaleY(1); }
    96.5% { transform: scaleY(0.1); }
  }
  
  .custom-hero-{{ section.id }}__line {
    width: 1px;
    flex-grow: 1;
    max-height: 300px;
    background-color: {{ section.settings.accent_color }};
  }
  
  .custom-hero-{{ section.id }}__main {
    flex: 1.2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px;
    max-width: 900px;
  }
  
  .custom-hero-{{ section.id }}__image-col {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: stretch;
    padding: 0;
    position: relative;
    overflow: hidden;
  }
  
  .custom-hero-{{ section.id }}__image-glow {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: flex-end;
    background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.12) 0%, transparent 65%);
  }
  
  .custom-hero-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    z-index: 2;
    position: relative;
    transition: opacity 0.5s ease;
  }
  
  .custom-hero-{{ section.id }}__title {
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    margin: 0 0 24px 0;
    color: {{ section.settings.text_color }};
    font-family: 'Archivo Black', 'Anton', sans-serif;
    letter-spacing: 1px;
    white-space: pre-line;
  }
  .custom-hero-{{ section.id }}__subtitle {
    font-size: 1.25rem;
    color: {{ section.settings.text_secondary_color }};
    margin: 0 0 48px 0;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-weight: 400;
  }
  .custom-hero-{{ section.id }}__button {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: #000000;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 1.125rem;
    padding: 16px 52px;
    text-decoration: none;
    border-radius: 4px;
    box-shadow: 0 0 30px {{ section.settings.accent_color | color_modify: 'alpha', 0.4 }};
    align-self: flex-start;
    transition: all 0.3s ease;
    letter-spacing: 1px;
  }
  .custom-hero-{{ section.id }}__button:hover {
    box-shadow: 0 0 40px {{ section.settings.accent_color | color_modify: 'alpha', 0.6 }};
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  /* --- MARQUEE CSS --- */
  .custom-marquee-{{ section.id }} {
    width: 100%;
    background-color: {{ section.settings.marquee_bg_color }};
    overflow: hidden;
    padding: 12px 0;
    position: relative;
    border-top: 1px solid rgba(255,255,255,0.05);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .custom-marquee-{{ section.id }}__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.marquee_speed }}s linear infinite;
  }
  .custom-marquee-{{ section.id }}__content {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }
  .custom-marquee-{{ section.id }}__text {
    color: {{ section.settings.marquee_text_color }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    white-space: nowrap;
    margin: 0 24px;
  }
  .custom-marquee-{{ section.id }}__icon {
    color: {{ section.settings.marquee_text_color }};
    font-size: 12px;
  }
  @keyframes marquee-scroll-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* --- THUMBNAIL STRIP CSS --- */
  .thumbnail-strip-{{ section.id }} {
    background-color: transparent;
    padding: 20px 40px;
    width: 100%;
    box-sizing: border-box;
  }
  .thumbnail-strip-{{ section.id }}__container {
    display: flex;
    justify-content: center;
    gap: 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .thumbnail-strip-{{ section.id }}__card {
    flex: 1 1 25%;
    max-width: 280px;
    background-color: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: flex;
    flex-direction: column;
  }
  .thumbnail-strip-{{ section.id }}__card:hover {
    transform: scale(1.03);
    border-color: {{ section.settings.accent_color }};
    box-shadow: 0 4px 20px {{ section.settings.accent_color | color_modify: 'alpha', 0.15 }};
  }
  .thumbnail-strip-{{ section.id }}__image-wrapper {
    width: 100%;
    aspect-ratio: 1 / 1.1;
    overflow: hidden;
  }
  .thumbnail-strip-{{ section.id }}__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumbnail-strip-{{ section.id }}__placeholder {
    fill: #333;
    background: {{ section.settings.card_bg_color }};
  }
  .thumbnail-strip-{{ section.id }}__info {
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    padding: 16px;
    background-color: {{ section.settings.card_bg_color }};
  }
  .thumbnail-strip-{{ section.id }}__color-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .thumbnail-strip-{{ section.id }}__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    display: block;
  }
  .thumbnail-strip-{{ section.id }}__text {
    color: {{ section.settings.text_color }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .thumbnail-strip-{{ section.id }}__price {
    color: {{ section.settings.text_color | color_modify: 'alpha', 0.8 }};
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 400;
  }

  /* --- RESPONSIVE CSS --- */
  @media (max-width: 1200px) {
    .custom-hero-{{ section.id }}__title { font-size: 4rem; }
  }
  @media (max-width: 990px) {
    .custom-hero-{{ section.id }}__title { font-size: 3.5rem; }
    .custom-hero-{{ section.id }}__subtitle { font-size: 1.15rem; }
    .custom-hero-{{ section.id }}__button { padding: 14px 40px; font-size: 1rem; }
  }
  @media (max-width: 768px) {
    /* Header overrides on mobile Index for ONE9 premium look */
    #shopify-section-header,
    #shopify-section-header .header-wrapper,
    #shopify-section-header sticky-header,
    #shopify-section-header .header__row {
      background-color: #0A0A0A !important;
    }
    
    #header-component {
      background-color: #0A0A0A !important;
      border-bottom: 1px solid rgba(255,255,255,0.05) !important;
    }

    #header-component .header__columns {
      position: relative !important;
      display: flex !important;
      justify-content: space-between !important;
      align-items: center !important;
    }
    
    /* Center the logo on mobile header */
    #header-component .header-logo {
      position: absolute !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      margin: 0 !important;
      color: #F4C430 !important; /* Gold logo */
      font-family: 'Archivo Black', 'Anton', sans-serif !important;
      font-weight: 900 !important;
      text-transform: uppercase !important;
      font-size: 22px !important;
      letter-spacing: -0.5px !important;
      z-index: 10 !important;
    }
    
    #header-component .header-logo * {
      color: #F4C430 !important;
    }
    
    /* Make icons/hamburger white */
    #header-component svg path,
    #header-component svg circle,
    #header-component svg line {
      stroke: #FFFFFF !important;
    }
    
    /* Cart count badge to match theme */
    .cart-count-bubble {
      background-color: #F4C430 !important;
      color: #000000 !important;
      font-weight: 800 !important;
    }

    /* Hero Layout: Mobile-first 390x844 responsive */
    .custom-hero-{{ section.id }} {
      display: block !important;
      position: relative !important;
      width: 100% !important;
      height: 540px !important;
      min-height: 540px !important;
      background-color: #0A0A0A !important;
      overflow: hidden !important;
    }

    /* Keep vertical ONE9 branding on far-left but smaller, not overlapping */
    .custom-hero-{{ section.id }}__sidebar {
      position: absolute !important;
      left: 0 !important;
      top: 0 !important;
      bottom: 0 !important;
      width: 50px !important;
      padding: 24px 0 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: flex-start !important;
      z-index: 5 !important;
      background: transparent !important;
    }
    
    .custom-hero-{{ section.id }}__vertical-text {
      flex-direction: column !important;
      font-size: 18px !important;
      margin-bottom: 8px !important;
      transform: none !important;
      letter-spacing: 0 !important;
      gap: 1px !important;
    }
    
    .custom-hero-{{ section.id }}__vertical-text span {
      margin-bottom: 2px !important;
      margin-right: 0 !important;
      line-height: 0.95 !important;
    }
    
    .custom-hero-{{ section.id }}__icon {
      margin: 8px 0 !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    
    .custom-hero-{{ section.id }}__icon svg {
      width: 24px !important;
      height: 24px !important;
    }
    
    .custom-hero-{{ section.id }}__line {
      width: 1px !important;
      height: 90px !important;
      background-color: {{ section.settings.accent_color }} !important;
    }

    /* Model image occupies upper-right portion */
    .custom-hero-{{ section.id }}__content-row {
      display: block !important;
      position: relative !important;
      width: 100% !important;
      height: 100% !important;
    }
    
    .custom-hero-{{ section.id }}__image-col {
      position: absolute !important;
      top: 0 !important;
      right: 0 !important;
      width: 68% !important;
      height: 60% !important;
      z-index: 1 !important;
      padding: 0 !important;
      margin: 0 !important;
      overflow: hidden !important;
    }
    
    /* Gradients to blend model with solid background */
    .custom-hero-{{ section.id }}__image-col::before {
      content: '' !important;
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      bottom: 0 !important;
      width: 50% !important;
      background: linear-gradient(to right, #0A0A0A 0%, transparent 100%) !important;
      z-index: 3 !important;
      pointer-events: none !important;
    }
    
    .custom-hero-{{ section.id }}__image-col::after {
      content: '' !important;
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      right: 0 !important;
      height: 40% !important;
      background: linear-gradient(to top, #0A0A0A 0%, transparent 100%) !important;
      z-index: 3 !important;
      pointer-events: none !important;
    }

    .custom-hero-{{ section.id }}__image {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
      object-position: center top !important;
    }

    /* Headline on the left/lower section */
    .custom-hero-{{ section.id }}__main {
      position: absolute !important;
      bottom: 0 !important;
      left: 0 !important;
      width: 100% !important;
      z-index: 4 !important;
      padding: 0px 20px 48px 62px !important; /* Left padding 62px keeps text from overlapping vertical sidebar */
      box-sizing: border-box !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: flex-start !important;
      text-align: left !important;
    }

    .custom-hero-{{ section.id }}__title {
      font-size: 24px !important;
      line-height: 1.1 !important;
      margin-bottom: 12px !important;
      text-transform: uppercase !important;
      font-family: 'Archivo Black', 'Anton', sans-serif !important;
      color: #FFFFFF !important;
      letter-spacing: 0.5px !important;
      white-space: pre-line !important;
    }

    .custom-hero-{{ section.id }}__subtitle {
      font-size: 12px !important;
      line-height: 1.4 !important;
      margin-bottom: 24px !important;
      color: #B0B0B0 !important;
      max-width: 250px !important;
      text-align: left !important;
    }

    /* Gold CTA button with gold glow */
    .custom-hero-{{ section.id }}__button {
      align-self: flex-start !important;
      padding: 12px 36px !important;
      font-size: 12px !important;
      font-weight: 800 !important;
      background-color: #F4C430 !important;
      color: #000000 !important;
      border-radius: 4px !important;
      box-shadow: 0 0 25px rgba(244, 196, 48, 0.5) !important;
      letter-spacing: 1px !important;
      text-transform: uppercase !important;
      transition: all 0.3s ease !important;
    }

    /* Below Hero: Horizontal scrollable jacket variants */
    .thumbnail-strip-{{ section.id }} {
      padding: 24px 20px !important;
      background-color: #0A0A0A !important;
    }
    
    .thumbnail-strip-{{ section.id }}__container {
      justify-content: flex-start !important;
      overflow-x: auto !important;
      scroll-snap-type: x mandatory !important;
      padding-bottom: 8px !important;
      -webkit-overflow-scrolling: touch !important;
      display: flex !important;
      gap: 16px !important;
    }
    
    /* Hide scrollbar */
    .thumbnail-strip-{{ section.id }}__container::-webkit-scrollbar {
      display: none !important;
    }
    
    /* Rounded variant cards */
    .thumbnail-strip-{{ section.id }}__card {
      flex: 0 0 62% !important; /* 62% width so next card is partially visible */
      scroll-snap-align: start !important;
      border-radius: 12px !important;
      border: 1px solid rgba(255, 255, 255, 0.06) !important;
      background-color: #111111 !important;
      overflow: hidden !important;
      display: flex !important;
      flex-direction: column !important;
      transition: border-color 0.3s ease, box-shadow 0.3s ease !important;
    }

    .thumbnail-strip-{{ section.id }}__card:active,
    .thumbnail-strip-{{ section.id }}__card:hover {
      border-color: #F4C430 !important;
      box-shadow: 0 4px 15px rgba(244, 196, 48, 0.15) !important;
    }
    
    .thumbnail-strip-{{ section.id }}__image-wrapper {
      border-radius: 12px 12px 0 0 !important;
      aspect-ratio: 1 / 1.15 !important;
      overflow: hidden !important;
      width: 100% !important;
    }
    
    .thumbnail-strip-{{ section.id }}__info {
      padding: 12px 14px !important;
      background-color: #111111 !important;
      border-radius: 0 0 12px 12px !important;
      display: flex !important;
      flex-direction: row !important;
      justify-content: space-between !important;
      align-items: center !important;
      box-sizing: border-box !important;
    }
    
    .thumbnail-strip-{{ section.id }}__color-wrap {
      display: flex !important;
      align-items: center !important;
      gap: 6px !important;
    }
    
    .thumbnail-strip-{{ section.id }}__dot {
      width: 8px !important;
      height: 8px !important;
      border-radius: 50% !important;
      display: block !important;
      border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }
    
    .thumbnail-strip-{{ section.id }}__text {
      font-size: 11px !important;
      font-weight: 600 !important;
      letter-spacing: 0.5px !important;
      color: #FFFFFF !important;
    }
    
    .thumbnail-strip-{{ section.id }}__price {
      font-size: 11px !important;
