<div class="custom-hero">
  <div class="custom-hero__bg">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2500 | image_tag: class: 'custom-hero__image' }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-hero__image custom-hero__image--placeholder' }}
    {%- endif -%}
    <div class="custom-hero__overlay"></div>
  </div>

  <div class="custom-hero__left">
    <div class="custom-hero__vertical-text">
      {% assign brand_letters = "O,N,E,9" | split: "," %}
      {% for letter in brand_letters %}
        <span>{{ letter }}</span>
      {% endfor %}
    </div>
    <div class="custom-hero__icon">
      <svg width="40" height="40" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 18 L18 8 L32 18 L18 28 Z" stroke="#F4C430" stroke-width="2.5" fill="none" />
        <circle cx="18" cy="18" r="4.5" fill="#F4C430" />
        <line x1="0" y1="18" x2="4" y2="18" stroke="#F4C430" stroke-width="2.5" />
        <line x1="32" y1="18" x2="36" y2="18" stroke="#F4C430" stroke-width="2.5" />
      </svg>
    </div>
    <div class="custom-hero__line"></div>
  </div>
  
  <div class="custom-hero__main">
    <h1 class="custom-hero__title">{{ section.settings.title | newline_to_br }}</h1>
    <p class="custom-hero__subtitle">{{ section.settings.subtitle }}</p>
    <a href="{{ section.settings.button_link }}" class="custom-hero__button">{{ section.settings.button_text }}</a>
  </div>
</div>

<style>
  .custom-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 700px;
    display: flex;
    background-color: #0A0A0A;
    color: #FFFFFF;
    overflow: hidden;
  }
  
  .custom-hero__bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  
  .custom-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  .custom-hero__image--placeholder {
    filter: brightness(0.7);
  }
  
  .custom-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 75% 50%, rgba(10,10,10,0) 0%, rgba(10,10,10,0.6) 50%, rgba(10,10,10,1) 100%);
  }
  
  .custom-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 65%;
    height: 100%;
    background: linear-gradient(to right, rgba(10,10,10,1) 0%, rgba(10,10,10,0.85) 45%, rgba(10,10,10,0) 100%);
    z-index: 1;
  }
  
  .custom-hero__left {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 80px 40px;
    width: 120px;
    flex-shrink: 0;
  }
  
  .custom-hero__vertical-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    font-size: 40px;
    font-weight: 900;
    color: #F4C430;
    font-family: 'Archivo Black', 'Anton', sans-serif;
    text-transform: uppercase;
  }
  
  .custom-hero__vertical-text span {
    display: block;
    line-height: 0.9;
    margin-bottom: 2px;
    transform: rotate(90deg); /* Or just stack as letters, the prompt said rotated 90 deg */
  }
  
  /* Applying full rotation to the container instead of individual letters to match standard "rotated 90 deg" design */
  .custom-hero__vertical-text {
    transform: rotate(-90deg);
    flex-direction: row;
    margin-bottom: 60px;
    margin-top: 20px;
    letter-spacing: 2px;
  }
  .custom-hero__vertical-text span {
    transform: none;
    margin-bottom: 0;
  }
  
  .custom-hero__icon {
    margin: 24px 0;
  }
  
  .custom-hero__line {
    width: 1px;
    flex-grow: 1;
    max-height: 300px;
    background-color: #F4C430;
  }
  
  .custom-hero__main {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 0;
    max-width: 800px;
  }
  
  .custom-hero__title {
    font-size: 4.5rem; /* ~72px */
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    margin: 0 0 24px 0;
    color: #FFFFFF;
    font-family: 'Archivo Black', 'Anton', sans-serif;
    letter-spacing: 1px;
  }
  
  .custom-hero__subtitle {
    font-size: 1.25rem; /* ~20px */
    color: #B0B0B0;
    margin: 0 0 48px 0;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-weight: 400;
  }
  
  .custom-hero__button {
    display: inline-block;
    background: #F4C430;
    color: #000000;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 1.125rem;
    padding: 16px 52px;
    text-decoration: none;
    border-radius: 4px; /* rounded-rect */
    box-shadow: 0 0 30px rgba(244, 196, 48, 0.4);
    align-self: flex-start;
    transition: all 0.3s ease;
    letter-spacing: 1px;
  }
  
  .custom-hero__button:hover {
    box-shadow: 0 0 40px rgba(244, 196, 48, 0.6);
    transform: translateY(-2px);
    background: #F8D050;
  }
  
  @media (max-width: 1200px) {
    .custom-hero__title {
      font-size: 4rem;
    }
  }
  
  @media (max-width: 990px) {
    .custom-hero__title {
      font-size: 3.5rem;
    }
    .custom-hero__subtitle {
      font-size: 1.15rem;
    }
    .custom-hero__button {
      padding: 14px 40px;
      font-size: 1rem;
    }
  }
  
  @media (max-width: 768px) {
    .custom-hero {
      flex-direction: column;
      height: auto;
      min-height: 80vh;
    }
    
    .custom-hero::before {
      width: 100%;
      height: 60%;
      background: linear-gradient(to bottom, rgba(10,10,10,1) 0%, rgba(10,10,10,0.7) 60%, rgba(10,10,10,0) 100%);
    }
    
    .custom-hero__left {
      flex-direction: row;
      justify-content: center;
      padding: 30px 20px 10px;
      width: 100%;
    }
    
    .custom-hero__vertical-text {
      transform: none;
      margin-bottom: 0;
      margin-top: 0;
      margin-right: 15px;
      font-size: 32px;
    }
    
    .custom-hero__icon {
      margin: 0 15px;
    }
    
    .custom-hero__line {
      width: 50px;
      height: 1px;
      margin-top: 0;
    }
    
    .custom-hero__main {
      padding: 20px 30px 60px;
      text-align: center;
      align-items: center;
    }
    
    .custom-hero__title {
      font-size: 3rem;
    }
    
    .custom-hero__button {
      align-self: center;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [
    {
      "type": "textarea",
      "id": "title",
      "label": "Heading",
      "default": "INSULATED JACKET\nFOR EVERYDAY WEAR"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subheading",
      "default": "Engineered for warmth. Designed for movement."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    }
  ],
  "presets": [
    {
      "name": "Custom Hero",
      "category": "Custom"
    }
  ]
}
{% endschema %}
